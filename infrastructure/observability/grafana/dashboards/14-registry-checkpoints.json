          "id": 22,
          "type": "stat",
          "title": "BM25 Cache Hit Rate",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 6, "x": 12, "y": 44 },
          "targets": [
            {
              "expr": "rate(memory_bm25_cache_hits_total[$__rate_interval]) / (rate(memory_bm25_cache_hits_total[$__rate_interval]) + rate(memory_bm25_cache_misses_total[$__rate_interval])) * 100",
