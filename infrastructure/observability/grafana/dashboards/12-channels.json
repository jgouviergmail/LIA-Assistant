      "title": "Processing Duration P95",
      "type": "timeseries",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(channel_message_processing_duration_seconds_bucket{channel_type=~\"$channel_type\"}[$__rate_interval])))",
