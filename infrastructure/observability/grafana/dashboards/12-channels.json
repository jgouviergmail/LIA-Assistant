          "title": "Active Bindings",
          "type": "stat",
          "datasource": "$datasource",
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
          "targets": [
            {
              "expr": "channel_active_bindings{channel_type=~\"$channel_type\"}",
              "legendFormat": " ",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "value": null, "color": "green" }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "graphMode": "none",
            "colorMode": "value",
            "textMode": "auto",
            "justifyMode": "auto",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            }
          }
        },
