{
  "title": "12 - Channels / Telegram",
  "uid": "12-channels",
  "description": "Monitoring des channels de messagerie externe (Telegram). Requiert CHANNELS_ENABLED=true.",
  "tags": ["lia", "channels", "telegram"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "LIA",
      "type": "dashboards",
      "tags": ["lia"],
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "channel_type",
        "type": "query",
        "datasource": "$datasource",
        "query": "label_values(channel_messages_received_total, channel_type)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Message Flow",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "title": "Messages Received",
      "type": "timeseries",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (message_type) (rate(channel_messages_received_total{channel_type=~\"$channel_type\"}[$__rate_interval]))",
          "legendFormat": "{{message_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "Messages Sent",
      "type": "timeseries",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "sum by (message_type) (rate(channel_messages_sent_total{channel_type=~\"$channel_type\"}[$__rate_interval]))",
          "legendFormat": "{{message_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
