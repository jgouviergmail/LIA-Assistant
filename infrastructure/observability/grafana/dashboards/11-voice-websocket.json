  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "voice_name",
        "type": "query",
        "datasource": "$datasource",
        "query": "label_values(voice_tts_requests_total, voice_name)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "TTS (Text-to-Speech)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "title": "TTS Requests Rate",
      "type": "timeseries",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (status, voice_name) (rate(voice_tts_requests_total{voice_name=~\"$voice_name\"}[$__rate_interval]))",
          "legendFormat": "{{voice_name}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "TTS Latency P95",
      "type": "timeseries",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (voice_name, le) (rate(voice_tts_latency_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{voice_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "title": "TTS Error Rate",
      "type": "stat",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(voice_tts_requests_total{status=\"error\"}[$__rate_interval])) / sum(rate(voice_tts_requests_total[$__rate_interval])) * 100",
          "legendFormat": " ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
