{
  "title": "02 - SLO Tracking",
  "uid": "02-slo-tracking",
  "tags": ["lia", "slo", "reliability"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "LIA",
      "type": "dashboards",
      "tags": ["lia"],
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "slo_window",
        "type": "custom",
        "query": "7d,14d,30d",
        "current": {
          "text": "30d",
          "value": "30d",
          "selected": true
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [
          { "text": "7d", "value": "7d", "selected": false },
          { "text": "14d", "value": "14d", "selected": false },
          { "text": "30d", "value": "30d", "selected": true }
        ],
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "API SLOs",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "title": "Availability (target 99.9%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 98 },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "api:slo:availability:ratio_5m * 100",
          "legendFormat": "Availability"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Budget Trend",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 }
            ]
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "line"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "api:slo:error_budget:remaining_30d * 100",
          "legendFormat": "Error Budget %"
        }
