{
  "title": "10 - OAuth, Connectors & MCP",
  "uid": "10-oauth-connectors-mcp",
  "tags": [
    "lia",
    "oauth",
    "connectors",
    "mcp"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "LIA",
      "type": "dashboards",
      "tags": [
        "lia"
      ],
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(oauth_callback_total, provider)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "connector_type",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(connector_api_requests_total, connector_type)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "mcp_server",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(mcp_tool_invocations_total, server_name)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "OAuth Flow",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
