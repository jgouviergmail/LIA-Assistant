    {
      "id": 2,
      "type": "timeseries",
      "title": "Callbacks (success/failure)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum by (provider, status) (rate(oauth_callback_total{provider=~\"$provider\"}[$__rate_interval]))",
          "legendFormat": "{{provider}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 30
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
