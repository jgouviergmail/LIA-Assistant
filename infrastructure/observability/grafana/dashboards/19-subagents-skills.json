      "id": 2,
      "type": "stat",
      "title": "Sub-Agents Spawned (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(subagent_spawned_total[24h]))",
          "legendFormat": " ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
