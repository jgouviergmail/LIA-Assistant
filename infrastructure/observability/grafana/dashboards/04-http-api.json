{
  "title": "04 - HTTP & API Performance",
  "uid": "04-http-api",
  "tags": ["lia", "http", "api", "latency"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "LIA",
      "type": "dashboards",
      "tags": ["lia"],
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "query": "label_values(http_requests_total, endpoint)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "method",
        "type": "custom",
        "query": "GET,POST,PUT,DELETE,PATCH",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Traffic Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests/sec",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{endpoint=~\"$endpoint\", method=~\"$method\"}[$__rate_interval]))",
          "legendFormat": "Total req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Status Code Distribution",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{endpoint=~\"$endpoint\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "type": "barchart",
      "title": "Top 10 Endpoints (1h)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "topk(10, sum by (endpoint) (increase(http_requests_total[1h])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "In-Progress Requests",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "sum by (endpoint) (http_requests_in_progress{endpoint=~\"$endpoint\"})",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Latency",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "panels": [
        {
          "id": 7,
          "type": "timeseries",
          "title": "P50/P95/P99 Latency",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
          "targets": [
            {
              "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__rate_interval])))",
              "legendFormat": "P50",
              "refId": "A"
            },
            {
              "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__rate_interval])))",
              "legendFormat": "P95",
              "refId": "B"
            },
            {
              "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__rate_interval])))",
              "legendFormat": "P99",
              "refId": "C"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 8,
          "type": "heatmap",
          "title": "Latency Heatmap",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
          "targets": [
            {
              "expr": "sum by (le) (increase(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__rate_interval]))",
              "refId": "A",
              "format": "heatmap"
            }
          ],
          "fieldConfig": {
            "defaults": {},
            "overrides": []
          },
          "options": {
            "calculate": false,
            "color": {
              "scheme": "Spectral"
            },
            "cellGap": 2,
            "yAxis": {
              "unit": "s"
            }
          }
        },
        {
          "id": 9,
          "type": "table",
          "title": "Slowest Endpoints (P95)",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
          "targets": [
            {
              "expr": "topk(15, http_request_duration:p95_5m)",
              "refId": "A",
              "format": "table",
              "instant": true
            }
          ],
          "fieldConfig": {
            "defaults": {},
            "overrides": []
          },
          "transformations": [
            {
              "id": "organize",
              "options": {
                "renameByName": {
                  "endpoint": "Endpoint",
                  "Value": "P95 Latency"
                }
              }
            }
          ],
          "options": {
            "showHeader": true,
            "sortBy": [{ "displayName": "P95 Latency", "desc": true }]
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Errors",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "panels": [
        {
          "id": 11,
          "type": "timeseries",
          "title": "Error Rate %",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
          "targets": [
            {
              "expr": "http_error_rate:5m * 100",
              "legendFormat": "Error Rate",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10,
                "thresholdsStyle": { "mode": "line" }
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "red", "value": 1.0 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "single" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 12,
          "type": "timeseries",
          "title": "Client Errors (4xx) par type",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
          "targets": [
            {
              "expr": "sum by (status) (rate(http_requests_total{endpoint=~\"$endpoint\", status=~\"4..\"}[$__rate_interval]))",
              "legendFormat": "{{status}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 13,
          "type": "timeseries",
          "title": "Server Errors (5xx) par type",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
          "targets": [
            {
              "expr": "sum by (status) (rate(http_requests_total{endpoint=~\"$endpoint\", status=~\"5..\"}[$__rate_interval]))",
              "legendFormat": "{{status}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 14,
          "type": "table",
          "title": "Error Requests Breakdown (1h)",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
          "targets": [
            {
              "expr": "topk(15, sum by (status, endpoint) (increase(http_requests_total{status=~\"[45]..\"}[1h])))",
              "refId": "A",
              "format": "table",
              "instant": true
            }
          ],
          "fieldConfig": {
            "defaults": {},
            "overrides": []
          },
          "options": {
            "showHeader": true,
            "sortBy": [{ "displayName": "Value", "desc": true }]
          }
        }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "Rate Limiting",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "panels": [
        {
          "id": 16,
          "type": "timeseries",
          "title": "HTTP Rate Limit Hits",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 44 },
          "targets": [
            {
              "expr": "sum by (endpoint_type) (rate(http_rate_limit_hits_total[$__rate_interval]))",
              "legendFormat": "{{endpoint_type}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 17,
          "type": "timeseries",
          "title": "Redis Allows vs Hits",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 44 },
          "targets": [
            {
              "expr": "sum(rate(redis_rate_limit_allows_total[$__rate_interval]))",
              "legendFormat": "Allows",
              "refId": "A"
            },
            {
              "expr": "sum(rate(redis_rate_limit_hits_total[$__rate_interval]))",
              "legendFormat": "Hits",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 18,
          "type": "timeseries",
          "title": "Check Latency P95",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 44 },
          "targets": [
            {
              "expr": "key_prefix:redis_rate_limit_check_duration_ms:p95_rate5m",
              "legendFormat": "{{key_prefix}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 19,
          "type": "timeseries",
          "title": "Sliding Window Current",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 52 },
          "targets": [
            {
              "expr": "redis_sliding_window_requests_current",
              "legendFormat": "Current Window",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "single" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 20,
          "type": "timeseries",
          "title": "Lua Script Executions",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 52 },
          "targets": [
            {
              "expr": "sum by (script_name, status) (rate(redis_lua_script_executions_total[$__rate_interval]))",
              "legendFormat": "{{script_name}} ({{status}})",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 21,
          "type": "timeseries",
          "title": "Rate Limit Errors",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 52 },
          "targets": [
            {
              "expr": "sum by (error_type) (rate(redis_rate_limit_errors_total[$__rate_interval]))",
              "legendFormat": "{{error_type}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        }
      ]
    }
  ]
}
