{
  "title": "21 - Health Metrics",
  "uid": "21-health-metrics",
  "tags": ["lia", "health-metrics"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "LIA",
      "type": "dashboards",
      "tags": ["lia"],
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Ingestion",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ingested samples (5 min)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(health_metrics_ingested_total[5m]))",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Ingestion rate (per minute)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "sum by (status) (rate(health_metrics_ingested_total[5m])) * 60",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active tokens (cumulative delta)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "sum(health_metrics_tokens_generated_total) - sum(health_metrics_tokens_revoked_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ingestion latency (p50/p95)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(health_metrics_ingest_duration_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(health_metrics_ingest_duration_seconds_bucket[5m])) by (le))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Validation rejections (per-field)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "expr": "sum by (field, reason) (rate(health_metrics_validation_rejected_total[5m])) * 60",
          "refId": "A",
          "legendFormat": "{{field}} / {{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Security & errors",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Auth failures",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(health_metrics_auth_failures_total[5m])) * 60",
          "refId": "A",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Rate-limit rejections",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "rate(health_metrics_rate_limit_hits_total[5m]) * 60",
          "refId": "A",
          "legendFormat": "per min"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Data lifecycle",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Tokens generated / revoked",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "targets": [
        {
          "expr": "rate(health_metrics_tokens_generated_total[5m]) * 60",
          "refId": "A",
          "legendFormat": "generated / min"
        },
        {
          "expr": "rate(health_metrics_tokens_revoked_total[5m]) * 60",
          "refId": "B",
          "legendFormat": "revoked / min"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Deletions by scope",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "targets": [
        {
          "expr": "sum by (scope) (rate(health_metrics_deleted_total[5m])) * 60",
          "refId": "A",
          "legendFormat": "{{scope}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "time": { "from": "now-6h", "to": "now" }
}
