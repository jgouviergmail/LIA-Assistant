      "panels": []
    },
    {
      "id": 1,
      "title": "Total Interrupts (24h)",
      "type": "stat",
      "datasource": "$datasource",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(hitl_interrupts_total[24h]))",
          "legendFormat": " ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "auto",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
