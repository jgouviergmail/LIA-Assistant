                    "1": { "text": "ENABLED", "index": 0 },
                    "0": { "text": "DISABLED", "index": 1 }
                  }
                }
              ],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "green", "value": 1 }
