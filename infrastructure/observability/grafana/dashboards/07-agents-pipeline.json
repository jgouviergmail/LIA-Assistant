{
  "title": "07 - Agent Orchestration Pipeline",
  "uid": "07-agents-pipeline",
  "tags": ["lia", "agents", "langgraph", "orchestration"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "LIA",
      "type": "dashboards",
      "tags": ["lia"],
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "node_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "query": "label_values(agent_node_executions_total, node_name)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "intention",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "query": "label_values(router_decisions_total, intention)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "agent_type",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "query": "label_values(agent_success_rate_total, agent_type)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Router",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Router Latency P50/P95",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(router_latency_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(router_latency_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Decision Distribution (1h)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "router_decisions_by_intention:1h",
          "legendFormat": "{{intention}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" },
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Confidence by Intention",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (intention, le) (rate(router_confidence_score_bucket{intention=~\"$intention\"}[$__rate_interval])))",
          "legendFormat": "{{intention}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Fallback Rate",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "sum(rate(router_fallback_total[$__rate_interval])) / sum(rate(router_decisions_total[$__rate_interval])) * 100",
          "legendFormat": " ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Data Presumption Decisions",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 9 },
      "targets": [
        {
          "expr": "sum by (pattern_detected, decision) (rate(router_data_presumption_total[$__rate_interval]))",
          "legendFormat": "{{pattern_detected}} - {{decision}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
