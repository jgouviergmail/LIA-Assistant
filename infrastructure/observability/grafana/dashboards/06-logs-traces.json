      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 81 },
      "panels": [
        {
          "id": 22,
          "type": "logs",
          "title": "Filterable Agent Logs",
          "datasource": {
            "type": "loki",
            "uid": "$datasource_loki"
          },
          "gridPos": { "h": 14, "w": 24, "x": 0, "y": 82 },
