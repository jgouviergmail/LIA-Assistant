  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Log Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log Volume by Level",
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "$datasource_loki"
          },
          "expr": "sum by (level) (rate({job=\"api\", level=~\"$log_level\"}[1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 50,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate by Logger",
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "$datasource_loki"
          },
          "expr": "sum by (logger) (rate({job=\"api\", level=\"error\"}[1m]))",
          "legendFormat": "{{logger}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Error Logs (live tail)",
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "$datasource_loki"
          },
          "expr": "{job=\"api\", level=~\"error|critical\"} | json | line_format \"{{.timestamp}} [{{.level}}] {{.logger}} | {{.event}} | {{.error}}\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Warning Logs",
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "$datasource_loki"
          },
          "expr": "{job=\"api\", level=\"warning\"} | json | line_format \"{{.timestamp}} [{{.level}}] {{.logger}} | {{.event}} | {{.message}}\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Trace Overview",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "panels": [
        {
          "id": 7,
          "type": "timeseries",
          "title": "Trace Duration P50/P95/P99",
          "datasource": {
            "type": "tempo",
            "uid": "$datasource_tempo"
          },
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "tempo",
                "uid": "$datasource_tempo"
              },
              "queryType": "traceql",
              "query": "{name=~\"router.*|response.*\"} | quantile_over_time(duration, 0.5) by (name)",
              "legendFormat": "{{name}} P50"
            },
            {
              "refId": "B",
              "datasource": {
                "type": "tempo",
                "uid": "$datasource_tempo"
              },
              "queryType": "traceql",
              "query": "{name=~\"router.*|response.*\"} | quantile_over_time(duration, 0.95) by (name)",
              "legendFormat": "{{name}} P95"
            },
            {
              "refId": "C",
              "datasource": {
                "type": "tempo",
                "uid": "$datasource_tempo"
              },
              "queryType": "traceql",
              "query": "{name=~\"router.*|response.*\"} | quantile_over_time(duration, 0.99) by (name)",
              "legendFormat": "{{name}} P99"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "linear",
                "fillOpacity": 10,
                "showPoints": "never",
                "spanNulls": false
              },
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 8,
          "type": "barchart",
          "title": "Trace Spans per Operation",
          "datasource": {
            "type": "tempo",
            "uid": "$datasource_tempo"
          },
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "tempo",
                "uid": "$datasource_tempo"
              },
              "queryType": "traceql",
              "query": "{name=~\"router.*|response.*\"} | count() by (name)",
              "legendFormat": "{{name}}"
            }
          ],
          "options": {
            "orientation": "horizontal",
            "legend": { "displayMode": "list", "placement": "bottom" }
          },
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          }
        },
        {
          "id": 9,
          "type": "traces",
          "title": "Traces Search (Recent 100)",
          "datasource": {
            "type": "tempo",
            "uid": "$datasource_tempo"
          },
          "gridPos": { "h": 12, "w": 24, "x": 0, "y": 30 },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "tempo",
                "uid": "$datasource_tempo"
              },
              "queryType": "traceql",
              "query": "{name=~\"router.*|response.*\"}",
              "limit": 100
            }
          ],
          "options": {
            "sortBy": "startTime",
            "sortOrder": "desc"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Metric-to-Log Correlation",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "panels": [
        {
          "id": 11,
          "type": "timeseries",
          "title": "HTTP 5xx + Error Logs",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "prometheus",
                "uid": "$datasource"
              },
              "expr": "sum(rate(http_requests_total{status=~\"5..\"}[$__rate_interval]))",
              "legendFormat": "5xx Rate"
            },
            {
              "refId": "B",
              "datasource": {
                "type": "loki",
                "uid": "$datasource_loki"
              },
              "expr": "sum(rate({job=\"api\", level=\"error\"} | json | status_code >= 500 [1m]))",
              "legendFormat": "Error Logs"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "linear",
                "fillOpacity": 10,
                "showPoints": "never",
                "spanNulls": false
              },
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 12,
          "type": "timeseries",
          "title": "LLM Errors + Logs",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
