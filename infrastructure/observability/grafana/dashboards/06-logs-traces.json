            {
              "refId": "A",
              "datasource": {
                "type": "prometheus",
                "uid": "$datasource"
              },
              "expr": "sum by (provider) (rate(llm_api_calls_total{status=\"error\"}[$__rate_interval]))",
              "legendFormat": "{{provider}}"
            },
            {
              "refId": "B",
              "datasource": {
                "type": "loki",
                "uid": "$datasource_loki"
              },
              "expr": "sum(rate({job=\"api\", level=\"error\"} | json | logger=~\".*llm.*|.*adapter.*\" [1m]))",
              "legendFormat": "LLM Error Logs"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "linear",
                "fillOpacity": 10,
                "showPoints": "never",
                "spanNulls": false
              },
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 13,
          "type": "timeseries",
          "title": "Graph Exceptions + Logs",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 51 },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "prometheus",
                "uid": "$datasource"
              },
              "expr": "sum by (exception_type) (rate(graph_exceptions_total[$__rate_interval]))",
              "legendFormat": "{{exception_type}}"
            },
            {
              "refId": "B",
              "datasource": {
                "type": "loki",
                "uid": "$datasource_loki"
              },
              "expr": "sum(rate({job=\"api\", level=\"error\"} | json | event=~\"graph_exception.*\" [1m]))",
              "legendFormat": "Exception Logs"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "linear",
                "fillOpacity": 10,
                "showPoints": "never",
                "spanNulls": false
              },
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Correlated View (Logs \u2192 Traces)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 59 },
      "panels": [
        {
          "id": 15,
          "type": "logs",
          "title": "Router Decisions (with trace links)",
          "datasource": {
            "type": "loki",
            "uid": "$datasource_loki"
          },
          "gridPos": { "h": 12, "w": 12, "x": 0, "y": 60 },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "loki",
                "uid": "$datasource_loki"
              },
              "expr": "{job=\"api\", event=\"router_decision\"} | json | line_format \"Intention: {{.intention}} | Confidence: {{.confidence}} | TraceID: {{.trace_id}}\""
            }
          ],
          "options": {
            "showLabels": true,
            "showTime": true,
            "wrapLogMessage": true,
            "enableLogDetails": true,
            "sortOrder": "Descending"
          },
          "fieldConfig": {
            "defaults": {},
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "Line" },
                "properties": [
                  {
                    "id": "links",
                    "value": [
                      {
                        "title": "View Trace in Tempo",
                        "url": "/explore?left=%7B%22datasource%22:%22Tempo%22,%22queries%22:%5B%7B%22queryType%22:%22traceql%22,%22query%22:%22%7Btrace_id%3D%5C%22${__data.fields.trace_id}%5C%22%7D%22%7D%5D%7D",
                        "targetBlank": true
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "id": 16,
          "type": "logs",
          "title": "Error Events (with trace links)",
          "datasource": {
            "type": "loki",
            "uid": "$datasource_loki"
          },
          "gridPos": { "h": 12, "w": 12, "x": 12, "y": 60 },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "loki",
                "uid": "$datasource_loki"
              },
              "expr": "{job=\"api\", level=\"error\"} | json | line_format \"{{.event}} | Error: {{.error}} | TraceID: {{.trace_id}}\""
            }
          ],
          "options": {
            "showLabels": true,
            "showTime": true,
            "wrapLogMessage": true,
            "enableLogDetails": true,
            "sortOrder": "Descending"
          },
          "fieldConfig": {
            "defaults": {},
