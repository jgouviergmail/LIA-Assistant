          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "decimals": 0,
              "color": {
                "mode": "fixed",
                "fixedColor": "blue"
              }
            },
            "overrides": []
          },
          "options": {
            "graphMode": "area",
            "colorMode": "value",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
