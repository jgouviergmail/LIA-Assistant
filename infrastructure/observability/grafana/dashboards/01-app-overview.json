{
  "title": "01 - Application Overview",
  "uid": "01-app-overview",
  "tags": ["lia", "overview", "health"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "LIA",
      "type": "dashboards",
      "tags": ["lia"],
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health Summary",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API Availability (30d)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "api:slo:availability:ratio_5m * 100",
          "legendFormat": " ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 98 },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Budget Remaining",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "api:slo:error_budget:remaining_30d * 100",
          "legendFormat": " ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Budget Burn Rate (1h)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "api:slo:error_budget:burn_rate_1h",
          "legendFormat": " ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Users (DAU)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "user_active_daily_gauge",
          "legendFormat": "DAU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active Users (WAU)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "user_active_weekly_gauge",
          "legendFormat": "WAU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Conversations Today",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "conversations_created_last_24h",
          "legendFormat": " ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Request Performance",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "panels": [
        {
          "id": 9,
          "type": "timeseries",
          "title": "Request Rate",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
          "targets": [
            {
              "expr": "http_requests:rate5m",
              "legendFormat": "Requests/s",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10,
                "showPoints": "auto"
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "single" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 10,
          "type": "timeseries",
          "title": "HTTP Error Rate (5xx)",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
          "targets": [
            {
              "expr": "http_error_rate:5m * 100",
              "legendFormat": "Error Rate %",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10,
                "showPoints": "auto",
                "thresholdsStyle": {
                  "mode": "dashed"
                }
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "red", "value": 0.1 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "single" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 11,
          "type": "timeseries",
          "title": "P95 Latency (top 10)",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
          "targets": [
            {
              "expr": "topk(10, http_request_duration:p95_5m)",
              "legendFormat": "{{endpoint}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10,
                "showPoints": "auto"
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "single" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 12,
          "type": "stat",
          "title": "Requests In Progress",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
          "targets": [
            {
              "expr": "sum(http_requests_in_progress)",
              "legendFormat": " ",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short"
            },
            "overrides": []
          },
          "options": {
            "graphMode": "none",
            "colorMode": "value",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Agent Pipeline Health",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "panels": [
        {
          "id": 14,
          "type": "bargauge",
          "title": "Node Success Rate",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
          "targets": [
            {
              "expr": "agent_node_success_rate:5m * 100",
              "legendFormat": "{{node_name}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "yellow", "value": 90 },
                  { "color": "orange", "value": 95 },
                  { "color": "green", "value": 99 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "orientation": "horizontal",
            "displayMode": "gradient",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        },
        {
          "id": 15,
          "type": "piechart",
          "title": "Router Distribution (1h)",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
          "targets": [
            {
              "expr": "router_decisions_by_intention:1h",
              "legendFormat": "{{intention}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short"
            },
            "overrides": []
          },
          "options": {
            "pieType": "donut",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            },
            "legend": {
              "displayMode": "list",
              "placement": "right"
            }
          }
        },
        {
          "id": 16,
          "type": "stat",
          "title": "E2E Duration P95",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 4, "x": 16, "y": 27 },
          "targets": [
            {
              "expr": "histogram_quantile(0.95, sum by (le) (rate(e2e_request_duration_seconds_bucket[$__rate_interval])))",
              "legendFormat": "P95",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "decimals": 2
            },
            "overrides": []
          },
          "options": {
            "graphMode": "area",
            "colorMode": "value",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        },
        {
          "id": 17,
          "type": "stat",
          "title": "TTFT P95",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 4, "x": 20, "y": 27 },
          "targets": [
            {
              "expr": "histogram_quantile(0.95, sum by (le) (rate(sse_time_to_first_token_seconds_bucket[$__rate_interval])))",
              "legendFormat": "P95",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "decimals": 2
            },
            "overrides": []
          },
          "options": {
            "graphMode": "area",
            "colorMode": "value",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        }
      ]
    },
    {
      "id": 18,
      "type": "row",
      "title": "Infrastructure Quick Glance",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "panels": [
        {
          "id": 19,
          "type": "gauge",
          "title": "CPU Usage Total",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 5, "x": 0, "y": 36 },
          "targets": [
            {
              "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])) * 100)",
              "legendFormat": " ",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 60 },
                  { "color": "orange", "value": 80 },
                  { "color": "red", "value": 90 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        },
        {
          "id": 20,
          "type": "gauge",
          "title": "Memory Usage",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 5, "x": 5, "y": 36 },
          "targets": [
            {
              "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
              "legendFormat": " ",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 60 },
                  { "color": "orange", "value": 80 },
                  { "color": "red", "value": 90 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        },
        {
          "id": 21,
          "type": "gauge",
          "title": "DB Pool Utilization",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 5, "x": 10, "y": 36 },
          "targets": [
            {
              "expr": "db_connection_pool_checkedout / db_connection_pool_size * 100",
              "legendFormat": " ",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 60 },
                  { "color": "orange", "value": 80 },
                  { "color": "red", "value": 90 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        },
        {
          "id": 22,
          "type": "stat",
          "title": "Cache Hit Rate",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 5, "x": 15, "y": 36 },
          "targets": [
            {
              "expr": "cache_hit_rate:5m * 100",
              "legendFormat": " ",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "decimals": 1,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "orange", "value": 30 },
                  { "color": "yellow", "value": 50 },
                  { "color": "green", "value": 80 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "graphMode": "none",
            "colorMode": "value",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        },
        {
          "id": 23,
          "type": "stat",
          "title": "Redis Memory",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 4, "x": 20, "y": 36 },
          "targets": [
            {
              "expr": "redis_memory_used_bytes",
              "legendFormat": " ",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "bytes",
              "decimals": 0
            },
            "overrides": []
          },
          "options": {
            "graphMode": "none",
            "colorMode": "value",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        }
      ]
    },
    {
      "id": 24,
      "type": "row",
      "title": "LLM Cost Summary",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
