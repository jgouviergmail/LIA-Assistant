    },
    {
      "id": 29,
      "type": "row",
      "title": "Features",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "panels": [
        {
          "id": 30,
          "type": "stat",
          "title": "Attachments (24h)",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 4, "x": 0, "y": 54 },
          "targets": [
            {
              "expr": "sum(increase(attachments_uploaded_total{status=\"success\"}[24h]))",
