                "mode": "absolute",
                "steps": [
                  { "value": null, "color": "green" },
                  { "value": 10, "color": "yellow" },
                  { "value": 25, "color": "red" }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "graphMode": "area",
            "colorMode": "value",
            "textMode": "auto",
            "justifyMode": "auto",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            }
          }
        },
        {
          "id": 23,
          "title": "HITL Approval Rate",
          "type": "stat",
          "datasource": "$datasource",
          "gridPos": { "h": 6, "w": 6, "x": 18, "y": 24 },
          "targets": [
            {
              "expr": "hitl_approval_rate:1h * 100",
              "legendFormat": " ",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "value": null, "color": "red" },
                  { "value": 60, "color": "yellow" },
                  { "value": 80, "color": "green" }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "graphMode": "area",
            "colorMode": "value",
            "textMode": "auto",
            "justifyMode": "auto",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            }
          }
        },
        {
          "id": 24,
          "title": "Abandonment by Reason",
          "type": "piechart",
          "datasource": "$datasource",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
          "targets": [
            {
              "expr": "sum by (abandonment_reason) (increase(conversation_abandonment_total[24h]))",
              "legendFormat": "{{abandonment_reason}}",
              "refId": "A",
              "instant": true
            }
          ],
          "options": {
            "pieType": "donut",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            },
            "legend": {
              "displayMode": "table",
              "placement": "right",
              "values": ["value", "percent"]
            },
            "tooltip": { "mode": "multi" }
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short"
            },
            "overrides": []
          }
        },
        {
          "id": 25,
          "title": "Cost per Conversation Trend",
          "type": "timeseries",
          "datasource": "$datasource",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
          "targets": [
            {
              "expr": "business:conversation:cost_avg_usd:1h",
              "legendFormat": "Avg cost",
              "refId": "A"
            },
            {
              "expr": "histogram_quantile(0.95, sum by (le) (rate(conversation_cost_usd_bucket[$__rate_interval])))",
              "legendFormat": "P95 cost",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "currencyEUR",
              "custom": {
                "drawStyle": "line",
