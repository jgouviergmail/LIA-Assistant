{
  "title": "17 - User Analytics & Geolocation",
  "uid": "17-user-analytics-geo",
  "description": "Analyse utilisateur : geolocalisation IP, periodes d'activite, outils les plus utilises, engagement. Requiert GeoIP DB-IP Lite.",
  "tags": ["lia", "users", "analytics", "geolocation"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "LIA",
      "type": "dashboards",
      "tags": ["lia"],
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "datasource_loki",
        "type": "datasource",
        "query": "loki",
        "current": {},
        "hide": 0
      },
      {
        "name": "country",
        "type": "query",
        "datasource": "$datasource",
        "query": "label_values(http_requests_by_country_total, country)",
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Geographic Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "title": "Request Origins (World Map)",
      "description": "Geographic distribution of API requests. Requires GeoIP DB-IP Lite MMDB. Private/local IPs are excluded.",
      "type": "geomap",
      "datasource": "$datasource",
      "gridPos": { "h": 14, "w": 16, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (country) (http_requests_by_country_total{country!~\"local|unknown\"})",
          "legendFormat": "{{country}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "view": {
          "id": "coords",
          "lat": 46.5,
          "lon": 2.2,
          "zoom": 3
        },
        "basemap": {
          "type": "default"
        },
        "layers": [
          {
            "type": "markers",
            "name": "Requests",
            "config": {
              "style": {
                "size": {
                  "fixed": 5,
                  "min": 2,
                  "max": 15
                },
                "color": {
                  "fixed": "dark-green"
                },
                "opacity": 0.7
              },
              "showLegend": true
            },
            "location": {
              "mode": "lookup",
              "lookup": "country",
              "gazetteer": "public/gazetteer/countries.json"
            }
          }
        ],
        "tooltip": {
          "mode": "details"
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Requests by Country",
      "type": "piechart",
      "datasource": "$datasource",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum by (country) (http_requests_by_country_total{country=~\"$country\"})",
          "legendFormat": "{{country}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Request Rate by Country",
      "type": "timeseries",
      "datasource": "$datasource",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum by (country) (rate(http_requests_by_country_total{country=~\"$country\", country!~\"local|unknown\"}[$__rate_interval]))",
          "legendFormat": "{{country}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
