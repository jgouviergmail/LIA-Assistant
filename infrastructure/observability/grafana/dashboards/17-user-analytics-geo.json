                "fillOpacity": 10,
                "lineWidth": 1
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          }
        }
      ]
