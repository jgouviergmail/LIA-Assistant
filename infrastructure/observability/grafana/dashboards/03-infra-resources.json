          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short"
            },
            "overrides": []
          },
          "options": {
            "graphMode": "none",
            "colorMode": "value",
            "reduceOptions": {
              "calcs": ["lastNotNull"]
            }
          }
        }
      ]
    }
  ]
}
