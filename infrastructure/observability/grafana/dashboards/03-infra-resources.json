            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 25,
          "type": "timeseries",
          "title": "Connected Clients",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 68 },
          "targets": [
            {
              "expr": "redis_connected_clients",
              "legendFormat": "Clients",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short"
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 26,
          "type": "timeseries",
          "title": "Commands/sec",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 68 },
          "targets": [
            {
              "expr": "rate(redis_commands_processed_total[$__rate_interval])",
              "legendFormat": "Commands/s",
