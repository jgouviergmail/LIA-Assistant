            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops"
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 27,
          "type": "timeseries",
          "title": "App Pool (size vs available)",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 76 },
          "targets": [
            {
              "expr": "redis_connection_pool_size_current",
              "legendFormat": "Pool Size",
              "refId": "A"
            },
            {
              "expr": "redis_connection_pool_available_current",
              "legendFormat": "Available",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short"
            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 28,
          "type": "stat",
          "title": "Keyspace Keys",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 76 },
