            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 11,
          "type": "piechart",
          "title": "Content Sources",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
          "targets": [
            {
              "expr": "sum by (source) (increase(proactive_content_source_total{task_type=~\"$task_type\"}[24h]))",
              "legendFormat": "{{source}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "thresholds": {
                "mode": "absolute",
