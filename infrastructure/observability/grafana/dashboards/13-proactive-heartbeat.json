            },
            "overrides": []
          },
          "options": {
            "tooltip": { "mode": "multi" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 10,
          "type": "timeseries",
          "title": "Cost (EUR)",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
          "targets": [
            {
              "expr": "sum by (task_type) (rate(proactive_cost_eur_total{task_type=~\"$task_type\"}[$__rate_interval]))",
              "legendFormat": "{{task_type}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "currencyEUR",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "value": null, "color": "green" }
