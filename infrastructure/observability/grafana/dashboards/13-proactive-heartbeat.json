      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "panels": [
        {
          "id": 13,
          "type": "timeseries",
          "title": "Eligibility Check Results",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 6, "x": 0, "y": 19 },
