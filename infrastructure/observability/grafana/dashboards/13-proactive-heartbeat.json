          "type": "timeseries",
          "title": "Tasks Processed Trend",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "gridPos": { "h": 8, "w": 6, "x": 12, "y": 19 },
          "targets": [
            {
              "expr": "sum by (task_type) (rate(proactive_task_processed_total[$__rate_interval]))",
              "legendFormat": "{{task_type}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "thresholds": {
                "mode": "absolute",
