    {
      "id": 2,
      "type": "stat",
      "title": "Tasks Processed (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 5,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum by (task_type) (increase(proactive_task_processed_total{task_type=~\"$task_type\"}[24h]))",
          "legendFormat": "{{task_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "auto",
        "justifyMode": "auto",
