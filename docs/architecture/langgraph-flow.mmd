    style SmartPlanner fill:#fff4e1
    style SemanticValidator fill:#e1ffe1
    style Clarification fill:#ffe1e1
    style ApprovalGate fill:#ffcccc
    style TaskOrchestrator fill:#e1ffe1
    style HITLDispatch fill:#ffe1e1
    style DomainAgents fill:#f0e1ff
    style PatternCheck fill:#fff9e1
    style SkillCheck fill:#fff9e1
    style MCPAgents fill:#f0e1ff
    style SubAgentDelegation fill:#e1fff5
    style DelegateTool fill:#e1fff5
    style SubPipeline fill:#e1fff5
    style ReplanNoSA fill:#ffe1e1
