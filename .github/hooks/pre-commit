#!/bin/bash
#
# Pre-commit hook for LIA
# Ensures code quality before committing
#
# Installation:
#   ln -sf ../../.github/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#

set -e

echo "🔍 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any check fails
FAILED=0

# Function to print colored output
print_error() {
    echo -e "${RED}❌ $1${NC}"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_info() {
    echo -e "${YELLOW}ℹ️  $1${NC}"
}

# Check if we're on Windows (Git Bash)
# Note: Paths are relative to apps/api directory (we cd there before using these)
# On Windows, use python -m to avoid permission issues with .exe files in Git Bash
if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "win32" ]]; then
    PYTHON_BIN=".venv/Scripts/python.exe"
    PIP_BIN="$PYTHON_BIN -m pip"
    RUFF_BIN="$PYTHON_BIN -m ruff"
    BLACK_BIN="$PYTHON_BIN -m black"
    MYPY_BIN="$PYTHON_BIN -m mypy"
    PYTEST_BIN="$PYTHON_BIN -m pytest"
else
    PYTHON_BIN=".venv/bin/python"
    PIP_BIN=".venv/bin/pip"
    RUFF_BIN=".venv/bin/ruff"
    BLACK_BIN=".venv/bin/black"
    MYPY_BIN=".venv/bin/mypy"
    PYTEST_BIN=".venv/bin/pytest"
fi

# 0. Check for .bak files in staged changes
echo ""
print_info "Checking for .bak files..."
BAK_FILES=$(git diff --cached --name-only | grep ".bak$" || true)
if [ -n "$BAK_FILES" ]; then
    print_error "Backup files (.bak) detected in staged changes!"
    echo "    These files should not be committed:"
    echo "$BAK_FILES" | sed 's/^/      /'
    echo ""
    echo "    Remove them with: git reset HEAD <file>"
    FAILED=1
else
    print_success "No .bak files detected"
fi

# 1. Check for secrets in staged files
echo ""
print_info "Checking for secrets..."
if git diff --cached --name-only | xargs grep -i "password\s*=\s*['\"]" 2>/dev/null | grep -v -E "(.env.example|tests/|TESTING.md|README.md|docs/|docker-entrypoint.sh)" | grep -v '\$2b\$12\$PLACEHOLDER'; then
    print_error "Potential secrets found in staged files!"
    FAILED=1
else
    print_success "No secrets detected"
fi

# 2. Backend checks (only if Python files are staged)
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.py$" || true)

if [ -n "$PYTHON_FILES" ]; then
    echo ""
    print_info "Running backend checks..."

    # 2.1 Ruff
    echo "  Running Ruff..."
    cd apps/api
    if ! $RUFF_BIN check src tests 2>&1; then
        print_error "Ruff check failed"
        FAILED=1
    else
        print_success "Ruff passed"
    fi

    # 2.2 Black
    echo "  Running Black..."
    if ! $BLACK_BIN --check src tests 2>&1; then
        print_error "Black check failed - run 'task format' to fix"
        FAILED=1
    else
        print_success "Black passed"
    fi

    # 2.3 MyPy
    echo "  Running MyPy..."
    if ! $MYPY_BIN src --config-file=pyproject.toml 2>&1; then
        print_error "MyPy check failed"
        FAILED=1
    else
        print_success "MyPy passed"
    fi

    # 2.4 Unit tests (fast only - same as `task test:backend:unit:fast`)
    echo "  Running fast unit tests..."
    if ! $PYTEST_BIN tests/unit/ --tb=short --no-cov -q -m "not integration" 2>&1; then
        print_error "Unit tests failed"
        FAILED=1
    else
        print_success "Unit tests passed"
    fi

    # 2.5 Phase 3.2.9: Critical Error Detection
    echo "  Checking for critical errors (Phase 3.2.9)..."

    # Get full paths for staged Python files (we're in apps/api now)
    STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.py$" || true)

    # Check for synchronous Store calls in async context (Erreur #5)
    SYNC_STORE_CALLS=$(echo "$STAGED_PY_FILES" | xargs grep -n "runtime\.store\.put(\|runtime\.store\.get(\|runtime\.store\.delete(\|runtime\.store\.search(" 2>/dev/null | grep -v "await " || true)

    if [ -n "$SYNC_STORE_CALLS" ]; then
        print_error "CRITICAL: Synchronous Store calls detected in async context!"
        echo "    This will cause InvalidStateError deadlocks"
        echo "    Use async methods: store.aput(), store.aget(), store.adelete(), store.asearch()"
        echo ""
        echo "    Problematic lines:"
        echo "$SYNC_STORE_CALLS" | sed 's/^/      /'
        echo ""
        echo "    Reference: runtime_helpers.py documentation (Store Interface)"
        FAILED=1
    fi

    # Check for Redis setex without json.dumps (Erreur #4)
    REDIS_SETEX_LINES=$(echo "$STAGED_PY_FILES" | xargs grep -n "\.setex(" 2>/dev/null || true)

    if [ -n "$REDIS_SETEX_LINES" ]; then
        # Check if json.dumps is used
        MISSING_JSON_DUMPS=$(echo "$REDIS_SETEX_LINES" | grep -v "json\.dumps(" || true)

        if [ -n "$MISSING_JSON_DUMPS" ]; then
            print_error "POTENTIAL: Redis setex() without json.dumps() detected"
            echo "    Redis only accepts bytes/string, not dict/list directly"
            echo "    Pattern: await redis_client.setex(key, ttl, json.dumps(data))"
            echo ""
            echo "    Lines to review:"
            echo "$MISSING_JSON_DUMPS" | sed 's/^/      /'
            echo ""
            echo "    Reference: redis_helpers.py (cache_set_json pattern)"
            FAILED=1
        fi
    fi

    # Check for missing json import in connector clients
    CLIENT_FILES=$(echo "$STAGED_PY_FILES" | grep "apps/api/src/domains/connectors/clients/" || true)

    if [ -n "$CLIENT_FILES" ]; then
        for file in $CLIENT_FILES; do
            # Check if file uses redis setex (needs json import)
            if grep -q "\.setex(" "$file" 2>/dev/null; then
                # Check if json is imported
                if ! grep -q "^import json" "$file" 2>/dev/null; then
                    print_error "CRITICAL: Missing 'import json' in $file"
                    echo "    This file uses redis.setex() but doesn't import json"
                    echo "    Add at top of file: import json"
                    echo ""
                    echo "    Reference: INTEGRATION_GUIDE.md Section 5.8 (Erreur #6)"
                    FAILED=1
                fi
            fi
        done
    fi

    if [ "$FAILED" -eq 0 ]; then
        print_success "No critical errors detected (Phase 3.2.9)"
    fi

    cd ../..
else
    print_info "No Python files staged, skipping backend checks"
fi

# 3. i18n keys sync (only if locale files are staged)
I18N_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "apps/web/locales/" || true)

if [ -n "$I18N_FILES" ]; then
    echo ""
    print_info "Checking i18n keys sync..."

    REFERENCE_LANG="en"
    LOCALES_DIR="apps/web/locales"
    I18N_FAILED=0

    if [ -f "$LOCALES_DIR/$REFERENCE_LANG/translation.json" ]; then
        for lang_dir in "$LOCALES_DIR"/*/; do
            lang=$(basename "$lang_dir")
            [ "$lang" = "$REFERENCE_LANG" ] && continue
            target_file="$lang_dir/translation.json"
            [ ! -f "$target_file" ] && continue

            # Compare keys using Python (handles nested JSON)
            DIFF_OUTPUT=$(python -c "
import json, sys

def get_keys(d, prefix=''):
    keys = set()
    for k, v in d.items():
        full = f'{prefix}.{k}' if prefix else k
        if isinstance(v, dict):
            keys |= get_keys(v, full)
        else:
            keys.add(full)
    return keys

with open('$LOCALES_DIR/$REFERENCE_LANG/translation.json', encoding='utf-8') as f:
    ref = get_keys(json.load(f))
with open('$target_file', encoding='utf-8') as f:
    tgt = get_keys(json.load(f))

missing = sorted(ref - tgt)
extra = sorted(tgt - ref)
if missing:
    print(f'MISSING in $lang ({len(missing)}):')
    for k in missing[:10]:
        print(f'  - {k}')
    if len(missing) > 10:
        print(f'  ... and {len(missing) - 10} more')
if extra:
    print(f'EXTRA in $lang ({len(extra)}):')
    for k in extra[:10]:
        print(f'  - {k}')
    if len(extra) > 10:
        print(f'  ... and {len(extra) - 10} more')
if missing or extra:
    sys.exit(1)
" 2>&1) || I18N_FAILED=1

            if [ -n "$DIFF_OUTPUT" ]; then
                echo "$DIFF_OUTPUT"
            fi
        done

        if [ "$I18N_FAILED" -eq 1 ]; then
            print_error "i18n keys are out of sync with '$REFERENCE_LANG'"
            FAILED=1
        else
            print_success "i18n keys are in sync"
        fi
    fi
else
    print_info "No i18n files staged, skipping i18n sync check"
fi

# 4. Alembic migration conflict detection
MIGRATION_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "apps/api/alembic/versions/" || true)

if [ -n "$MIGRATION_FILES" ]; then
    echo ""
    print_info "Checking for Alembic migration conflicts..."

    # Detect multiple migrations with the same date prefix (potential branch conflict)
    MIGRATION_DIR="apps/api/alembic/versions"
    DUPLICATE_PREFIXES=$(ls "$MIGRATION_DIR"/*.py 2>/dev/null | xargs -I{} basename {} | sed 's/-.*//' | sort | uniq -d || true)

    if [ -n "$DUPLICATE_PREFIXES" ]; then
        print_error "Potential Alembic migration conflict detected!"
        echo "    Multiple migrations share the same date prefix:"
        for prefix in $DUPLICATE_PREFIXES; do
            echo "    $prefix:"
            ls "$MIGRATION_DIR"/${prefix}-*.py 2>/dev/null | sed 's/^/      /'
        done
        echo ""
        echo "    This may cause 'Multiple heads' errors. Check revision chains."
        FAILED=1
    else
        print_success "No migration conflicts detected"
    fi
else
    print_info "No migration files staged, skipping migration check"
fi

# 5. .env.example sync check (only if Python files are staged)
if [ -n "$PYTHON_FILES" ]; then
    echo ""
    print_info "Checking .env.example completeness..."

    if [ -f ".env.example" ]; then
        # Extract setting names from .env.example (lines like KEY=value, ignoring comments)
        ENV_KEYS=$(grep -E "^[A-Z_]+=" .env.example | sed 's/=.*//' | sort -u)

        # Search for os.environ / os.getenv references in staged Python files that use new env vars
        NEW_ENV_REFS=$(echo "$PYTHON_FILES" | xargs grep -ohE '(os\.environ\[|os\.getenv\(|environ\.get\()"?([A-Z_]+)"?' 2>/dev/null | grep -oE '[A-Z][A-Z_]+[A-Z]' | sort -u || true)

        if [ -n "$NEW_ENV_REFS" ]; then
            MISSING_VARS=""
            for var in $NEW_ENV_REFS; do
                if ! echo "$ENV_KEYS" | grep -q "^${var}$"; then
                    MISSING_VARS="$MISSING_VARS $var"
                fi
            done

            if [ -n "$MISSING_VARS" ]; then
                print_error "Environment variables referenced in code but missing from .env.example:"
                for var in $MISSING_VARS; do
                    echo "    - $var"
                done
                echo ""
                echo "    Add them to .env.example with a default or placeholder value."
                FAILED=1
            else
                print_success ".env.example is up to date"
            fi
        else
            print_success ".env.example check passed (no new env refs)"
        fi
    fi
fi

# 6. Frontend checks (only if TS/TSX files are staged)
FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(ts|tsx)$" || true)

if [ -n "$FRONTEND_FILES" ]; then
    echo ""
    print_info "Running frontend checks..."

    cd apps/web

    # 6.1 ESLint
    echo "  Running ESLint..."
    if ! pnpm lint 2>&1; then
        print_error "ESLint check failed"
        FAILED=1
    else
        print_success "ESLint passed"
    fi

    # 6.2 TypeScript
    echo "  Running TypeScript check..."
    if ! pnpm type-check 2>&1; then
        print_error "TypeScript check failed"
        FAILED=1
    else
        print_success "TypeScript passed"
    fi

    cd ../..
else
    print_info "No TypeScript files staged, skipping frontend checks"
fi

# 7. Final verdict
echo ""
if [ $FAILED -eq 1 ]; then
    print_error "Pre-commit checks failed! Commit aborted."
    echo ""
    echo "To fix issues:"
    echo "  - Run 'task format' to auto-fix formatting"
    echo "  - Run 'task lint' to see all issues"
    echo "  - Run 'task test:backend:unit' to run tests"
    echo ""
    echo "To bypass this hook (NOT RECOMMENDED):"
    echo "  git commit --no-verify"
    exit 1
else
    print_success "All pre-commit checks passed!"
    exit 0
fi
