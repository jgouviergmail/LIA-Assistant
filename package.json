{
  "name": "lia",
  "version": "1.7.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "LIA - AI-powered personal assistant monorepo",
  "author": "LIA Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/jgouviergmail/LIA-Assistant.git"
  },
  "homepage": "https://github.com/jgouviergmail/LIA-Assistant",
  "scripts": {
    "setup": "bash scripts/setup-dev.sh",
    "dev": "docker compose -f docker-compose.dev.yml up -d",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:restart": "docker compose -f docker-compose.dev.yml restart",
    "prod:build": "docker compose -f docker-compose.prod.yml build",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "dev:web": "pnpm --filter @lia-assistant/web dev",
    "build:web": "pnpm --filter @lia-assistant/web build",
    "lint:web": "pnpm --filter @lia-assistant/web lint",
    "test:web": "pnpm --filter @lia-assistant/web test"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.18.3"
}
