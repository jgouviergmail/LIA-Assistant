# ===================================================================
# AlertManager Configuration - LIA
# ===================================================================
# Production-ready configuration with multi-channel routing
#
# Environment Variables Required (substituted via docker-entrypoint.sh):
#   - ALERTMANAGER_SMTP_FROM
#   - ALERTMANAGER_SMTP_SMARTHOST
#   - ALERTMANAGER_SMTP_AUTH_USERNAME
#   - ALERTMANAGER_SMTP_AUTH_PASSWORD
#   - ALERTMANAGER_BACKEND_TEAM_EMAIL
#   - ALERTMANAGER_FINANCE_TEAM_EMAIL
#   - ALERTMANAGER_SECURITY_TEAM_EMAIL
#   - ALERTMANAGER_ML_TEAM_EMAIL
#   - ALERTMANAGER_SLACK_WEBHOOK_CRITICAL (optional)
#   - ALERTMANAGER_SLACK_WEBHOOK_WARNING (optional)
#   - ALERTMANAGER_SLACK_WEBHOOK_SECURITY (optional)
#   - ALERTMANAGER_PAGERDUTY_ROUTING_KEY (optional)
# ===================================================================

global:
  # Time to wait before sending a notification about resolved alert
  resolve_timeout: 5m

  # SMTP configuration for email notifications
  smtp_from: '${ALERTMANAGER_SMTP_FROM}'
  smtp_smarthost: '${ALERTMANAGER_SMTP_SMARTHOST}'
  smtp_auth_username: '${ALERTMANAGER_SMTP_AUTH_USERNAME}'
  smtp_auth_password: '${ALERTMANAGER_SMTP_AUTH_PASSWORD}'
  smtp_require_tls: true

# Templates for notification messages
templates:
  - '/etc/alertmanager/templates/*.tmpl'

# ===================================================================
# ROUTING CONFIGURATION
# ===================================================================
route:
  # Default receiver if no route matches
  receiver: 'default-email'

  # Group alerts by these labels to reduce notification spam
  group_by: ['alertname', 'component', 'severity']

  # Wait time before sending first notification for a group
  group_wait: 30s

  # Wait time before sending notification about new alerts added to a group
  group_interval: 5m

  # Minimum wait time before re-sending notifications for an alert
  repeat_interval: 4h

  # ===== CHILD ROUTES WITH SPECIFIC ROUTING LOGIC =====
  routes:
    # ------------------------------------------------
    # CRITICAL SEVERITY - Multi-channel + Fastest delivery
    # ------------------------------------------------
    - match:
        severity: critical
      receiver: 'critical-multi-channel'
      group_wait: 10s           # Send faster for critical alerts
      group_interval: 2m
      repeat_interval: 30m      # Repeat more frequently if not resolved
      continue: false           # Don't evaluate other routes

    # ------------------------------------------------
    # WARNING SEVERITY - Email + Slack
    # ------------------------------------------------
    - match:
        severity: warning
      receiver: 'warning-email-slack'
      group_wait: 1m
      group_interval: 10m
      repeat_interval: 2h
      continue: false

    # ------------------------------------------------
    # COMPONENT-SPECIFIC ROUTING
    # ------------------------------------------------

    # LLM Budget Alerts (critical for cost control) → Finance team
    - match:
        component: llm
      match_re:
        alertname: '.*(Budget|Cost).*'
      receiver: 'llm-budget-finance'
      group_by: ['alertname', 'severity']
      group_wait: 5s            # Immediate notification for budget alerts
      repeat_interval: 15m
      continue: false

    # Agent Performance Alerts → ML team (business hours only)
    - match:
        component: agents
      receiver: 'agents-ml-team'
      group_by: ['alertname', 'intention']
      group_wait: 1m
      repeat_interval: 1h
      continue: false

    # Database Alerts → Backend team with DB label
    - match:
        component: postgresql
      receiver: 'database-backend-team'
      group_by: ['alertname', 'datname']
      continue: false

    # Redis Alerts → Backend team with Redis label
    - match:
        component: redis
      receiver: 'redis-backend-team'
      group_by: ['alertname']
      continue: false

    # OAuth Security Alerts → Security team + Immediate attention
    - match:
        component: oauth
        severity: critical
      receiver: 'security-team-critical'
      group_wait: 5s
      repeat_interval: 30m
      continue: false

    # HITL/Streaming Alerts → ML team
    - match_re:
        component: '(hitl|hitl_streaming)'
      receiver: 'hitl-ml-team'
      group_by: ['alertname', 'severity']
      group_wait: 30s
      repeat_interval: 4h
      continue: false

# ===================================================================
# INHIBITION RULES
# ===================================================================
# Prevent notification spam by inhibiting lower-priority alerts
# when higher-priority alerts are firing
inhibit_rules:
  # If service is down, don't alert on high error rate or latency
  - source_match:
      alertname: 'ServiceDown'
    target_match:
      component: 'api'
    target_match_re:
      alertname: '(HighErrorRate|HighLatency.*|CriticalLatency.*)'
    equal: ['service']

  # If Redis is down, don't alert on connection issues
  - source_match:
      alertname: 'RedisDown'
    target_match:
      component: 'redis'
    target_match_re:
      alertname: '(RedisConnectionsHigh|RedisMemoryHigh)'

  # If PostgreSQL is down, don't alert on connection pool issues
  - source_match:
      alertname: 'PostgreSQLDown'
    target_match:
      component: 'postgresql'
    target_match_re:
      alertname: '(HighDatabaseConnections|CriticalDatabaseConnections|SlowQueries)'

  # If container is down, don't alert on container-specific metrics
  - source_match:
      alertname: 'ContainerDown'
    target_match_re:
      alertname: '(HighCPUUsage|HighMemoryUsage|ContainerRestartingFrequently)'
    equal: ['container']

  # If daily budget exceeded, weekly/monthly alerts are redundant
  - source_match_re:
      alertname: '.*DailyBudget.*'
    target_match_re:
      alertname: '.*(Weekly|Monthly)Budget.*'
    equal: ['component']

  # If LLM API has high failure rate, don't alert on latency
  - source_match:
      alertname: 'LLMAPIFailureRateHigh'
    target_match_re:
      alertname: '.*Latency.*'
    equal: ['component']

  # Critical severity inhibits warnings for same alert
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'component']

# ===================================================================
# RECEIVERS CONFIGURATION
# ===================================================================
receivers:
  # ===== DEFAULT RECEIVER =====
  - name: 'default-email'
    email_configs:
      - to: '${ALERTMANAGER_BACKEND_TEAM_EMAIL}'
        headers:
          Subject: '[LIA {{ .Status | toUpper }}] {{ .GroupLabels.alertname }}'
        html: '{{ template "email.default.html" . }}'
        send_resolved: true

  # ===== CRITICAL MULTI-CHANNEL =====
  # Email + Slack + PagerDuty for critical alerts
  - name: 'critical-multi-channel'
    # Email notification
    email_configs:
      - to: '${ALERTMANAGER_BACKEND_TEAM_EMAIL}'
        headers:
          Subject: '[CRITICAL] LIA: {{ .GroupLabels.alertname }}'
        html: '{{ template "email.critical.html" . }}'
        send_resolved: true

    # Slack notification (if webhook configured)
    slack_configs:
      - api_url: '${ALERTMANAGER_SLACK_WEBHOOK_CRITICAL}'
        channel: '#alerts-critical'
        title: ':fire: CRITICAL: {{ .GroupLabels.alertname }}'
        text: |-
          {{ range .Alerts }}
          *Alert:* {{ .Labels.alertname }}
          *Severity:* {{ .Labels.severity }}
          *Component:* {{ .Labels.component }}
          *Summary:* {{ .Annotations.summary }}
          *Description:* {{ .Annotations.description }}
          {{ if .Annotations.runbook_url }}*Runbook:* {{ .Annotations.runbook_url }}{{ end }}
          {{ end }}
        send_resolved: true
        color: '{{ if eq .Status "firing" }}danger{{ else }}good{{ end }}'

    # PagerDuty notification (if routing key configured)
    pagerduty_configs:
      - routing_key: '${ALERTMANAGER_PAGERDUTY_ROUTING_KEY}'
        description: '[{{ .GroupLabels.severity }}] {{ .GroupLabels.alertname }} - {{ .GroupLabels.component }}'
        details:
          firing: '{{ .Alerts.Firing | len }}'
          resolved: '{{ .Alerts.Resolved | len }}'
          summary: '{{ range .Alerts }}{{ .Annotations.summary }}{{ end }}'
        severity: 'critical'
        send_resolved: true

  # ===== WARNING EMAIL + SLACK =====
  - name: 'warning-email-slack'
    email_configs:
      - to: '${ALERTMANAGER_BACKEND_TEAM_EMAIL}'
        headers:
          Subject: '[WARNING] LIA: {{ .GroupLabels.alertname }}'
        html: '{{ template "email.warning.html" . }}'
        send_resolved: true

    slack_configs:
      - api_url: '${ALERTMANAGER_SLACK_WEBHOOK_WARNING}'
        channel: '#alerts-warning'
        title: ':warning: Warning: {{ .GroupLabels.alertname }}'
        text: |-
          {{ range .Alerts }}
          *Alert:* {{ .Labels.alertname }}
          *Component:* {{ .Labels.component }}
          *Summary:* {{ .Annotations.summary }}
          {{ end }}
        send_resolved: true
        color: 'warning'

  # ===== LLM BUDGET → FINANCE TEAM =====
  - name: 'llm-budget-finance'
    email_configs:
      - to: '${ALERTMANAGER_FINANCE_TEAM_EMAIL},${ALERTMANAGER_BACKEND_TEAM_EMAIL}'
        headers:
          Subject: '[BUDGET ALERT] LLM Cost: {{ .GroupLabels.alertname }}'
        html: '{{ template "email.budget.html" . }}'
        send_resolved: true

    slack_configs:
      - api_url: '${ALERTMANAGER_SLACK_WEBHOOK_WARNING}'
        channel: '#alerts-llm-budget'
        title: ':money_with_wings: LLM Budget Alert: {{ .GroupLabels.alertname }}'
        text: |-
          {{ range .Alerts }}
          *Budget Alert:* {{ .Labels.alertname }}
          *Severity:* {{ .Labels.severity }}
          {{ if .Annotations.current_cost }}*Current Cost:* {{ .Annotations.current_cost }}{{ end }}
          {{ if .Annotations.budget_limit }}*Budget Limit:* {{ .Annotations.budget_limit }}{{ end }}
          *Summary:* {{ .Annotations.summary }}
          {{ end }}
        send_resolved: true
        color: 'danger'

  # ===== AGENTS → ML TEAM =====
  - name: 'agents-ml-team'
    email_configs:
      - to: '${ALERTMANAGER_ML_TEAM_EMAIL}'
        headers:
          Subject: '[AGENTS SLA] {{ .GroupLabels.alertname }}'
        html: '{{ template "email.agents.html" . }}'
        send_resolved: true

    slack_configs:
      - api_url: '${ALERTMANAGER_SLACK_WEBHOOK_WARNING}'
        channel: '#alerts-agents'
        title: ':robot_face: Agent Alert: {{ .GroupLabels.alertname }}'
        text: |-
          {{ range .Alerts }}
          *Agent:* {{ .Labels.alertname }}
          *Component:* {{ .Labels.component }}
          *Summary:* {{ .Annotations.summary }}
          {{ if .Annotations.runbook }}*Runbook:* {{ .Annotations.runbook }}{{ end }}
          {{ end }}
        send_resolved: true

  # ===== HITL → ML TEAM =====
  - name: 'hitl-ml-team'
    email_configs:
      - to: '${ALERTMANAGER_ML_TEAM_EMAIL}'
        headers:
          Subject: '[HITL] {{ .GroupLabels.alertname }}'
        html: '{{ template "email.agents.html" . }}'
        send_resolved: true

  # ===== DATABASE → BACKEND TEAM =====
  - name: 'database-backend-team'
    email_configs:
      - to: '${ALERTMANAGER_BACKEND_TEAM_EMAIL}'
        headers:
          Subject: '[DATABASE] {{ .GroupLabels.alertname }}'
        html: '{{ template "email.database.html" . }}'
        send_resolved: true

  # ===== REDIS → BACKEND TEAM =====
  - name: 'redis-backend-team'
    email_configs:
      - to: '${ALERTMANAGER_BACKEND_TEAM_EMAIL}'
        headers:
          Subject: '[REDIS] {{ .GroupLabels.alertname }}'
        html: '{{ template "email.redis.html" . }}'
        send_resolved: true

  # ===== SECURITY → SECURITY TEAM =====
  - name: 'security-team-critical'
    email_configs:
      - to: '${ALERTMANAGER_SECURITY_TEAM_EMAIL},${ALERTMANAGER_BACKEND_TEAM_EMAIL}'
        headers:
          Subject: '[SECURITY CRITICAL] OAuth Alert: {{ .GroupLabels.alertname }}'
        html: '{{ template "email.security.html" . }}'
        send_resolved: true

    slack_configs:
      - api_url: '${ALERTMANAGER_SLACK_WEBHOOK_SECURITY}'
        channel: '#alerts-security'
        title: ':rotating_light: SECURITY: {{ .GroupLabels.alertname }}'
        text: |-
          {{ range .Alerts }}
          *Security Alert:* {{ .Labels.alertname }}
          *Severity:* CRITICAL
          *Component:* {{ .Labels.component }}
          *Summary:* {{ .Annotations.summary }}
          *Description:* {{ .Annotations.description }}
          {{ end }}
        send_resolved: true
        color: 'danger'

    pagerduty_configs:
      - routing_key: '${ALERTMANAGER_PAGERDUTY_ROUTING_KEY}'
        description: 'Security Alert: {{ .GroupLabels.alertname }}'
        severity: 'critical'
        send_resolved: true
