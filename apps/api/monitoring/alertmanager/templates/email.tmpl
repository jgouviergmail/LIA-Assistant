{{ define "email.default.html" }}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #f4f4f4; padding: 15px; border-radius: 5px; margin-bottom: 20px; }
        .alert { border-left: 4px solid #ffa500; padding: 15px; margin-bottom: 15px; background-color: #fff8e1; }
        .alert.critical { border-left-color: #d32f2f; background-color: #ffebee; }
        .alert.warning { border-left-color: #ffa500; background-color: #fff8e1; }
        .label { display: inline-block; padding: 3px 8px; border-radius: 3px; font-size: 12px; margin-right: 5px; }
        .label.severity { background-color: #ff9800; color: white; }
        .label.component { background-color: #2196f3; color: white; }
        .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #ddd; font-size: 12px; color: #666; }
        .runbook { background-color: #f5f5f5; padding: 10px; border-radius: 3px; margin-top: 10px; white-space: pre-wrap; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>🔔 LIA Alert Notification</h2>
            <p><strong>Status:</strong> {{ .Status }}</p>
            <p><strong>Time:</strong> {{ .Alerts.Firing | len }} firing, {{ .Alerts.Resolved | len }} resolved</p>
        </div>

        {{ range .Alerts }}
        <div class="alert {{ .Labels.severity }}">
            <h3>{{ .Labels.alertname }}</h3>
            <p><strong>Summary:</strong> {{ .Annotations.summary }}</p>
            <p><strong>Description:</strong> {{ .Annotations.description }}</p>

            <div>
                <span class="label severity">{{ .Labels.severity }}</span>
                <span class="label component">{{ .Labels.component }}</span>
            </div>

            {{ if .Annotations.runbook }}
            <div class="runbook">
                <strong>📖 Runbook:</strong><br>
                {{ .Annotations.runbook }}
            </div>
            {{ end }}

            <p><strong>Starts at:</strong> {{ .StartsAt }}</p>
            {{ if .EndsAt }}
            <p><strong>Ends at:</strong> {{ .EndsAt }}</p>
            {{ end }}
        </div>
        {{ end }}

        <div class="footer">
            <p>This alert was generated by Prometheus AlertManager for LIA.</p>
            <p>View dashboards: <a href="http://localhost:3000">Grafana</a></p>
        </div>
    </div>
</body>
</html>
{{ end }}

{{ define "email.critical.html" }}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #d32f2f 0%, #f44336 100%); color: white; padding: 20px; border-radius: 5px; margin-bottom: 20px; }
        .alert { border: 2px solid #d32f2f; padding: 20px; margin-bottom: 15px; background-color: #ffebee; border-radius: 5px; }
        .priority { font-size: 24px; font-weight: bold; color: #d32f2f; margin-bottom: 10px; }
        .label { display: inline-block; padding: 4px 10px; border-radius: 3px; font-size: 12px; margin-right: 5px; }
        .label.severity { background-color: #d32f2f; color: white; font-weight: bold; }
        .label.component { background-color: #2196f3; color: white; }
        .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #ddd; font-size: 12px; color: #666; }
        .runbook { background-color: #fff; padding: 15px; border-radius: 3px; margin-top: 15px; border-left: 4px solid #d32f2f; white-space: pre-wrap; }
        .action-required { background-color: #fff3cd; border: 1px solid #ffc107; padding: 10px; border-radius: 3px; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🚨 CRITICAL ALERT</h1>
            <p style="font-size: 18px;">Immediate action required for LIA</p>
            <p><strong>Status:</strong> {{ .Status | toUpper }}</p>
        </div>

        <div class="priority">⚠️ PRIORITY: CRITICAL</div>

        {{ range .Alerts }}
        <div class="alert">
            <h2>{{ .Labels.alertname }}</h2>
            <p style="font-size: 16px;"><strong>{{ .Annotations.summary }}</strong></p>
            <p>{{ .Annotations.description }}</p>

            <div style="margin: 15px 0;">
                <span class="label severity">CRITICAL</span>
                <span class="label component">{{ .Labels.component }}</span>
            </div>

            {{ if .Annotations.runbook }}
            <div class="runbook">
                <strong>📖 RUNBOOK - Follow these steps:</strong><br>
                {{ .Annotations.runbook }}
            </div>
            {{ end }}

            <div class="action-required">
                <strong>⚡ Action Required:</strong><br>
                1. Acknowledge this alert immediately<br>
                2. Follow the runbook steps above<br>
                3. Escalate if not resolved within 30 minutes
            </div>

            <p style="margin-top: 15px;"><strong>Alert started:</strong> {{ .StartsAt }}</p>
            {{ if .EndsAt }}
            <p><strong>Alert ended:</strong> {{ .EndsAt }}</p>
            {{ end }}
        </div>
        {{ end }}

        <div class="footer">
            <p><strong>On-call engineer:</strong> Please respond to this alert within 15 minutes.</p>
            <p>View live metrics: <a href="http://localhost:3000">Grafana Dashboard</a></p>
            <p>Prometheus: <a href="http://localhost:9090">Prometheus UI</a></p>
        </div>
    </div>
</body>
</html>
{{ end }}

