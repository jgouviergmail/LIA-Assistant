{{ define "email.budget.html" }}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #d32f2f 0%, #c62828 100%); color: white; padding: 20px; border-radius: 5px; margin-bottom: 20px; }
        .alert { border: 2px solid #d32f2f; padding: 20px; margin-bottom: 15px; background-color: #ffebee; border-radius: 5px; }
        .budget-chart { background-color: #fff; padding: 15px; border-radius: 3px; margin: 15px 0; }
        .cost-detail { display: flex; justify-content: space-between; padding: 8px; border-bottom: 1px solid #ddd; }
        .cost-detail:last-child { border-bottom: none; }
        .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #ddd; font-size: 12px; color: #666; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>💰 LLM Budget Alert</h1>
            <p style="font-size: 18px;">Cost threshold exceeded for LIA</p>
        </div>

        {{ range .Alerts }}
        <div class="alert">
            <h2>{{ .Labels.alertname }}</h2>
            <p style="font-size: 16px;"><strong>{{ .Annotations.summary }}</strong></p>
            <p>{{ .Annotations.description }}</p>

            <div class="budget-chart">
                <div class="cost-detail">
                    <span><strong>Current Cost:</strong></span>
                    <span style="color: #d32f2f; font-weight: bold;">{{ .Annotations.current_cost }}</span>
                </div>
                <div class="cost-detail">
                    <span><strong>Budget Limit:</strong></span>
                    <span>{{ .Annotations.budget_limit }}</span>
                </div>
                <div class="cost-detail">
                    <span><strong>Exceeded By:</strong></span>
                    <span style="color: #d32f2f; font-weight: bold;">{{ .Annotations.exceeded_by }}</span>
                </div>
            </div>

            {{ if .Annotations.runbook }}
            <div style="background-color: #fff; padding: 15px; border-radius: 3px; margin-top: 15px; border-left: 4px solid #d32f2f;">
                <strong>📖 Recommended Actions:</strong><br>
                <pre style="white-space: pre-wrap; margin: 0;">{{ .Annotations.runbook }}</pre>
            </div>
            {{ end }}

            <p style="margin-top: 15px;"><strong>Alert started:</strong> {{ .StartsAt }}</p>
        </div>
        {{ end }}

        <div class="footer">
            <p><strong>Cost Control:</strong> Please review LLM usage and consider implementing cost reduction measures.</p>
            <p>View cost dashboard: <a href="http://localhost:3000/d/llm-tokens-cost">LLM Tokens & Cost Dashboard</a></p>
        </div>
    </div>
</body>
</html>
{{ end }}

{{ define "email.agents.html" }}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #673ab7 0%, #7e57c2 100%); color: white; padding: 15px; border-radius: 5px; margin-bottom: 20px; }
        .alert { border-left: 4px solid #673ab7; padding: 15px; margin-bottom: 15px; background-color: #f3e5f5; }
        .sla-violation { background-color: #ffcdd2; padding: 10px; border-radius: 3px; margin: 10px 0; }
        .runbook { background-color: #fff; padding: 15px; border-radius: 3px; margin-top: 15px; border-left: 4px solid #673ab7; white-space: pre-wrap; font-family: monospace; font-size: 12px; }
        .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #ddd; font-size: 12px; color: #666; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>🤖 Agent Performance Alert</h2>
            <p>SLA violation detected for LIA agents</p>
        </div>

        {{ range .Alerts }}
        <div class="alert">
            <h3>{{ .Labels.alertname }}</h3>
            <p><strong>{{ .Annotations.summary }}</strong></p>
            <p>{{ .Annotations.description }}</p>

            {{ if .Labels.intention }}
            <p><strong>Intention:</strong> {{ .Labels.intention }}</p>
            {{ end }}

            {{ if .Labels.sla }}
            <div class="sla-violation">
                <strong>⚠️ SLA Violated:</strong> {{ .Labels.sla | toUpper }}
            </div>
            {{ end }}

            {{ if .Annotations.runbook }}
            <div class="runbook">
                <strong>📖 Troubleshooting Steps:</strong><br>
{{ .Annotations.runbook }}
            </div>
            {{ end }}

            <p><strong>Started:</strong> {{ .StartsAt }}</p>
        </div>
        {{ end }}

        <div class="footer">
            <p>Review agent performance: <a href="http://localhost:3000/d/agents-langgraph">LangGraph Agents Dashboard</a></p>
        </div>
    </div>
</body>
</html>
{{ end }}

