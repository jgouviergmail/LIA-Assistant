msgstr "Konnektor bereits aktiviert"

msgid "Connector disabled"
msgstr "Konnektor deaktiviert"

msgid "OAuth flow failed"
msgstr "OAuth-Authentifizierung fehlgeschlagen"

msgid "Please enable Google Contacts connector first"
msgstr "Bitte aktivieren Sie zuerst den Google Kontakte-Konnektor"

