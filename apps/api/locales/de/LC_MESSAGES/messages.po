# Authentication errors
msgid "Invalid credentials"
msgstr "Ungültige Anmeldedaten"

msgid "Account inactive"
msgstr "Konto inaktiv"

msgid "Email already registered"
msgstr "E-Mail bereits registriert"

msgid "Invalid token"
msgstr "Ungültiges Token"

msgid "Token expired"
msgstr "Token abgelaufen"

msgid "Unauthorized"
msgstr "Nicht autorisiert"

msgid "Access denied"
msgstr "Zugriff verweigert"

# Validation errors
msgid "Invalid email format"
msgstr "Ungültiges E-Mail-Format"

msgid "Password too short"
msgstr "Passwort zu kurz"

msgid "Password must contain at least 8 characters"
msgstr "Das Passwort muss mindestens 8 Zeichen enthalten"

msgid "Passwords do not match"
msgstr "Passwörter stimmen nicht überein"

msgid "Email is required"
msgstr "E-Mail ist erforderlich"

msgid "Password is required"
msgstr "Passwort ist erforderlich"

msgid "Full name is required"
msgstr "Vollständiger Name ist erforderlich"

