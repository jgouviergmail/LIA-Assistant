# User activation/deactivation emails
msgid "Failed to send deactivation email notification"
msgstr "Échec de l'envoi de la notification par email de désactivation"

msgid "Failed to send activation email notification"
msgstr "Échec de l'envoi de la notification par email d'activation"

msgid "Your LIA account has been deactivated"
msgstr "Votre compte LIA a été désactivé"

msgid "Account deactivated"
msgstr "Compte désactivé"

msgid "We inform you that your LIA account has been deactivated by an administrator."
msgstr "Nous vous informons que votre compte LIA a été désactivé par un administrateur."

msgid "You can no longer access the application."
msgstr "Vous ne pouvez plus accéder à l'application."

msgid "If you think this is an error, please contact the administrator."
msgstr "Si vous pensez qu'il s'agit d'une erreur, veuillez contacter l'administrateur."

msgid "Your LIA account has been reactivated"
msgstr "Votre compte LIA a été réactivé"

msgid "Account reactivated"
msgstr "Compte réactivé"

msgid "We inform you that your LIA account has been reactivated."
msgstr "Nous vous informons que votre compte LIA a été réactivé."

msgid "You can now access the application again."
msgstr "Vous pouvez à nouveau accéder à l'application."

msgid "Log in"
msgstr "Se connecter"

msgid "Login link"
msgstr "Lien de connexion"

msgid "Hello"
msgstr "Bonjour"

msgid "Reason"
msgstr "Raison"

msgid "This is an automated email, please do not reply."
msgstr "Ceci est un email automatique, merci de ne pas y répondre."

# User pending activation email
msgid "Your LIA account is pending activation"
msgstr "Votre compte LIA est en attente d'activation"

msgid "Account pending activation"
msgstr "Compte en attente d'activation"

msgid "Welcome to LIA! Your account has been created successfully."
msgstr "Bienvenue sur LIA ! Votre compte a été créé avec succès."

msgid "Your account is currently pending activation by an administrator."
msgstr "Votre compte est actuellement en attente d'activation par un administrateur."

msgid "You will receive an email once your account has been activated."
msgstr "Vous recevrez un email dès que votre compte aura été activé."

msgid "Thank you for your patience."
msgstr "Merci de votre patience."

# Semantic Architecture - Context Loader
msgid "No previous conversation."
msgstr "Aucune conversation précédente."

msgid "No relevant memories."
msgstr "Aucune mémoire pertinente."

msgid "Error retrieving memories."
msgstr "Erreur lors de la récupération des mémoires."

# Semantic Architecture - Semantic Agent
msgid "No memories available."
msgstr "Aucune mémoire disponible."

msgid "No tools available."
msgstr "Aucun outil disponible."

msgid "Parameters:"
msgstr "Paramètres:"

msgid "(required)"
msgstr "(requis)"

msgid "(optional)"
msgstr "(optionnel)"

msgid "Internal error: registry not available."
msgstr "Erreur interne: registre non disponible."

msgid "I've reached the action limit. Here's what I was able to accomplish."
msgstr "J'ai atteint la limite d'actions. Voici ce que j'ai pu accomplir."

msgid "I'm sorry, an error occurred. Please try again."
msgstr "Je suis désolé, une erreur s'est produite. Veuillez réessayer."

# Semantic Architecture - HITL Tool Gate
msgid "The action '{tool_name}' requires your approval. Do you want to continue?"
msgstr "L'action '{tool_name}' nécessite votre approbation. Voulez-vous continuer?"

msgid "The following actions require your approval: {tool_names}. Do you want to continue?"
msgstr "Les actions suivantes nécessitent votre approbation: {tool_names}. Voulez-vous continuer?"

msgid "Action cancelled: {reason}"
msgstr "Action annulée: {reason}"

msgid "Action cancelled by user."
msgstr "Action annulée par l'utilisateur."

# ============================================================================
# Context Tools (Phase 5 i18n - 2025-12-22)
# ============================================================================

msgid "No active domain. Please perform a search first."
msgstr "Aucun domaine actif. Effectue d'abord une recherche."

msgid "Domain '{domain}' not registered. Available domains: {available}"
msgstr "Domaine '{domain}' non enregistré. Domaines disponibles: {available}"

msgid "none"
msgstr "aucun"

msgid "No active '{domain}' list in memory. Please perform a search first to create a context."
msgstr "Aucune liste '{domain}' active en mémoire. Effectue d'abord une recherche pour créer un contexte."

msgid "Error retrieving domains: {error}"
msgstr "Erreur lors de la récupération des domaines: {error}"

msgid "Item {index} marked as current in {domain}."
msgstr "Item {index} marqué comme courant dans {domain}."

msgid "No active context for domain '{domain}'."
msgstr "Aucun contexte actif pour le domaine '{domain}'."

msgid "List truncated to {limit} items ({available} available)"
msgstr "Liste tronquée à {limit} items ({available} disponibles)"

msgid "Error retrieving list: {error}"
msgstr "Erreur lors de la récupération de la liste: {error}"

# ============================================================================
# Wikipedia Tools (Phase 5 i18n - 2025-12-22)
# ============================================================================

msgid "No article found for '{query}' on Wikipedia ({language})"
msgstr "Aucun article trouvé pour '{query}' sur Wikipedia ({language})"

msgid "Wikipedia search for '{query}' ({language}): {count} results"
msgstr "Recherche Wikipedia pour '{query}' ({language}): {count} résultats"

msgid "Error during Wikipedia search: {error}"
msgstr "Erreur lors de la recherche Wikipedia: {error}"

msgid "Article '{title}' not found on Wikipedia ({language})"
msgstr "Article '{title}' non trouvé sur Wikipedia ({language})"

msgid "Wikipedia summary: {title}"
msgstr "Résumé Wikipedia: {title}"

msgid "Error retrieving summary: {error}"
msgstr "Erreur lors de la récupération du résumé: {error}"

msgid "content truncated"
msgstr "contenu tronqué"

msgid "Wikipedia article: {title}"
msgstr "Article Wikipedia: {title}"

msgid "Sections"
msgstr "Sections"

msgid "and {count} more sections"
msgstr "et {count} autres sections"

msgid "Content"
msgstr "Contenu"

msgid "{count} additional characters in registry"
msgstr "{count} caractères supplémentaires dans le registre"

msgid "Error retrieving article: {error}"
msgstr "Erreur lors de la récupération de l'article: {error}"

msgid "No related article found for '{title}'"
msgstr "Aucun article lié trouvé pour '{title}'"

msgid "Articles related to '{title}' ({language}): {count} results"
msgstr "Articles liés à '{title}' ({language}): {count} résultats"

msgid "Error retrieving related articles: {error}"
msgstr "Erreur lors de la récupération des articles liés: {error}"

# ============================================================================
# Weather Tools (Phase 5 i18n - 2025-12-22)
# ============================================================================

msgid "Current location"
msgstr "Position actuelle"

msgid "Please specify a city or enable geolocation."
msgstr "Précise une ville ou active la géolocalisation."

msgid "Unable to find location: {location}"
msgstr "Impossible de trouver la localisation: {location}"

# ============================================================================
# Adaptive Replanner (Phase 5 i18n - 2025-12-22)
# ============================================================================

msgid "I couldn't find any results matching your request. Could you clarify or rephrase?"
msgstr "Je n'ai pas trouvé de résultats correspondant à ta demande. Peux-tu préciser ou reformuler ?"

msgid "Sorry, some operations failed after multiple attempts: {operations}"
msgstr "Désolé, certaines opérations ont échoué après plusieurs tentatives: {operations}"

msgid "The required data could not be found. Could you clarify your request?"
msgstr "Les données nécessaires n'ont pas pu être trouvées. Peux-tu préciser ta demande ?"

msgid "A dependency error occurred between steps."
msgstr "Une erreur de dépendance entre les étapes s'est produite."

msgid "The operation is taking too long. Try a more specific request."
msgstr "L'opération prend trop de temps. Essaye une demande plus spécifique."

msgid "Unable to execute this request after multiple attempts. Errors: {errors}"
msgstr "Impossible d'exécuter cette demande après plusieurs tentatives. Erreurs: {errors}"

msgid "Unable to execute this request after multiple attempts."
msgstr "Impossible d'exécuter cette demande après plusieurs tentatives."

