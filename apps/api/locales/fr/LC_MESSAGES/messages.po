msgstr "Jeton invalide"

msgid "Token expired"
msgstr "Jeton expiré"

msgid "Unauthorized"
msgstr "Non autorisé"

msgid "Access denied"
msgstr "Accès refusé"

# Validation errors
msgid "Invalid email format"
msgstr "Format d'email invalide"

msgid "Password too short"
msgstr "Mot de passe trop court"

msgid "Password must contain at least 8 characters"
msgstr "Le mot de passe doit contenir au moins 8 caractères"

msgid "Passwords do not match"
msgstr "Les mots de passe ne correspondent pas"

msgid "Email is required"
msgstr "L'email est requis"

msgid "Password is required"
msgstr "Le mot de passe est requis"

msgid "Full name is required"
msgstr "Le nom complet est requis"

