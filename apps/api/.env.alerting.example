# ===================================================================
# AlertManager Configuration
# ===================================================================
# Copy this file to .env.alerting and configure for your environment
# This file contains environment variables for AlertManager notification channels

# ===== SMTP EMAIL CONFIGURATION (REQUIRED) =====

# SMTP server configuration (GMX in this example)
ALERTMANAGER_SMTP_SMARTHOST=smtp_smarthost
# SMTP from address (monitoring alerts sender)
ALERTMANAGER_SMTP_FROM=your-email
# SMTP authentication
ALERTMANAGER_SMTP_AUTH_USERNAME=your-email
ALERTMANAGER_SMTP_AUTH_PASSWORD=your-smtp-password

# ===== EMAIL RECIPIENTS (REQUIRED) =====

# Backend team email (receives all technical alerts by default)
ALERTMANAGER_BACKEND_TEAM_EMAIL=your-email

# Finance team email (receives LLM budget/cost alerts)
# If not set, defaults to ALERTMANAGER_BACKEND_TEAM_EMAIL
ALERTMANAGER_FINANCE_TEAM_EMAIL=your-email

# Security team email (receives OAuth/security alerts)
# If not set, defaults to ALERTMANAGER_BACKEND_TEAM_EMAIL
ALERTMANAGER_SECURITY_TEAM_EMAIL=your-email

# ML team email (receives agent/HITL performance alerts)
# If not set, defaults to ALERTMANAGER_BACKEND_TEAM_EMAIL
ALERTMANAGER_ML_TEAM_EMAIL=your-email

# ===== SLACK CONFIGURATION (OPTIONAL) =====

# Slack webhook URLs for different alert severities
# Get these from: https://api.slack.com/messaging/webhooks
# Leave empty or comment out to disable Slack notifications

# Critical alerts webhook (fires for severity=critical)
# ALERTMANAGER_SLACK_WEBHOOK_CRITICAL=https://hooks.slack.com/services/YOUR/CRITICAL/WEBHOOK

# Warning alerts webhook (fires for severity=warning)
# ALERTMANAGER_SLACK_WEBHOOK_WARNING=https://hooks.slack.com/services/YOUR/WARNING/WEBHOOK

# Security alerts webhook (fires for OAuth/security issues)
# ALERTMANAGER_SLACK_WEBHOOK_SECURITY=https://hooks.slack.com/services/YOUR/SECURITY/WEBHOOK

# ===== PAGERDUTY CONFIGURATION (OPTIONAL) =====

# PagerDuty routing key for critical alerts (24/7 on-call)
# Get this from: PagerDuty Service > Integrations > Events API v2
# Leave empty or comment out to disable PagerDuty notifications
# ALERTMANAGER_PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key

# ===================================================================
# Alert Thresholds Configuration
# ===================================================================
# These thresholds are used in alerts.yml.template via Jinja2 templating
# 39 thresholds total (as of 2025-11-22)

# ===== APPLICATION (API) THRESHOLDS (4) =====

# Error rate threshold (percentage) - HighErrorRate alert
ALERT_API_ERROR_RATE_CRITICAL_PERCENT=5

# Latency P95 threshold (seconds) - HighLatencyP95 alert
ALERT_API_LATENCY_P95_WARNING_SECONDS=1

# Latency P99 threshold (seconds) - CriticalLatencyP99 alert
ALERT_API_LATENCY_P99_CRITICAL_SECONDS=2

# Request rate threshold (requests per second) - HighRequestQueueing alert
ALERT_API_REQUEST_RATE_RPS=1000

# ===== DATABASE (PostgreSQL) THRESHOLDS (3) =====

# Connection pool warning threshold (percentage) - HighDatabaseConnections alert
ALERT_DB_CONNECTIONS_WARNING_PERCENT=80

# Connection pool critical threshold (percentage) - CriticalDatabaseConnections alert
ALERT_DB_CONNECTIONS_CRITICAL_PERCENT=90

# Slow queries threshold (tuples per second) - SlowQueries alert
ALERT_DB_SLOW_QUERIES_TUPLES_PER_SEC=100000

# ===== INFRASTRUCTURE THRESHOLDS (5) =====

# Disk usage warning threshold (percentage) - DiskSpaceHigh alert
ALERT_DISK_USAGE_WARNING_PERCENT=85

# Disk usage critical threshold (percentage) - DiskSpaceCritical alert
ALERT_DISK_USAGE_CRITICAL_PERCENT=95

# CPU usage warning threshold (percentage) - HighCPUUsage alert
ALERT_CPU_USAGE_WARNING_PERCENT=80

# Memory usage warning threshold (percentage) - HighMemoryUsage alert
ALERT_MEMORY_USAGE_WARNING_PERCENT=85

# Container down timeout (seconds) - ContainerDown alert
ALERT_CONTAINER_DOWN_SECONDS=60

# Container restart rate threshold (restarts per second) - ContainerRestartingFrequently alert
ALERT_CONTAINER_RESTART_RATE=0.1

# ===== REDIS THRESHOLDS (2) =====

# Redis memory usage warning threshold (percentage) - RedisMemoryHigh alert
ALERT_REDIS_MEMORY_WARNING_PERCENT=80

# Redis connections warning threshold (count) - RedisConnectionsHigh alert
ALERT_REDIS_CONNECTIONS_WARNING=100

# ===== AGENTS (LangGraph) THRESHOLDS (5) =====

# Time to First Token P95 threshold (milliseconds) - AgentsTTFTViolation alert
ALERT_AGENTS_TTFT_P95_MS=1000

# Minimum tokens per second threshold - AgentsTokensPerSecondLow alert
ALERT_AGENTS_TOKENS_PER_SECOND_MIN=20

# Router latency P95 threshold (milliseconds) - AgentsRouterLatencyHigh alert
ALERT_AGENTS_ROUTER_LATENCY_P95_MS=500

# Streaming error rate threshold (percentage) - AgentsStreamingErrorRateHigh alert
ALERT_AGENTS_STREAMING_ERROR_RATE_PERCENT=5

# Router low confidence rate threshold (percentage) - AgentsRouterLowConfidenceHigh alert
ALERT_AGENTS_ROUTER_LOW_CONFIDENCE_PERCENT=10

# ===== CONVERSATIONS THRESHOLDS (5) =====

# Checkpoint save P99 critical threshold (seconds) - CheckpointSaveSlowCritical alert
ALERT_CHECKPOINT_SAVE_P99_CRITICAL_SECONDS=2.0

# Checkpoint save P99 warning threshold (seconds) - CheckpointSaveSlowWarning alert
ALERT_CHECKPOINT_SAVE_P99_WARNING_SECONDS=1.0

# Conversation reset rate threshold (resets per second) - HighConversationResetRate alert
ALERT_CONVERSATION_RESET_RATE=0.5

# Checkpoint size P95 threshold (bytes) - CheckpointSizeGrowing alert
ALERT_CHECKPOINT_SIZE_P95_BYTES=50000

# Minimum active users before alerting on creation stall - ConversationCreationStalled alert
ALERT_CONVERSATION_CREATION_MIN_USERS=10

# ===== LLM & COST THRESHOLDS (6) =====

# LLM API failure rate threshold (5% as 0.05) - LLMAPIFailureRateHigh alert
ALERT_LLM_API_FAILURE_RATE_PERCENT=0.05

# LLM API success rate threshold (95% as 0.95) - LLMAPISuccessRateLow alert
ALERT_LLM_API_SUCCESS_RATE_PERCENT=0.95

# LLM daily budget threshold (EUR) - DailyCostBudgetExceeded alert
ALERT_LLM_DAILY_BUDGET_EUR=100

# LLM hourly budget threshold (EUR) - HourlyCostTrendingHigh alert
ALERT_LLM_HOURLY_BUDGET_EUR=5

# LLM API latency P99 threshold (seconds) - LLMAPILatencyHigh alert
ALERT_LLM_API_LATENCY_P99_SECONDS=10

# LLM model-specific daily budget threshold (EUR) - ModelCostBudgetExceeded alert
ALERT_LLM_MODEL_DAILY_BUDGET_EUR=50

# ===== TOKENS THRESHOLDS (2) =====

# LLM token consumption rate threshold (tokens per second) - HighTokenConsumptionRate alert
ALERT_LLM_TOKEN_CONSUMPTION_RATE=1000

# LLM output/input token ratio threshold - HighOutputTokenRatio alert
ALERT_LLM_OUTPUT_INPUT_TOKEN_RATIO=5

# ===== OAUTH SECURITY THRESHOLDS (6) =====

# OAuth failure rate threshold (percentage) - HighOAuthFailureRate alert
ALERT_OAUTH_FAILURE_RATE_PERCENT=10

# OAuth PKCE validation failure rate threshold (failures per second) - PKCEValidationFailures alert
ALERT_OAUTH_PKCE_FAILURE_RATE=0.1

# OAuth state token validation failure rate threshold (failures per second) - StateTokenValidationFailures alert
ALERT_OAUTH_STATE_FAILURE_RATE=0.1

# OAuth callback latency P95 threshold (seconds) - SlowOAuthCallback alert
ALERT_OAUTH_CALLBACK_LATENCY_P95_SECONDS=5

# OAuth provider error rate threshold (errors per second) - OAuthProviderErrors alert
ALERT_OAUTH_PROVIDER_ERROR_RATE=0.5

# OAuth callback spike detection threshold (callbacks per second) - OAuthCallbackSpike alert
ALERT_OAUTH_CALLBACK_SPIKE_RATE=10

# ===================================================================
# Environment-Specific Notes
# ===================================================================
#
# PRODUCTION:
#   - Use strict thresholds (lower values = earlier alerts)
#   - Enable all notification channels (email + Slack + PagerDuty)
#   - Short repeat intervals for critical alerts (30min)
#
# STAGING:
#   - Use relaxed thresholds (higher values = fewer alerts)
#   - Enable email + Slack only (no PagerDuty)
#   - Longer repeat intervals (2h)
#
# DEVELOPMENT:
#   - Use very relaxed thresholds or disable alerts
#   - Email only to dev team
#   - Long repeat intervals (12h) or disable entirely
#
# ===================================================================
