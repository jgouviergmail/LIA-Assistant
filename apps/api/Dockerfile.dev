# syntax=docker/dockerfile:1.4

# =============================================================================
# Model download stage - Downloads Sherpa-onnx Whisper Small INT8 STT model
# =============================================================================
FROM python:3.12-slim-bookworm AS model-downloader

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /models/whisper-small

# Download Whisper Small INT8 model files (~375MB total)
# Multi-language: 99+ languages including French
# Source: HuggingFace csukuangfj/sherpa-onnx-whisper-small
ARG HF_BASE_URL=https://huggingface.co/csukuangfj/sherpa-onnx-whisper-small/resolve/main

RUN curl -L -o encoder.onnx "${HF_BASE_URL}/small-encoder.int8.onnx" && \
    curl -L -o decoder.onnx "${HF_BASE_URL}/small-decoder.int8.onnx" && \
    curl -L -o tokens.txt "${HF_BASE_URL}/small-tokens.txt"

# =============================================================================
# GeoIP database download stage - DB-IP Lite City (free, CC-BY-4.0)
# =============================================================================
FROM python:3.12-slim-bookworm AS geoip-downloader

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /data/geoip

# DB-IP Lite City database — free, no account needed, updated monthly
ARG DBIP_DATE=2026-03
RUN curl -L -o dbip-city-lite.mmdb.gz \
        "https://download.db-ip.com/free/dbip-city-lite-${DBIP_DATE}.mmdb.gz" && \
    gunzip dbip-city-lite.mmdb.gz

# =============================================================================
# Development stage
# =============================================================================
FROM python:3.12-slim-bookworm

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    HF_HOME=/app/.cache/huggingface

# Create app directory
WORKDIR /app

# Install system dependencies + uv (ultra-fast pip replacement)
RUN apt-get update && apt-get install -y \
    gcc \
    postgresql-client \
    curl \
    git \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && pip install uv

# Copy requirements
COPY requirements.txt requirements-dev.txt ./

# Install Python dependencies with uv (10-100x faster than pip)
# No cache mount = Docker layer cache works = instant rebuild if requirements unchanged
RUN uv pip install --system -r requirements.txt -r requirements-dev.txt

# Copy STT model from model-downloader stage
COPY --from=model-downloader /models/whisper-small /models/whisper-small

# Copy GeoIP database from geoip-downloader stage
COPY --from=geoip-downloader /data/geoip /data/geoip

# Copy entrypoint script first
COPY docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh

# Install Playwright Chromium browser (F7 — Browser Control)
# playwright install downloads the browser binary + system deps
RUN playwright install --with-deps chromium

# Copy application code
COPY . .

# Expose ports (8000: API HTTPS, 9091: Prometheus metrics HTTP)
EXPOSE 8000 9091

# Set entrypoint to run migrations before starting app
ENTRYPOINT ["/app/docker-entrypoint.sh"]

# Run with hot reload
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
