# ============================================================================
# LIA API - Test Environment Configuration
# ============================================================================
# Minimal configuration for running unit/integration tests.
# Values are test stubs — never use in production.
# ============================================================================

# ============================================================================
# [01] CORE
# ============================================================================
API_PREFIX=/api/v1
DEBUG=true

# ============================================================================
# [02] DATABASE & REDIS
# ============================================================================
# Database (managed by test fixtures / testcontainers)
DATABASE_URL=postgresql+asyncpg://test:test@localhost:5432/test_db

# Redis (overridden by conftest.py, uses DB 15 to avoid collisions)
REDIS_URL=redis://localhost:6379/15

# ============================================================================
# [03] SECURITY (test-only values, NOT for production)
# ============================================================================
SECRET_KEY=test-secret-key-change-in-production-minimum-32-chars-required-for-security
FERNET_KEY=nXQIoBSMZtcMuA30Zz8LUORRsD3zsV04L5oOJDoR0WM=

# ============================================================================
# [04] LLM MODEL STUBS
# ============================================================================
# These are test stubs — LLM calls are mocked in unit tests.
# Uses fake model names to ensure no real API calls are made.
ROUTER_LLM_MODEL=gpt-4.1-mini-mini
HITL_CLASSIFIER_LLM_MODEL=gpt-4.1-mini-mini
HITL_QUESTION_GENERATOR_LLM_MODEL=gpt-4.1-mini-mini
HITL_PLAN_APPROVAL_QUESTION_LLM_MODEL=gpt-4.1-mini-mini
PLANNER_LLM_MODEL=gpt-4.1-mini-mini
CONTACTS_AGENT_LLM_MODEL=gpt-4.1-mini-mini
EMAILS_AGENT_LLM_MODEL=gpt-4.1-mini-mini

# ============================================================================
# [05] OBSERVABILITY (disabled for tests)
# ============================================================================
OTEL_SDK_DISABLED=true
LANGFUSE_SECRET_KEY=sk-lf-test
LANGFUSE_PUBLIC_KEY=pk-lf-test
LANGFUSE_HOST=http://localhost:3000

# ============================================================================
# [06] RATE LIMITING (disabled for tests)
# ============================================================================
RATE_LIMIT_ENABLED=false

# ============================================================================
# [07] MEMORY (aggressive values for fast test cleanup)
# ============================================================================
MEMORY_MAX_AGE_DAYS=1
MEMORY_MIN_USAGE_COUNT=1
MEMORY_PURGE_THRESHOLD=0.5
MEMORY_CLEANUP_HOUR=0
MEMORY_CLEANUP_MINUTE=0
MEMORY_RELEVANCE_THRESHOLD=0.5
MEMORY_RETENTION_WEIGHT_USAGE=0.4
MEMORY_RETENTION_WEIGHT_IMPORTANCE=0.3
MEMORY_RETENTION_WEIGHT_RECENCY=0.3
