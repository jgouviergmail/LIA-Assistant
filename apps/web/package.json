    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "^4.1.2"
