{
  "name": "@lia-assistant/web",
  "version": "1.16.4",
  "description": "LIA Assistant - Frontend application",
  "license": "AGPL-3.0-or-later",
  "author": "LIA Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/jgouviergmail/LIA-Assistant.git"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:local": "next dev --webpack --hostname localhost",
    "dev:network": "next dev --webpack --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-api": "openapi-ts --input ../../api/openapi.json --output ./src/lib/generated"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "geist": "^1.7.0",
    "i18next": "^26.0.5",
    "i18next-resources-to-backend": "^1.2.1",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^0.577.0",
    "next": "16.2.3",
    "next-i18n-router": "^5.5.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "react-snowfall": "^2.4.0",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
