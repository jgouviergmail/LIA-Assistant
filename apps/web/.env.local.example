# ============================================
# Local Development Environment (pnpm dev)
# ============================================
# Use this file when running "pnpm dev" locally WITHOUT Docker Compose.
# Copy this file to .env.local and adjust as needed.
#
# For Docker Compose development, see .env.docker (variables set in docker-compose.dev.yml)
# ============================================

# API Configuration
# NEXT_PUBLIC_API_URL is used for client-side API calls (from browser)
# In local dev: Direct calls to backend
# In production: Set to absolute API URL (e.g., https://api.yourdomain.com)
NEXT_PUBLIC_API_URL=http://localhost:8000

# API_URL_SERVER is used for server-side API calls (Server Actions, SSR)
# In local dev: Use localhost since backend runs on host machine
# In Docker: Use service name (e.g., http://api:8000)
API_URL_SERVER=http://localhost:8000

# OAuth Configuration (Google Cloud Console)
# Get these from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Do NOT commit real credentials to version control
NEXT_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID

# Application Configuration
NEXT_PUBLIC_APP_NAME=LIA
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Change port if using custom WEB_HOST_PORT

# Logging Configuration
# Controls the minimum log level displayed in the browser console
# Values: debug | info | warn | error | none
# - debug: Show all logs (most verbose)
# - info: Show info, warn, and error logs
# - warn: Show only warnings and errors
# - error: Show only errors
# - none: Disable all console logs
# Default: debug (in development), warn (in production)
NEXT_PUBLIC_LOG_LEVEL=info

# Debug Panel Configuration
# The debug panel is controlled via the admin settings UI (Settings > Debug Panel toggle).
# No compile-time flag needed. When enabled, it displays scoring metrics for threshold tuning.

# Note: The backend handles OAuth flow, so Google Client Secret is NOT needed here
# All OAuth secrets should be configured in the backend .env file

# Allowed Dev Origins (comma-separated)
# Required for accessing the app via IP address/nip.io in development
# Prevents "Cross origin request detected" warning in Next.js
# Example for local network access: http://your-local-ip:3000,http://localhost:3000
NEXT_PUBLIC_ALLOWED_DEV_ORIGINS=http://localhost:3000  # Change port if using custom WEB_HOST_PORT

# ============================================================================
# FIREBASE CLOUD MESSAGING (FCM) - Push Notifications
# ============================================================================
# Firebase configuration for web push notifications.
# Enables reminder notifications even when the browser is closed.
#
# Prerequisites:
# 1. Create a Firebase project: https://console.firebase.google.com/
# 2. Add a Web App: Project Settings → General → Your apps → Add app (Web)
# 3. Copy the firebaseConfig values below
# 4. Generate VAPID key: Project Settings → Cloud Messaging → Web Push certificates
#
# IMPORTANT: All values are NEXT_PUBLIC_ prefixed (client-side, public)
# ============================================================================

# Firebase API Key
# Found in: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=

# Firebase Auth Domain
# Format: your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# Firebase Project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Storage Bucket
# Format: your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Firebase Messaging Sender ID
# Found in: Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Firebase App ID
# Found in: Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase VAPID Key (Web Push Certificate)
# Generate in: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# Click "Generate key pair" to create a new VAPID key
NEXT_PUBLIC_FIREBASE_VAPID_KEY=