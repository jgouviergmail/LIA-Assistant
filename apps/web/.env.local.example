# ============================================================================
# LIA Frontend - Local Development Environment
# ============================================================================
# Use this file when running "pnpm dev" locally WITHOUT Docker Compose.
# Copy this file to .env.local and adjust as needed.
# For Docker Compose, variables are set in docker-compose.dev.yml.
# ============================================================================

# ============================================================================
# [01] API CONFIGURATION
# ============================================================================
# Browser-side API URL (direct calls from frontend)
# Local dev: http://localhost:8000
# LAN access: https://<your-ip>.nip.io:8000 (accept self-signed cert first)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL (Server Actions, SSR)
# Local dev: http://localhost:8000 (backend on host)
# Docker: http://api:8000 (service name)
API_URL_SERVER=http://localhost:8000

# ============================================================================
# [02] OAUTH
# ============================================================================
# Google Client ID (public, safe for frontend)
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID

# ============================================================================
# [03] APPLICATION
# ============================================================================
NEXT_PUBLIC_APP_NAME=LIA
NEXT_PUBLIC_APP_URL=http://localhost:3000      # Change port if using custom WEB_HOST_PORT

# ============================================================================
# [04] LOGGING
# ============================================================================
# Browser console log level (debug|info|warn|error|none)
NEXT_PUBLIC_LOG_LEVEL=info

# ============================================================================
# [05] DEVELOPMENT
# ============================================================================
# Allowed dev origins (hostname only, comma-separated, NOT full URLs)
# Required for IP/nip.io access in Next.js 16+ (prevents CORS warnings)
NEXT_PUBLIC_ALLOWED_DEV_ORIGINS=localhost

# ============================================================================
# [06] FIREBASE CLOUD MESSAGING (FCM) - Push Notifications
# ============================================================================
# Setup: https://console.firebase.google.com/ → Project Settings → General → Web app
# VAPID key: Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
