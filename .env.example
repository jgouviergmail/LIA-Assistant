VOICE_STT_LANGUAGE=                                         # Language hint ISO 639-1 (empty = auto-detect)
VOICE_STT_TASK=transcribe                                   # valid: transcribe (same lang), translate (to English)
VOICE_STT_MAX_DURATION_SECONDS=60                           # Max audio duration in seconds


