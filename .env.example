HITL_LOW_CONFIDENCE_THRESHOLD=0.5                           # Below = inferred rejection (default: 0.5)
HITL_DEMOTION_CONFIDENCE=0.5                                # Confidence threshold when demoting EDIT to AMBIGUOUS (default: 0.5)
HITL_MAX_WAIT_SECONDS=900                                   # Max wait time for HITL user response in seconds (default: 900)
