MCP_USER_POOL_TTL_SECONDS=900                               # Connection pool TTL in seconds (15 min)
MCP_USER_POOL_MAX_TOTAL=50                                  # Max total connections in pool
MCP_USER_POOL_EVICTION_INTERVAL=60                          # Pool eviction check interval in seconds
# Base URL for OAuth 2.1 callbacks (required for OAuth-authenticated MCP servers)
MCP_USER_OAUTH_CALLBACK_BASE_URL=https://lia-back.yourdomain.com


