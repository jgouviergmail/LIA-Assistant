# Weather Change Detection
HEARTBEAT_WEATHER_RAIN_THRESHOLD_HIGH=0.6                   # Precipitation probability for rain alert (0.3-0.9)
HEARTBEAT_WEATHER_RAIN_THRESHOLD_LOW=0.4                    # Precipitation probability for clearing (0.1-0.5)
HEARTBEAT_WEATHER_TEMP_CHANGE_THRESHOLD=5.0                 # Temperature change in C for notification (2.0-15.0)
HEARTBEAT_WEATHER_WIND_THRESHOLD=14.0                       # Wind speed in m/s for wind alert (8.0-25.0)

# Last-known Location (proactive weather cascade)
LAST_KNOWN_LOCATION_TTL_HOURS=24                            # TTL hours for persisted geoloc before fallback to home (1-168)
LAST_KNOWN_LOCATION_MIN_DISTANCE_KM=50.0                    # Min distance km from home to prefer last-known (1.0-500.0)

# Early-exit Optimization
HEARTBEAT_INACTIVE_SKIP_DAYS=7                              # Skip if user inactive > N days (1-30)


