# ============================================================================
# [32] LONG-TERM MEMORY
# Config: src/core/config/agents.py
# ============================================================================

# Embedding Model (OpenAI text-embedding-3-small: 1536 dims)
MEMORY_EXTRACTION_ENABLED=true                              # Enable background memory extraction from conversations (default: true)
MEMORY_EMBEDDING_MODEL=models/gemini-embedding-001          # Gemini embedding model for memory search
MEMORY_EMBEDDING_DIMENSIONS=1536                            # Must match model dimensions
INTEREST_EMBEDDING_MODEL=models/gemini-embedding-001        # Gemini embedding model for interest dedup
INTEREST_EMBEDDING_DIMENSIONS=1536                          # Must match model dimensions
MEMORY_MAX_RESULTS=50                                       # Max memories to retrieve per query
MEMORY_EXTRACTION_MESSAGE_MAX_CHARS=3000                    # Max chars per message for extraction
MEMORY_EXTRACTION_MAX_TOKENS=1000                           # Max tokens for memory extraction LLM response (default: 1000)
MEMORY_EXTRACTION_TOP_P=1.0                                 # Top-p for memory extraction LLM (default: 1.0)
MEMORY_EXTRACTION_FREQUENCY_PENALTY=0.0                     # Frequency penalty for memory extraction LLM (default: 0.0)
MEMORY_EXTRACTION_PRESENCE_PENALTY=0.0                      # Presence penalty for memory extraction LLM (default: 0.0)

# Memory Search Thresholds
MEMORY_MIN_SEARCH_SCORE=0.65                                # Calibrated for Gemini embedding-001 (2026-04-09). Realistic bank: 1-4 results/query.
MEMORY_RELEVANCE_THRESHOLD=0.72                             # Min score for usage_count++ (purge protection). Match p75=0.735.

# Memory Deduplication (extraction-time contradiction detection)
MEMORY_DEDUP_SEARCH_LIMIT=10                                # Max candidates checked for semantic duplicates at extraction time
MEMORY_DEDUP_MIN_SCORE=0.4                                  # Min similarity for dedup candidates (lower = more contradictions caught, slightly more tokens)

# Hybrid Search (BM25 + Semantic)
MEMORY_HYBRID_ENABLED=false                                 # Enable hybrid search (false = semantic-only)
MEMORY_HYBRID_ALPHA=0.6                                     # Semantic weight (1-alpha = BM25 weight, default: 0.6)
MEMORY_HYBRID_MIN_SCORE=0.4                                 # Min hybrid score for inclusion (default: 0.5)
MEMORY_HYBRID_BOOST_THRESHOLD=0.5                           # Both scores above this get +10% boost (default: 0.5)
MEMORY_BM25_CACHE_MAX_USERS=100                             # BM25 local cache LRU limit (default: 100)

# Memory Reference Resolution (Pre-Planner Entity Resolution)
MEMORY_REFERENCE_RESOLUTION_TIMEOUT_MS=5000                 # Timeout for resolving relational references

# Memory Purge Configuration
# Retention score = weight_importance * importance + weight_recency * recency_factor
# recency_factor decays linearly from 1.0 (new) to 0.0 over MEMORY_RECENCY_DECAY_DAYS.
# If a memory has usage_count == 0 past the penalty age, its score is multiplied by
# MEMORY_USAGE_PENALTY_FACTOR (never-activated = suspect).
# A memory is purged if its final score < MEMORY_PURGE_THRESHOLD.
MEMORY_CLEANUP_HOUR=4                                       # Cleanup job hour (UTC)
MEMORY_CLEANUP_MINUTE=0                                     # Cleanup job minute
MEMORY_MIN_AGE_FOR_CLEANUP_DAYS=7                           # Grace period before a memory becomes purge-eligible
MEMORY_RECENCY_DECAY_DAYS=45                                # Horizon over which recency_factor decays to 0
MEMORY_USAGE_PENALTY_AGE_DAYS=30                            # Age threshold for applying zero-usage penalty
MEMORY_USAGE_PENALTY_FACTOR=0.5                             # Multiplier on score when usage_count==0 past threshold
MEMORY_RETENTION_WEIGHT_IMPORTANCE=0.7                      # Importance factor weight (dominant signal)
MEMORY_RETENTION_WEIGHT_RECENCY=0.3                         # Recency factor weight
MEMORY_PURGE_THRESHOLD=0.5                                  # Retention score below this = purged

# Memory Consolidation (daily semantic deduplication of near-identical memories)
# Runs at 5 AM UTC by default, right after the cleanup job. Merges pairs with
# cosine similarity >= MEMORY_CONSOLIDATION_SIMILARITY_THRESHOLD, excluding
# pinned memories, differing categories, and pairs with divergent affect.
MEMORY_CONSOLIDATION_ENABLED=true                           # Enable daily consolidation job
MEMORY_CONSOLIDATION_HOUR=5                                 # UTC hour for the job
MEMORY_CONSOLIDATION_SIMILARITY_THRESHOLD=0.9               # Min cosine similarity to merge
MEMORY_CONSOLIDATION_MAX_PAIRS_PER_USER=50                  # Cap per user per run (blast radius)
MEMORY_CONSOLIDATION_EMOTIONAL_DIFF_SKIP=5                  # Skip pair if |weight_a - weight_b| > this


