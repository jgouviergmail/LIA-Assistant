# Cooldowns
HEARTBEAT_GLOBAL_COOLDOWN_HOURS=1                           # Min hours between heartbeat notifications (1-12)
HEARTBEAT_ACTIVITY_COOLDOWN_MINUTES=15                      # Don't notify if user active within N minutes (5-60)
PROACTIVE_CROSS_TYPE_COOLDOWN_MINUTES=10                    # Min minutes between different proactive types (5-120)

# Context Aggregation
HEARTBEAT_CONTEXT_CALENDAR_HOURS=4                          # Hours ahead to look for calendar events (1-24)
HEARTBEAT_CONTEXT_MEMORY_LIMIT=5                            # Max user memories in context (1-20)
HEARTBEAT_CONTEXT_EMAILS_MAX=5                              # Max recent emails in heartbeat context (default: 5)
