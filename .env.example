# ============================================================================
# [53] INTEREST LEARNING
# Config: src/core/config/notifications.py
# ============================================================================
# Learns user interests from conversations and sends proactive notifications.

# Feature Toggles
INTEREST_EXTRACTION_ENABLED=true                            # Extract interests from conversations
INTEREST_NOTIFICATIONS_ENABLED=true                         # Enable proactive interest notifications
INTEREST_NOTIFY_START_HOUR=9                                # Earliest notification hour (user local time)
INTEREST_NOTIFY_END_HOUR=22                                 # Latest notification hour (user local time)
PROACTIVE_FEEDBACK_ENABLED=true                             # Show feedback buttons on proactive messages
PROACTIVE_NOTIFICATION_MAX_LENGTH=150                       # Max chars for notification preview

# Proactive Message Injection (LangGraph State)
PROACTIVE_INJECT_MAX_MESSAGES=5                             # Max proactive messages injected per turn (1-20)
PROACTIVE_INJECT_LOOKBACK_HOURS=24                          # Lookback window when no checkpoint exists (1-168)

# Content Sources
INTEREST_WIKIPEDIA_SEARCH_LIMIT=3                           # Max Wikipedia search results for content
INTEREST_PERPLEXITY_RECENCY_FILTER=week                     # valid: day, week, month, year
INTEREST_PERPLEXITY_RETURN_RELATED_QUESTIONS=false           # Include related questions in search

# Scheduler & Batching
INTEREST_NOTIFICATION_INTERVAL_MINUTES=5                    # Scheduler interval in minutes
INTEREST_NOTIFICATION_BATCH_SIZE=50                         # Users per scheduler run

# Interest Selection & Cooldowns
INTEREST_TOP_PERCENT=1.0                                    # Top N% by weight for notifications (0.0-1.0)
INTEREST_GLOBAL_COOLDOWN_HOURS=1                            # Min hours between any two notifications
INTEREST_PER_TOPIC_COOLDOWN_HOURS=12                        # Min hours before re-notifying same interest
INTEREST_ACTIVITY_COOLDOWN_MINUTES=5                        # Don't notify if user active within N minutes

# Bayesian Prior (Beta distribution for interest confidence)
INTEREST_PRIOR_ALPHA=2                                      # Beta alpha (higher = more optimistic start)
INTEREST_PRIOR_BETA=1                                       # Beta beta

# Weight Evolution
INTEREST_DECAY_RATE_PER_DAY=0.005                           # Daily weight decay without mention
INTEREST_DORMANT_THRESHOLD_DAYS=15                          # Days below threshold before dormant
INTEREST_DELETION_THRESHOLD_DAYS=30                         # Days dormant before auto-deletion

# Deduplication
INTEREST_DEDUP_SIMILARITY_THRESHOLD=0.89                    # Topic merge. Calibrated 2026-04-09 v2: F1=0.800, zero false merges.
INTEREST_CONTENT_SIMILARITY_THRESHOLD=0.90                  # Notif dedup. Calibrated for Gemini embedding-001 (2026-04-09).
INTEREST_DEDUP_SEARCH_LIMIT=20                              # Max embeddings to check for similarity

# Content Generation
INTEREST_CONTENT_MAX_LENGTH=500                             # Max chars for notification content
INTEREST_CONTENT_LOOKBACK_DAYS=7                            # Lookback window for content generation

# Query Processing
INTEREST_EXTRACTION_QUERY_TRUNCATION_LENGTH=500             # Max chars for extraction query

# Limits
INTEREST_USER_LIST_LIMIT=200                                # Max users in interest queries
INTEREST_ACTIVE_LIST_LIMIT=50                               # Max active interests per user


# ============================================================================
# [54] PLAN PATTERN LEARNING
# Config: src/core/config/agents.py
# ============================================================================
# Dynamic learning from planner successes/failures. Records outcomes to Redis,
# injects patterns in prompts, bypasses validation for high-confidence patterns.

PLAN_PATTERN_TRAINING_ENABLED=false                         # Enable plan pattern learning

# Bayesian Prior: Beta(alpha, beta) — initial confidence = alpha/(alpha+beta)
PLAN_PATTERN_PRIOR_ALPHA=2                                  # Default: 2 (67% initial confidence)
PLAN_PATTERN_PRIOR_BETA=1                                   # Default: 1

# Decision Thresholds
PLAN_PATTERN_MIN_OBS_SUGGEST=3                              # Min observations to suggest pattern
PLAN_PATTERN_MIN_CONF_SUGGEST=0.75                          # Min confidence to suggest (75%)
PLAN_PATTERN_MIN_OBS_BYPASS=10                              # Min observations to bypass validation
PLAN_PATTERN_MIN_CONF_BYPASS=0.90                           # Min confidence to bypass (90%)

# Performance
PLAN_PATTERN_MAX_SUGGESTIONS=3                              # Max patterns injected in prompt
PLAN_PATTERN_SUGGESTION_TIMEOUT_MS=100                      # Redis lookup timeout in ms (fail-open)
PLAN_PATTERN_LOCAL_CACHE_TTL_S=1.0                          # Local cache TTL to reduce Redis calls

# Redis Storage
PLAN_PATTERN_REDIS_PREFIX=plan:patterns                     # Redis key prefix
PLAN_PATTERN_REDIS_TTL_DAYS=30                              # Pattern expiration (days of inactivity)


# ============================================================================
# [55] SEMANTIC LINKING & TEXT COMPACTION
# Config: src/core/config/agents.py
# ============================================================================

# Semantic Linking — cross-domain parameter linking
SEMANTIC_LINKING_ENABLED=true                               # Enable automatic parameter source suggestions
SEMANTIC_EXPANSION_THRESHOLD=0.7                            # Expansion toggle (< 1.0 enables, = 1.0 disables)
SEMANTIC_LINKING_MAX_SUGGESTIONS=5                          # Max suggestions per parameter

# Text Compaction — token optimization for embedded data in text parameters
TEXT_COMPACTION_ENABLED=true                                 # Enable post-Jinja compaction of data structures
TEXT_COMPACTION_MIN_SIZE=200                                 # Min chars for a data structure to be compacted
TEXT_COMPACTION_MAX_ITEMS=5                                  # Max items shown per list in compacted format
TEXT_COMPACTION_MAX_FIELD_LENGTH=40                          # Max chars per field value in compacted format

# Entity Resolution (name mention disambiguation)
ENTITY_RESOLUTION_ENABLED=true                              # Enable automatic entity resolution for name mentions (default: true)
ENTITY_RESOLUTION_AUTO_THRESHOLD=0.9                        # Auto-resolve threshold (no disambiguation) (default: 0.9)
ENTITY_RESOLUTION_MAX_CANDIDATES=5                          # Max candidates shown in disambiguation questions (default: 5)


# ============================================================================
# [56] MCP — Admin Servers
# Config: src/core/config/mcp.py
# ============================================================================
# MCP (Model Context Protocol) allows connecting external tool servers.
# Tools are discovered at startup and registered in the existing catalogue.
# Reference: docs/technical/MCP_INTEGRATION.md

MCP_ENABLED=true                                            # Enable MCP integration

# JSON config for MCP servers
# Format: {"name": {"transport": "stdio"|"streamable_http", "command": "...", "args": [...], "url": "...", "env": {...}, "timeout_seconds": 30, "enabled": true, "hitl_required": null, "description": "...", "internal": false}}
# - description: Domain description for query routing (helps LLM select the right server)
# - internal: Set true for Docker-internal services (skips SSRF validation for HTTP + private IPs)
# MCP_SERVERS_CONFIG={"filesystem":{"transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}
# Example with Docker-internal Google Flights server:
# MCP_SERVERS_CONFIG={"google_flights":{"transport":"streamable_http","url":"http://google-flights:8000/mcp","internal":true,"description":"Search flights, find airports, compare prices and get best flight deals worldwide","timeout_seconds":120,"enabled":true,"hitl_required":false}}
# Excalidraw admin MCP server (interactive diagram creation via MCP Apps)
# iterative_mode=true: delegates to ReAct sub-agent (reads docs first, then creates)
MCP_SERVERS_CONFIG={"excalidraw":{"transport":"streamable_http","url":"https://mcp.excalidraw.com","timeout_seconds":60,"enabled":true,"hitl_required":false,"iterative_mode":true,"description":"Provides interactive hand-drawn diagram creation and sharing using Excalidraw element format. It can render streaming, animated diagrams from element definitions, upload finished diagrams to Excalidraw and return shareable URLs, and save/restore user-edited diagram states. Call the element format reference before first render."}}
# Alternative: path to JSON config file (overrides MCP_SERVERS_CONFIG)
MCP_SERVERS_CONFIG_PATH=                                    # Path to JSON config file (overrides MCP_SERVERS_CONFIG, default: empty)

MCP_TOOL_TIMEOUT_SECONDS=120                                # Timeout per MCP tool call (default: 120)
MCP_MAX_SERVERS=10                                          # Max admin MCP servers (default: 10)
MCP_MAX_TOOLS_PER_SERVER=40                                 # Max tools discovered per server (default: 40)

# MCP ReAct Sub-Agent (ADR-062): iterative multi-step MCP interaction
MCP_REACT_ENABLED=true                                      # Enable ReAct sub-agent for iterative_mode servers
MCP_REACT_MAX_ITERATIONS=10                                 # Max ReAct iterations per MCP call

MCP_HITL_REQUIRED=false                                     # Default HITL requirement for MCP tools
MCP_RATE_LIMIT_CALLS=60                                     # MCP rate limit calls per window
MCP_RATE_LIMIT_WINDOW=60                                    # MCP rate limit window in seconds
MCP_HEALTH_CHECK_INTERVAL_SECONDS=300                       # Health check interval (default: 300)
MCP_CONNECTION_RETRY_MAX=3                                  # Max connection retries
MCP_MAX_STRUCTURED_ITEMS_PER_CALL=25                        # Max structured items per MCP call
MCP_APP_MAX_HTML_SIZE=2097152                               # Max HTML size from MCP read_resource in bytes (default: 2MB)
MCP_REFERENCE_CONTENT_MAX_CHARS=30000                       # Max chars of read_me content injected in planner (default: 30000)


