# ============================================================================
# ENVIRONMENT & LOGGING
# ============================================================================
# Application Environment
ENVIRONMENT=development
DEBUG=true
# Application Log Level
# DEBUG : Everything (debug, info, warning, error, critical)
# INFO : Info, warning, error, critical (no debug)
# WARNING : Warning, error, critical only
# ERROR : Error and critical only
# CRITICAL : Critical only
# Use DEBUG to see detailed logs for troubleshooting, WARNING for production
LOG_LEVEL=INFO
# HTTP Request Logging Configuration
# Log level used for HTTP request_started/request_completed events.
# These logs are filtered by LOG_LEVEL: HTTP_LOG_LEVEL must be >= LOG_LEVEL to appear.
#
# Typical setup:
#   LOG_LEVEL=INFO + HTTP_LOG_LEVEL=DEBUG  → HTTP logs hidden (DEBUG < INFO)
#   LOG_LEVEL=INFO + HTTP_LOG_LEVEL=INFO   → HTTP logs visible
#   LOG_LEVEL=DEBUG + HTTP_LOG_LEVEL=DEBUG → HTTP logs visible
#
# Values: DEBUG (default), INFO, WARNING, ERROR (not recommended - misleading)
HTTP_LOG_LEVEL=DEBUG
# Paths to exclude from HTTP request logging (comma-separated list)
# Default: /metrics,/health (noisy endpoints scraped frequently)
HTTP_LOG_EXCLUDE_PATHS=/metrics,/health
# Third-party Library Log Levels
LOG_LEVEL_HTTPX=ERROR
LOG_LEVEL_SQLALCHEMY=ERROR
LOG_LEVEL_UVICORN=ERROR
LOG_LEVEL_UVICORN_ACCESS=ERROR

# ============================================================================
# FCM CONFIGURATION
# ============================================================================
FCM_ENABLED=true
FIREBASE_CREDENTIALS_PATH=config/firebase-service-account.json
FIREBASE_PROJECT_ID=CHANGE_ME_FIREBASE_PROJECT_ID
# Firebase Client SDK (Frontend - NEXT_PUBLIC_* are exposed to browser)
NEXT_PUBLIC_FIREBASE_API_KEY=CHANGE_ME_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=CHANGE_ME_FIREBASE_PROJECT_ID.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=CHANGE_ME_FIREBASE_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=CHANGE_ME_FIREBASE_PROJECT_ID.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=CHANGE_ME_FIREBASE_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=CHANGE_ME_FIREBASE_APP_ID
NEXT_PUBLIC_FIREBASE_VAPID_KEY=CHANGE_ME_FIREBASE_VAPID_KEY

# ============================================================================
# API CONFIGURATION
# ============================================================================
# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
# CORS Configuration
CORS_ORIGINS=https://lia.yourdomain.com,https://lia-back.yourdomain.com
# URLs
FRONTEND_URL=https://lia.yourdomain.com
API_URL=https://lia-back.yourdomain.com

# ============================================================================
# OBSERVABILITY - TRACING (OpenTelemetry)
# ============================================================================
# OpenTelemetry Configuration
# For Docker: use service name (tempo)
# For local dev: use localhost
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=lia-api

# ============================================================================
# OBSERVABILITY - METRICS (Prometheus)
# ============================================================================
# Dedicated HTTP-only metrics server port (separate from main HTTPS API)
# Prometheus scrapes this port directly (no TLS handshake needed)
PROMETHEUS_METRICS_PORT=9091

# ============================================================================
# OBSERVABILITY - GEOIP (IP Geolocation)
# ============================================================================
# Enriches HTTP request logs with geographic data (country, city, lat/lon)
# Uses DB-IP Lite City MMDB database (free, CC-BY-4.0)
# Database is downloaded during Docker build (see Dockerfile)
GEOIP_ENABLED=true
GEOIP_DB_PATH=/data/geoip/dbip-city-lite.mmdb

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
# Secret Keys
# Generate with: openssl rand -base64 32
# Minimum length: 32 characters (enforced by config validation)
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256
# Encryption Key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_FERNET_KEY
# Session Cookie Configuration
# Session durations are defined in src/core/constants.py
# Default session: 7 days (604,800 seconds)
# Remember me session: 30 days (2,592,000 seconds)
SESSION_COOKIE_NAME=lia_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
# Session Cookie Domain
# IMPORTANT for OAuth cross-port cookie sharing in development:
# Set to "localhost" for local dev (enables cookies between ports 3000 and 8000)
# For production: set to ".yourdomain.com" to share cookies across subdomains
SESSION_COOKIE_DOMAIN=.yourdomain.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL Credentials (used by docker-compose)
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD
POSTGRES_DB=lia
# Database Connection
# For Docker: use service names (postgres)
# For local dev: use localhost
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# Database Pool Settings
# Reference: https://docs.sqlalchemy.org/en/20/core/pooling.html
# Sizing: pool_size >= concurrent_users x avg_connections_per_request
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis Credentials (used by docker-compose)
REDIS_PASSWORD=CHANGE_ME_PASSWORD
# Redis Connection
# For Docker: use service names (redis)
# For local dev: use localhost
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# Redis Database Assignments
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2
# Redis Pool Settings
# Reference: https://redis.io/docs/latest/develop/clients/pools-and-muxing/
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=30
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_HEALTH_CHECK_INTERVAL=30

# ============================================================================
# DOCKER SERVICES CREDENTIALS
# ============================================================================
# PgAdmin Credentials
PGADMIN_DEFAULT_EMAIL=admin@lia.local
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PASSWORD
# Grafana Credentials
GRAFANA_ADMIN_USER=CHANGE_ME_GRAFANA_USER
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_PASSWORD
# MinIO Credentials (S3-compatible storage)
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_PASSWORD
# Langfuse Database Credentials
LANGFUSE_DB_USER=CHANGE_ME_LANGFUSE_DB_USER
LANGFUSE_DB_PASSWORD=CHANGE_ME_PASSWORD
# Langfuse ClickHouse Credentials
CLICKHOUSE_USER=CHANGE_ME_CLICKHOUSE_USER
CLICKHOUSE_PASSWORD=CHANGE_ME_PASSWORD
# Langfuse Redis Credentials
LANGFUSE_REDIS_PASSWORD=CHANGE_ME_PASSWORD
# Langfuse Security Keys (CHANGE IN PRODUCTION)
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_SECRET_KEY
LANGFUSE_SALT=CHANGE_ME_SALT
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_64_HEX_CHARS

# ============================================================================
# SSL CONFIGURATION (Development only)
# ============================================================================
# Domain for self-signed SSL certificates (used by ssl-init container in dev)
# For LAN access, use nip.io with your local IP (e.g., 192.168.1.100.nip.io)
# The IP is automatically extracted from nip.io domains for SAN inclusion
# Not needed in production (use real certificates from Let's Encrypt, etc.)
#SSL_DOMAIN=192.168.1.100.nip.io

# ============================================================================
# WEB FRONTEND CONFIGURATION (Next.js)
# ============================================================================
# Node Environment
NODE_ENV=development
# API Configuration (BFF Pattern)
# NEXT_PUBLIC_API_URL: URL used by the browser to call the API
# In localhost dev: https://localhost:8000
# For LAN access: https://<your-ip>.nip.io:8000 (must accept self-signed cert in browser first)
NEXT_PUBLIC_API_URL=https://localhost:8000
# Server-side API URL (SSR, Server Actions)
# Uses Docker service name for container-to-container communication
API_URL_SERVER=https://api:8000
# HTTP variant for Next.js rewrites (proxy fallback)
# Next.js rewrite proxy cannot validate self-signed certs, so this HTTP fallback exists
# In practice, browser calls NEXT_PUBLIC_API_URL directly — rewrites are not used for API calls
API_URL_SERVER_HTTP=http://api:8000
# Application URL (HTTPS via Next.js experimental-https)
# For LAN access: https://<your-ip>.nip.io:3000
NEXT_PUBLIC_APP_URL=https://localhost:3000
# Logging Configuration (Frontend)
# Controls the minimum log level displayed in the browser console
# Values: debug | info | warn | error | none
# Default: debug (in development), warn (in production)
NEXT_PUBLIC_LOG_LEVEL=info
# OAuth Configuration (Frontend)
# Google Client ID (public, safe to expose in frontend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
# Application Name
NEXT_PUBLIC_APP_NAME=LIA
# Allowed Dev Origins (hostname only, comma-separated)
# Required for accessing the app via IP address/nip.io in development
# Prevents "Cross origin request detected" warning in Next.js 16+
# IMPORTANT: Use hostname only, NOT full URL (e.g., 192.168.1.100.nip.io, NOT https://...)
# For LAN access: replace with your nip.io hostname (e.g., 192.168.1.100.nip.io)
NEXT_PUBLIC_ALLOWED_DEV_ORIGINS=localhost
# Jinja2 Template Evaluation (Issue #41)
JINJA_MAX_RECURSION_DEPTH=20

# ============================================================================
# SMTP & ALERTMANAGER CONFIGURATION
# ============================================================================
# Unified SMTP configuration for both application emails and monitoring alerts
# Uses the same SMTP server but different sender addresses for separation
# SMTP Server Configuration
ALERTMANAGER_SMTP_SMARTHOST=CHANGE_ME_SMTP_HOST:587
# SMTP Authentication
ALERTMANAGER_SMTP_AUTH_USERNAME=CHANGE_ME_SMTP_USERNAME
ALERTMANAGER_SMTP_AUTH_PASSWORD=CHANGE_ME_SMTP_PASSWORD
# Email Sender Addresses
APPLICATION_SMTP_FROM=noreply@yourdomain.com
ALERTMANAGER_SMTP_FROM=alerts@yourdomain.com
# Email Recipients for Monitoring Alerts
ALERTMANAGER_BACKEND_TEAM_EMAIL=your-email@example.com
ALERTMANAGER_FINANCE_TEAM_EMAIL=your-email@example.com
ALERTMANAGER_SECURITY_TEAM_EMAIL=your-email@example.com
ALERTMANAGER_ML_TEAM_EMAIL=your-email@example.com
# Slack Webhooks (OPTIONAL - leave empty to disable)
ALERTMANAGER_SLACK_WEBHOOK_CRITICAL=
ALERTMANAGER_SLACK_WEBHOOK_WARNING=
ALERTMANAGER_SLACK_WEBHOOK_SECURITY=
# PagerDuty (OPTIONAL - leave empty to disable)
ALERTMANAGER_PAGERDUTY_ROUTING_KEY=

# ============================================================================
# OAUTH CONFIGURATION
# ============================================================================
# Google OAuth
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Create separate Client IDs for development and production (security best practice 2025)
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
# Google OAuth Redirect URI
# Backend handles OAuth callback directly (port 8000)
# Cookie sharing between ports works because SESSION_COOKIE_DOMAIN is set to the base domain
# Production: https://yourdomain.com/api/v1/auth/google/callback (via nginx reverse proxy)
GOOGLE_REDIRECT_URI=https://lia-back.yourdomain.com/api/v1/auth/google/callback
# Google API Key (for Places photos, Drive thumbnails)
GOOGLE_API_KEY=CHANGE_ME_API_KEY

# OpenAI API Key (read by openai SDK, used by langchain-openai)
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY

# =============================================================================
# Brave Search API (user connector - API key per user)
# Note: No global API key - each user configures their own via Settings > Connectors
# =============================================================================
CLIENT_RATE_LIMIT_BRAVE_SEARCH_PER_SECOND=20.0
BRAVE_SEARCH_CACHE_TTL_SECONDS=3600

# Microsoft 365 OAuth (Entra ID / Azure AD)
# Get these from Azure Portal: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# App Registration > Certificates & secrets > New client secret
# Redirect URIs: http://localhost:8000/api/v1/connectors/microsoft-outlook/callback (+ calendar, contacts, tasks)
# MICROSOFT_TENANT_ID: "common" = personal + enterprise (default),
#                      "consumers" = personal only, "organizations" = enterprise only
MICROSOFT_CLIENT_ID=CHANGE_ME_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
MICROSOFT_TENANT_ID=common

# =============================================================================
# APPLE iCLOUD CONFIGURATION
# Apple connectors use Apple ID + app-specific password (not OAuth).
# App-specific passwords are generated at https://appleid.apple.com/
# Requires 2FA enabled on the Apple account.
# =============================================================================
# IMAP / SMTP (Apple Mail)
APPLE_IMAP_HOST=imap.mail.me.com
APPLE_IMAP_PORT=993
APPLE_SMTP_HOST=smtp.mail.me.com
APPLE_SMTP_PORT=587
APPLE_SMTP_DAILY_LIMIT=1000           # Apple imposes 1000 messages/day
APPLE_SMTP_MAX_RECIPIENTS=500         # 500 recipients per message
APPLE_SMTP_MAX_SIZE_MB=20             # 20MB per message
# CalDAV (Apple Calendar)
APPLE_CALDAV_URL=https://caldav.icloud.com
# CardDAV (Apple Contacts)
APPLE_CARDDAV_URL=https://contacts.icloud.com
# Common
APPLE_CONNECTION_TIMEOUT=30.0
CLIENT_RATE_LIMIT_APPLE_PER_SECOND=5
APPLE_CONTACTS_CACHE_TTL=600          # Full contacts list cache (10 minutes)
APPLE_EMAIL_MESSAGE_CACHE_TTL=60      # Individual IMAP message cache (solves N+1)

# =============================================================================
# KNOWLEDGE ENRICHMENT (Brave Search integration)
# Enriches LLM responses with up-to-date web/news search results
# =============================================================================
KNOWLEDGE_ENRICHMENT_ENABLED=true

# ============================================================================
# OBSERVABILITY - LANGFUSE (LLM Observability)
# ============================================================================
# Langfuse Configuration
# Enable/disable Langfuse tracing for LLM observability
LANGFUSE_ENABLED=false
# Langfuse Self-Hosted URL
# For Docker: use service name (langfuse-web)
# For local dev: use localhost:3002
LANGFUSE_HOST=http://langfuse-web:3000
# Langfuse API Keys
LANGFUSE_PUBLIC_KEY=CHANGE_ME_API_KEY
LANGFUSE_SECRET_KEY=CHANGE_ME_SECRET_KEY
# Langfuse Tracing Configuration
# Release version for tracking deployments (optional)
LANGFUSE_RELEASE=development
# Sample rate for tracing (0.0-1.0, 1.0 = trace everything)
# Lower values reduce storage and processing costs
# Recommended: 1.0 for development, 0.1-0.5 for production
LANGFUSE_SAMPLE_RATE=1.0
# Langfuse Performance
# Flush interval in seconds (how often to send traces to server)
# Lower = more real-time but more requests, Higher = batched but delayed
LANGFUSE_FLUSH_INTERVAL=600
# Debug Mode (true/false)
# Enables detailed SDK logging to stdout (useful for troubleshooting)
# WARNING: Generates significant log volume. Disable in production.
LANGFUSE_DEBUG=true

# ============================================================================
# LLM CACHING
# ============================================================================
# Enable LLM response caching for Router and Planner nodes
LLM_CACHE_ENABLED=false
# Cache TTL in seconds (default: 300 = 5 minutes)
LLM_CACHE_TTL_SECONDS=60
# Conversation ID cache TTL (avoids DB lookup per request)
# Default: 300 seconds (5 minutes), range: 60-3600
CONVERSATION_ID_CACHE_TTL_SECONDS=60

# ============================================================================
# LLM PRICING & COST TRACKING
# ============================================================================
# Background Tasks & Scheduler
# Currency exchange rate synchronization schedule
# Runs daily at 3:00 AM UTC (see src/core/constants.py CURRENCY_SYNC_HOUR)
DEFAULT_CURRENCY=EUR
# LLM Pricing Cache TTL (seconds)
LLM_PRICING_CACHE_TTL_SECONDS=3600
# Fallback USD/EUR rate when DB/API unavailable (updated manually)
# Check current rate: https://api.frankfurter.app/latest?from=USD&to=EUR
DEFAULT_USD_EUR_RATE=0.93
# Currency Exchange Rates API
CURRENCY_API_URL=https://api.frankfurter.app

# ============================================================================
# GLOBAL API SECURITY LIMITS
# ============================================================================
# Maximum number of items that can be returned by any API call to external services
API_MAX_ITEMS_PER_REQUEST=20

# ============================================================================
# STATE & MEMORY MANAGEMENT
# ============================================================================
# AGENT_MAX_ITERATIONS: Limits ReAct agent iterations (contacts, emails, etc.)
AGENT_MAX_ITERATIONS=20
# MAX_MESSAGES_HISTORY: Max messages to keep in LangGraph state (PostgreSQL)
MAX_MESSAGES_HISTORY=150
# MAX_TOKENS_HISTORY: Token threshold before automatic history truncation
MAX_TOKENS_HISTORY=200000
# AGENT_HISTORY_KEEP_LAST: Recent messages kept in ReAct agent context
AGENT_HISTORY_KEEP_LAST=30
# MAX_CONTEXT_BATCH_SIZE: Max items returned by get_context_list (batch operations)
MAX_CONTEXT_BATCH_SIZE=10
# MAX_AGENT_RESULTS: Max agent_results kept in memory (cleanup per turn)
MAX_AGENT_RESULTS=10
# Maximum items per domain in multi-domain responses
V3_DISPLAY_MAX_ITEMS_PER_DOMAIN=5
# MAX_ROUTING_HISTORY: Max routing history entries kept
MAX_ROUTING_HISTORY=30
# REGISTRY_MAX_ITEMS: Max items in data_registry (contacts, emails, etc.)
REGISTRY_MAX_ITEMS=75

# ============================================================================
# LLM WINDOWING (Token Optimization)
# ============================================================================
# DEFAULT_MESSAGE_WINDOW_SIZE
# Purpose: Default value for windowing (fallback)
DEFAULT_MESSAGE_WINDOW_SIZE=4
# ROUTER_MESSAGE_WINDOW_SIZE
# Purpose: Context for router (quick intent decision)
ROUTER_MESSAGE_WINDOW_SIZE=4
# PLANNER_MESSAGE_WINDOW_SIZE
# Purpose: Context for planner (execution plan generation)
PLANNER_MESSAGE_WINDOW_SIZE=4
# RESPONSE_MESSAGE_WINDOW_SIZE
# Purpose: Context for final response generation
RESPONSE_MESSAGE_WINDOW_SIZE=10

# ============================================================================
# TOOLS CONFIGURATION
# ============================================================================
# Tool Context Management (Agent Memory & State)
# Confidence threshold for fuzzy matching in context resolution (0.0-1.0)
TOOL_CONTEXT_CONFIDENCE_THRESHOLD=0.7
# Maximum number of items to keep in context list per domain (search results)
TOOL_CONTEXT_MAX_ITEMS=10
# Maximum number of detailed items to cache per domain (Phase 3.2.9 - Multi-Keys Store Pattern)
TOOL_CONTEXT_DETAILS_MAX_ITEMS=5

# ============================================================================
# SCORING THRESHOLDS - COMPLETE GUIDE
# ============================================================================
#
# QUERY PROCESSING FLOW:
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  User Query                                                              │
# │       ↓                                                                  │
# │  [1] INTENT DETECTION (SemanticIntentDetector)                          │
# │       → Detects: search, details, create, chat, etc.                    │
# │       → Uses: SEMANTIC_INTENT_* thresholds                             │
# │       ↓                                                                  │
# │  [2] DOMAIN SELECTION (SemanticDomainSelector)                          │
# │       → Selects: calendar, contacts, places, etc.                       │
# │       → Uses: SEMANTIC_DOMAIN_* + V3_DOMAIN_* thresholds               │
# │       ↓                                                                  │
# │  [3] ROUTING DECISION (QueryIntelligenceService)                        │
# │       → Decides: chat (direct response) or planner (tool execution)     │
# │       → Uses: V3_ROUTING_* thresholds                                  │
# │       ↓                                                                  │
# │  [4] TOOL SELECTION (SemanticToolSelector) - if route=planner           │
# │       → Filters tool catalogue for the LLM                              │
# │       → Uses: SEMANTIC_TOOL_SELECTOR_* thresholds                      │
# │       ↓                                                                  │
# │  [5] CONTEXT RESOLUTION (ContextResolutionService) - if references      │
# │       → Resolves "the 2nd appointment" → concrete event_id             │
# │       → Uses: CONTEXT_REFERENCE_CONFIDENCE_THRESHOLD                   │
# │       ↓                                                                  │
# │  [6] SEMANTIC VALIDATION (SemanticValidator) - post-execution           │
# │       → Verifies that results answer the question                       │
# │       → Uses: SEMANTIC_VALIDATION_CONFIDENCE_THRESHOLD                 │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ============================================================================
# ============================================================================
# [1] SEMANTIC_INTENT_* - User intent detection
# ============================================================================
# Determines confidence in the intent: search, details, create, chat...
# ============================================================================
# SEMANTIC_INTENT_FALLBACK_THRESHOLD
# ├── Role: Below this = uncertain intent → fallback
# ├── When: No intent >= 0.50 → use default intent
# ├── Example: "hmm..." → search(0.3), chat(0.4) → fallback
# └── Adjust: ↑ to be more strict
SEMANTIC_INTENT_FALLBACK_THRESHOLD=0.7 # 0.50
# SEMANTIC_INTENT_HIGH_THRESHOLD
# ├── Role: Above this = CERTAIN intent
# ├── When: score >= 0.75 → high confidence in intent
# ├── Example: "delete this appointment" → delete(0.95) = certain
# └── Adjust: ↑ to require more certainty
SEMANTIC_INTENT_HIGH_THRESHOLD=0.85 # 0.75
# SEMANTIC_FALLBACK_THRESHOLD
# ├── Role: Global fallback threshold (backup)
# └── Adjust: Rarely modified, safety net
SEMANTIC_FALLBACK_THRESHOLD=0.75 # 0.4

# ============================================================================
# [2b] V3_DOMAIN_SOFTMAX_* - Softmax temperature calibration
# ============================================================================
# SOLUTION to narrow discrimination problem (scores 0.83-0.86).
# Applies softmax with low temperature to AMPLIFY differences.
#
# BEFORE calibration: emails=0.86, calendar=0.85, contacts=0.84 (delta=0.02)
# AFTER calibration: emails=0.65, calendar=0.20, contacts=0.08 (delta=0.57!)
#
# IMPACT: Drastically improves correct domain selection.
# ============================================================================
# V3_DOMAIN_SOFTMAX_TEMPERATURE
# ├── Role: Softmax temperature AFTER min-max stretching
# ├── Pipeline: raw scores → stretching [0,1] → softmax(T)
# ├── Values (with stretching):
# │   - T=1.0 → soft discrimination
# │   - T=0.2 → moderate discrimination
# │   - T=0.1 → strong discrimination ← RECOMMENDED
# │   - T=0.05 → winner-takes-most
# └── Adjust: ↓ for more discrimination, ↑ for less
V3_DOMAIN_SOFTMAX_TEMPERATURE=0.8
# V3_DOMAIN_CALIBRATED_PRIMARY_MIN
# ├── Role: Minimum calibrated score for primary domain
# ├── When: After softmax, top domain must have >= this score
# ├── Example: If top calibrated = 0.12 and threshold = 0.15 → uncertainty
# └── Adjust: ↑ to require more certainty
V3_DOMAIN_CALIBRATED_PRIMARY_MIN=0.75
# V3_DOMAIN_MIN_RANGE_FOR_DISCRIMINATION (RAW)
# ├── Role: Minimum range for significant discrimination
# ├── Problem: If all scores are very close (e.g., 0.87, 0.86, 0.85),
# │   stretching + softmax artificially creates a "winner"
# ├── Solution: If range < this threshold, treat domains as "equally relevant"
# ├── Example: range=0.03 → [0.87, 0.86] difference 0.01 < 0.03 → multi-domain
# └── Adjust: ↑ for more multi-domain, ↓ for more discrimination
V3_DOMAIN_MIN_RANGE_FOR_DISCRIMINATION=0.03
# SEMANTIC_DOMAIN_MAX_DOMAINS
# ├── Role: Absolute limit on number of domains
# ├── When: Even if 10 domains pass, keep max 5
# ├── Impact: Safety against token explosion
# └── Adjust: ↓ save tokens, ↑ complex queries
SEMANTIC_DOMAIN_MAX_DOMAINS=3

# ============================================================================
# [3] V3_ROUTING_* - Routing decision (chat vs planner)
# ============================================================================
# These thresholds determine if the query should:
# - Go to CHAT (direct conversational response, ~500 tokens)
# - Go to PLANNER (tool execution, ~3000-6000 tokens)
#
# TOKEN IMPACT: Critical - bad routing wastes 5000+ tokens
# ============================================================================
# V3_ROUTING_HIGH_SEMANTIC_THRESHOLD
# ├── Role: HIGH threshold - above this, clearly planner
# ├── When: Semantic score >= 0.7 → route to planner with confidence
# ├── Example: "find my appointments tomorrow" (score 0.85) → planner direct
# └── Adjust: ↓ if too many valid queries go to chat
V3_ROUTING_HIGH_SEMANTIC_THRESHOLD=0.8 # 0.7
# V3_ROUTING_CHAT_SEMANTIC_THRESHOLD
# ├── Role: LOW threshold - below this, definitely chat
# ├── When: Semantic score < 0.4 → route directly to chat
# ├── Example: "hello" (score 0.2) → chat immediately
# └── Adjust: ↑ if too many simple queries go to planner
V3_ROUTING_CHAT_SEMANTIC_THRESHOLD=0.7 # 0.4
# V3_ROUTING_MIN_CONFIDENCE
# ├── Role: Minimum confidence floor for planner
# ├── When: Between CHAT and HIGH, check intent confidence
# ├── Example: score=0.5, intent_confidence=0.7 → planner (>= 0.6)
# └── Adjust: ↑ to be more strict on ambiguous cases
V3_ROUTING_MIN_CONFIDENCE=0.75 # 0.6
# V3_ROUTING_CHAT_OVERRIDE_THRESHOLD
# ├── Role: Override - if intent="chat" with high confidence, ignore domains
# ├── When: Intent "chat" with confidence >= 0.85 → forced chat
# ├── Example: "how are you?" → chat even if domain score is high
# ├── Impact: Avoids ~9000 tokens wasted on chitchat
# └── Adjust: ↓ if conversations are wrongly routed to planner
V3_ROUTING_CHAT_OVERRIDE_THRESHOLD=0.85 # 0.85

# ============================================================================
# [4] SEMANTIC_TOOL_SELECTOR_* - Tool filtering for planner
# ============================================================================
# After domain selection, these thresholds filter TOOLS sent to the LLM.
# Fewer tools = shorter prompt = fewer tokens + fewer hallucinations.
#
# TOKEN IMPACT: Moderate - each tool = ~50-100 tokens
# V3_TOOL_SOFTMAX_* - Softmax temperature calibration (ACTIVE)
# ============================================================================
# Pipeline: raw scores → min-max stretching → softmax(T) → calibrated selection
# THESE THRESHOLDS ARE USED BY THE CODE (tool_selector.py)
# ============================================================================
# V3_TOOL_SOFTMAX_TEMPERATURE
# └── Softmax temperature (0.1 = strong discrimination)
V3_TOOL_SOFTMAX_TEMPERATURE=0.1
# V3_TOOL_CALIBRATED_PRIMARY_MIN
# └── Minimum calibrated score for primary tool
V3_TOOL_CALIBRATED_PRIMARY_MIN=0.07
# SEMANTIC_TOOL_SELECTOR_MAX_TOOLS
SEMANTIC_TOOL_SELECTOR_MAX_TOOLS=8 #8

# ============================================================================
# [5] CONTEXT_REFERENCE_* - Contextual reference resolution
# ============================================================================
# When the user says "the 2nd", "that one", "this appointment", these thresholds
# determine if the context match is reliable.
# ============================================================================
# CONTEXT_REFERENCE_CONFIDENCE_THRESHOLD
# ├── Role: Minimum confidence to validate a resolution
# ├── When: "the 2nd appointment" → match with event_id if confidence >= 0.7
# ├── Example: "that one" → contact found score 0.8 → OK
# │           "that one" → contact found score 0.5 → ask clarification
# └── Adjust: ↑ avoids bad resolutions (more clarifications)
CONTEXT_REFERENCE_CONFIDENCE_THRESHOLD=0.7 # 0.7
# QUERY_ENGINE_SIMILARITY_THRESHOLD
# ├── Role: Detection of DUPLICATE queries (avoids re-execution)
# ├── When: New query similar >= 0.85 to a previous one → reuse result
# ├── Example: "my appointments tomorrow" then "tomorrow's appointments" → same result
# └── Adjust: ↓ more cache hits, ↑ fewer false positives
QUERY_ENGINE_SIMILARITY_THRESHOLD=0.85 # 0.85

# ============================================================================
# [6] SEMANTIC_VALIDATION_* - Post-execution validation
# ============================================================================
# Verifies that tool results answer the question asked.
# Allows triggering a semantic pivot if results are not relevant.
# ============================================================================
# SEMANTIC_VALIDATION_CONFIDENCE_THRESHOLD
# ├── Role: Minimum confidence to validate results vs question
# ├── When: Post-execution, checks data relevance
# ├── Example: "find doctor appointment" → results contain "doctor" → OK
# │           results without "doctor" → pivot or clarification
# └── Adjust: ↑ stricter on result validation
SEMANTIC_VALIDATION_CONFIDENCE_THRESHOLD=0.70 # 0.8

# ============================================================================
# [7] HITL_* - Human-in-the-Loop Classification & Clarification
# ============================================================================
# These thresholds control when to ask for user confirmation/clarification.
# Goal: Avoid costly errors (deletion, email sending) while minimizing interruptions.
# ============================================================================
# HITL_CLASSIFIER_CONFIDENCE_THRESHOLD
# ├── Role: Minimum confidence to classify a HITL response
# ├── When: User responds "yes" or "no" to a clarification
# ├── Example: "yes I confirm" → confidence 0.95 → classified as approval
# │           "maybe" → confidence 0.4 → new clarification
# └── Adjust: ↑ more re-clarifications, ↓ accepts ambiguous responses
HITL_CLASSIFIER_CONFIDENCE_THRESHOLD=0.7 # 0.7
# HITL_AMBIGUOUS_CONFIDENCE_THRESHOLD
# ├── Role: Threshold below which response is deemed AMBIGUOUS
# ├── When: Classification score < 0.7 → ask for reformulation
# ├── Example: "I don't know" → score 0.3 → "Could you clarify?"
# └── Adjust: ↑ stricter on response clarity
HITL_AMBIGUOUS_CONFIDENCE_THRESHOLD=0.7 # 0.7
# HITL_FUZZY_MATCH_AMBIGUITY_THRESHOLD
# ├── Role: Gap between 2 options to detect ambiguity
# ├── When: |score_option1 - score_option2| < 0.05 → ambiguous
# ├── Example: "Dupont" matches contact_A(0.87) and contact_B(0.85) → ambiguous
# └── Adjust: ↑ tolerates more gap, ↓ more sensitive to conflicts
HITL_FUZZY_MATCH_AMBIGUITY_THRESHOLD=0.05 # 0.05
# HITL_LOW_CONFIDENCE_THRESHOLD
# ├── Role: Below this = inferred rejection (Issue #60 Fix)
# ├── When: Very low score → considered as implicit refusal
# ├── Example: "no thanks" → approval score 0.2 → rejection
# └── Adjust: ↑ more inferred rejections
HITL_LOW_CONFIDENCE_THRESHOLD=0.5 # 0.5

# ============================================================================
# [8] V3_EXECUTOR_* - Execution and error recovery
# ============================================================================
# Controls autonomous executor resilience: retries, circuit breaker.
# Goal: Complete execution even with partial errors.
# ============================================================================
# V3_EXECUTOR_MAX_RECOVERY_PER_STEP
# ├── Role: Recovery attempts PER STEP in the plan
# ├── When: A tool fails → retry up to 3 times before giving up
# ├── Example: search_contacts timeout → retry 1, 2, 3 → step failure
# └── Adjust: ↑ more retries (latency), ↓ fail-fast
V3_EXECUTOR_MAX_RECOVERY_PER_STEP=2 # 3
# V3_EXECUTOR_MAX_TOTAL_RECOVERIES
# ├── Role: TOTAL recovery budget for the entire plan
# ├── When: After 5 cumulative recoveries → plan stops
# ├── Example: step1 retry×2, step2 retry×2, step3 retry×1 → budget exhausted
# └── Adjust: ↑ more error tolerance, ↓ fail-fast
V3_EXECUTOR_MAX_TOTAL_RECOVERIES=6 # 5
# V3_EXECUTOR_RECOVERY_TIMEOUT_MS
# ├── Role: Global timeout for recovery operations
# ├── When: Recovery takes > 30s → abandon
# └── Adjust: ↑ for slow operations (external APIs)
V3_EXECUTOR_RECOVERY_TIMEOUT_MS=15000 # 30000
# V3_EXECUTOR_CIRCUIT_BREAKER_THRESHOLD
# ├── Role: After N consecutive failures, stop attempts
# ├── When: 3 consecutive failures → circuit open → immediate fail
# ├── Impact: Avoids wasting time on a down service
# └── Adjust: ↑ more tolerant, ↓ circuit opens faster
V3_EXECUTOR_CIRCUIT_BREAKER_THRESHOLD=2 # 3

# ============================================================================
# [9] V3_RELEVANCE_* - Result relevance ranking
# ============================================================================
# Scores result relevance relative to the query.
# Used to filter/sort multi-source results.
# ============================================================================
# V3_RELEVANCE_PRIMARY_THRESHOLD
# ├── Role: Minimum score to be "highly relevant"
# ├── When: Results >= 0.7 displayed first
# ├── Example: "doctor appointment" → event with "Dr Martin" score 0.85 → primary
# └── Adjust: ↑ stricter on primary relevance
V3_RELEVANCE_PRIMARY_THRESHOLD=0.7 # 0.7
# V3_RELEVANCE_MINIMUM_THRESHOLD
# ├── Role: Minimum score to be DISPLAYED (below = filtered out)
# ├── When: Results < 0.3 excluded from response
# ├── Example: "doctor appointment" → "yoga" event score 0.15 → excluded
# └── Adjust: ↓ more results (noise), ↑ more relevant results
V3_RELEVANCE_MINIMUM_THRESHOLD=0.3 # 0.3

# ============================================================================
# [10] MEMORY_* - Long-term memory thresholds
# ============================================================================
# Controls memory retrieval and maintenance.
# ============================================================================
# MEMORY_MIN_SEARCH_SCORE
# ├── Role: Minimum semantic score to retrieve a memory
# ├── When: Memory injection into system prompt
# ├── Example: "my brother" → search memories >= 0.8 similar
# └── Adjust: ↓ more memories (noise), ↑ more precise memories
MEMORY_MIN_SEARCH_SCORE=0.87 # 0.7
# MEMORY_RELEVANCE_THRESHOLD
# ├── Role: Minimum score to consider memory "relevant"
# ├── When: Decision to retain a memory
# └── Adjust: ↑ stricter on what is kept
MEMORY_RELEVANCE_THRESHOLD=0.8 # 0.8

# ============================================================================
# [10b] MEMORY_HYBRID_* - Hybrid Search (BM25 + Semantic)
# ============================================================================
# Combines keyword-based BM25 scoring with semantic embeddings for better recall.
# Formula: final_score = alpha x semantic + (1-alpha) x bm25
# Boost: If both scores > threshold, apply 10% boost.
# MEMORY_HYBRID_ENABLED
# ├── Role: Enables/disables hybrid search
# ├── When: false = semantic-only (legacy behavior)
# └── Adjust: Disable if performance issues
MEMORY_HYBRID_ENABLED=false
# MEMORY_HYBRID_ALPHA
# ├── Role: Semantic score weight (1-alpha = BM25 weight)
# ├── When: 0.6 = 60% semantic, 40% BM25
# └── Adjust: ↑ favors semantic, ↓ favors exact keywords
MEMORY_HYBRID_ALPHA=0.6
# MEMORY_HYBRID_MIN_SCORE
# ├── Role: Minimum hybrid score to include a result
# └── Adjust: ↑ fewer but more relevant results
MEMORY_HYBRID_MIN_SCORE=0.5
# MEMORY_HYBRID_BOOST_THRESHOLD
# ├── Role: Threshold for bonus when both scores are high
# ├── When: If semantic > 0.5 AND bm25 > 0.5 → +10% final score
# └── Adjust: ↑ rarer bonus, ↓ more frequent bonus
MEMORY_HYBRID_BOOST_THRESHOLD=0.5
# MEMORY_BM25_CACHE_MAX_USERS
# ├── Role: BM25 local cache limit (LRU eviction)
# └── Adjust: ↑ more memory, ↓ fewer cache hits
MEMORY_BM25_CACHE_MAX_USERS=100

# ============================================================================
# [11] TOKEN_THRESHOLD_* - Token overflow management
# ============================================================================
# Progressive thresholds for catalogue reduction when prompt is too long.
# Goal: Maintain quality while respecting model limits.
# ============================================================================
# TOKEN_THRESHOLD_SAFE
# ├── Role: Below = FULL catalogue, optimal quality
# ├── When: < 80k tokens → all tools, all domains
# └── gpt-4.1-mini supports 128k, comfortable margin
TOKEN_THRESHOLD_SAFE=20000 # 80000
# TOKEN_THRESHOLD_WARNING
# ├── Role: Above = "essential" reduction activated
# ├── When: 80k-100k tokens → "essential" strategy on catalogue
# ├── Impact: Tool descriptions shortened
# └── Adjust: ↑ if quality acceptable with less reduction
TOKEN_THRESHOLD_WARNING=30000 # 100000
# TOKEN_THRESHOLD_CRITICAL
# ├── Role: Above = "minimal" reduction activated
# ├── When: 100k-110k tokens → primary domain only
# ├── Impact: Significant, possible context gaps
# └── Adjust: ↓ to preserve quality sooner
TOKEN_THRESHOLD_CRITICAL=40000 # 110000
# TOKEN_THRESHOLD_MAX
# ├── Role: Above = emergency mode, truncation risk
# ├── When: > 120k tokens → aggressive fallback
# ├── Impact: Possible functionality loss
# └── Adjust: Do not increase beyond 128k (model limit)
TOKEN_THRESHOLD_MAX=50000 # 120000

# ============================================================================
# [12] EVALUATOR_LATENCY_* - Latency scores (Langfuse evaluators)
# ============================================================================
# Define SLA thresholds for scoring response time.
# Used by Langfuse evaluators for quality metrics.
# ============================================================================
# EVALUATOR_LATENCY_EXCELLENT_THRESHOLD_MS
# ├── Role: Below = "excellent" score
# ├── When: Response < 500ms → best score
# └── Adjust: ↓ stricter SLA
EVALUATOR_LATENCY_EXCELLENT_THRESHOLD_MS=500.0
# EVALUATOR_LATENCY_GOOD_THRESHOLD_MS
# ├── Role: Below = "good" score
# ├── When: 500ms-1000ms → good score
EVALUATOR_LATENCY_GOOD_THRESHOLD_MS=1000.0
# EVALUATOR_LATENCY_ACCEPTABLE_THRESHOLD_MS
# ├── Role: Below = "acceptable" score
# ├── When: 1000ms-2000ms → average score
EVALUATOR_LATENCY_ACCEPTABLE_THRESHOLD_MS=2000.0
# EVALUATOR_LATENCY_SLOW_THRESHOLD_MS
# ├── Role: Above = "slow" score
# ├── When: > 5000ms → low score
EVALUATOR_LATENCY_SLOW_THRESHOLD_MS=5000.0

# ============================================================================
# [13] CIRCUIT_BREAKER_* - External service resilience
# ============================================================================
# Protects against failure cascades when a service is down.
# Pattern: closed → open (after N failures) → half-open → closed/open
# ============================================================================
# CIRCUIT_BREAKER_FAILURE_THRESHOLD
# ├── Role: Consecutive failures before circuit opens
# ├── When: 5 consecutive failures → circuit opens
# ├── Impact: Fail-fast during TIMEOUT_SECONDS
# └── Adjust: ↓ opens faster (protection), ↑ more tolerant
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3 # 5
# CIRCUIT_BREAKER_SUCCESS_THRESHOLD
# ├── Role: Successes needed to close the circuit
# ├── When: In half-open, 3 successes → circuit closes
# └── Adjust: ↑ more cautious before reopening
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3 # 3
# CIRCUIT_BREAKER_TIMEOUT_SECONDS
# ├── Role: Duration before recovery attempt (half-open)
# ├── When: Circuit open → wait 60s → try half-open
# └── Adjust: ↑ gives service more time to recover
CIRCUIT_BREAKER_TIMEOUT_SECONDS=10 # 60
# CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS
# ├── Role: Calls allowed in half-open to test
# ├── When: Tests if service has recovered
# └── Adjust: ↑ tests more before deciding
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3 # 3

# ============================================================================
# [14] V3_FEEDBACK_LOOP_* - Error pattern learning
# ============================================================================
# Collects recovery patterns for preemptive suggestions.
# Improves recovery strategies over time.
# ============================================================================
# V3_FEEDBACK_LOOP_MAX_RECORDS
# ├── Role: Maximum pattern records kept
# ├── When: After 1000 records → FIFO purge
# └── Adjust: ↑ more history (memory), ↓ less storage
V3_FEEDBACK_LOOP_MAX_RECORDS=1000
# V3_FEEDBACK_LOOP_MIN_SAMPLES
# ├── Role: Minimum samples before suggesting a strategy
# ├── When: Pattern seen < 3 times → no suggestion
# └── Adjust: ↑ more cautious, ↓ earlier suggestions
V3_FEEDBACK_LOOP_MIN_SAMPLES=3
# V3_FEEDBACK_LOOP_CONFIDENCE_THRESHOLD
# ├── Role: Minimum confidence to suggest a strategy
# ├── When: Pattern with success < 60% → no suggestion
# └── Adjust: ↑ only suggests proven strategies
V3_FEEDBACK_LOOP_CONFIDENCE_THRESHOLD=0.6

# ============================================================================
# HITL Clarification
# ============================================================================
# Minimum chars remaining after pattern removal to consider content sufficient
# Higher = more likely to ask clarification, Lower = more tolerant
INSUFFICIENT_CONTENT_MIN_CHARS_THRESHOLD=30

# ========================================================================================================================================================
# VOICE / TEXT-TO-SPEECH CONFIGURATION
# ========================================================================================================================================================
# Default mode when no admin setting exists in database
# standard = Edge TTS (free, high quality), hd = OpenAI/Gemini TTS (paid, premium)
VOICE_TTS_DEFAULT_MODE=standard

# -----------------------------------------------------------------------
# STANDARD VOICE - Edge TTS Specific Configuration
# -----------------------------------------------------------------------
VOICE_TTS_STANDARD_PROVIDER=edge
VOICE_TTS_STANDARD_RATE=+10%
VOICE_TTS_STANDARD_PITCH=+0Hz
VOICE_TTS_STANDARD_VOLUME=+0%
VOICE_TTS_STANDARD_VOICE_MALE=fr-FR-RemyMultilingualNeural
VOICE_TTS_STANDARD_VOICE_FEMALE=fr-FR-VivienneMultilingualNeural

# -----------------------------------------------------------------------
# HD VOICE - Premium TTS Configuration
# -----------------------------------------------------------------------
VOICE_TTS_HD_PROVIDER=openai
VOICE_TTS_HD_PROVIDER_CONFIG={}
VOICE_TTS_HD_VOICE_MALE=echo
VOICE_TTS_HD_VOICE_FEMALE=coral
VOICE_TTS_HD_MODEL=tts-1-1106
VOICE_TTS_HD_SPEED=1.1
VOICE_TTS_HD_RESPONSE_FORMAT=mp3
# Maximum sentences in voice comment
VOICE_MAX_SENTENCES=3
# Characters that mark end of sentence (for TTS chunking)
VOICE_SENTENCE_DELIMITERS=.!?
# Maximum characters for voice context (truncation limit for chat fallback)
VOICE_CONTEXT_MAX_CHARS=2000
# Timeout for parallel voice generation task (seconds)
# Voice LLM (~2s) + 3 TTS sentences (~4s) = ~6s minimum. Set to 15s for network variability.
VOICE_PARALLEL_TIMEOUT_SECONDS=15.0
# Max sentences to TTS in chat mode (chat responses don't need full commentary)
VOICE_CHAT_MODE_MAX_SENTENCES=3

# -----------------------------------------------------------------------
# VOICE STT - Speech-to-Text (Sherpa-onnx Whisper - Offline, multi-language)
# -----------------------------------------------------------------------
# Uses Whisper Small INT8 model supporting: 99+ languages (FR/EN/DE/ES/IT/ZH/...)
# 100% offline - no API costs, runs on CPU (AMD64 dev, ARM64 Pi prod)
# Model: csukuangfj/sherpa-onnx-whisper-small (~375 MB INT8)
# Enable/disable STT feature
VOICE_STT_ENABLED=true
# Path to Sherpa-onnx Whisper model directory
# Must contain: encoder.onnx, decoder.onnx, tokens.txt
# Download: ./scripts/download-whisper-model.sh
VOICE_STT_MODEL_PATH=/models/whisper-small
# CPU threads for STT processing (adjust based on hardware)
# Development (AMD64): 4 threads
# Production (Raspberry Pi 4): 2-4 threads
VOICE_STT_NUM_THREADS=4
# Language hint for Whisper transcription (ISO 639-1 code)
# Empty = auto-detect. Examples: 'fr', 'en', 'de', 'es', 'it', 'zh'
VOICE_STT_LANGUAGE=
# Whisper task: 'transcribe' (same language) or 'translate' (to English)
VOICE_STT_TASK=transcribe
# Maximum audio duration allowed (seconds)
# Longer audio = more memory, protect against abuse
VOICE_STT_MAX_DURATION_SECONDS=60

# -----------------------------------------------------------------------
# VOICE WEBSOCKET - Audio streaming configuration
# -----------------------------------------------------------------------
# WebSocket /ws/audio endpoint for real-time audio transcription
# BFF pattern: ticket-based auth (session cookie → short-lived ticket)
# WebSocket authentication ticket TTL (seconds)
# Short-lived for security, single-use
VOICE_WS_TICKET_TTL_SECONDS=60
# Rate limiting for WebSocket connections (per user)
# Protects against connection spam
VOICE_WS_RATE_LIMIT_MAX_CALLS=10
VOICE_WS_RATE_LIMIT_WINDOW_SECONDS=60
# Idle timeout before closing inactive WebSocket (seconds)
VOICE_WS_IDLE_TIMEOUT_SECONDS=120

# ========================================================================================================================================================
# LONG-TERM MEMORY (LangMem - Psychological Profiling)
# ========================================================================================================================================================
# Model: intfloat/multilingual-e5-small (100 languages, 384 dims, ~470MB)
MEMORY_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# Embedding dimensions (must match model)
# E5-small: 384, E5-base: 768, OpenAI small: 1536
MEMORY_EMBEDDING_DIMENSIONS=384
# Maximum memories to retrieve per query
MEMORY_MAX_RESULTS=50
# NOTE: MEMORY_MIN_SEARCH_SCORE moved to SCORING THRESHOLDS section (line ~733)
# Additional Memory Extraction Settings
MEMORY_EXTRACTION_MESSAGE_MAX_CHARS=3000

# ============================================================================
# MEMORY REFERENCE RESOLUTION (Pre-Planner Entity Resolution)
# ============================================================================
# Resolves relational references ("my brother") to entity names ("jean")
MEMORY_REFERENCE_RESOLUTION_TIMEOUT_MS=5000

# ============================================================================
# MEMORY PURGE CONFIGURATION (Phase 6)
# ============================================================================
# NOTE: MEMORY thresholds moved to SCORING THRESHOLDS section (line ~722)
# Only scheduling config remains here.
MEMORY_CLEANUP_HOUR=4
MEMORY_CLEANUP_MINUTE=0
MEMORY_MAX_AGE_DAYS=2
MEMORY_MIN_USAGE_COUNT=1
MEMORY_RETENTION_WEIGHT_USAGE=0.4
MEMORY_RETENTION_WEIGHT_IMPORTANCE=0.3
MEMORY_RETENTION_WEIGHT_RECENCY=0.3
# MEMORY_PURGE_THRESHOLD
# retention_score = MEMORY_RETENTION_WEIGHT_USAGE x usage_boost + MEMORY_RETENTION_WEIGHT_IMPORTANCE x importance_boost + MEMORY_RETENTION_WEIGHT_RECENCY x recency_boost
# where:
#   usage_boost   = min(1.0, usage_count / MEMORY_MIN_USAGE_COUNT)
#   importance    = importance (0.0-1.0)
#   recency_boost = max(0.0, 1.0 - age_days / MEMORY_MAX_AGE_DAYS)
MEMORY_PURGE_THRESHOLD=0.5

# ============================================================================
# INTEREST LEARNING SYSTEM (Proactive User Interest Tracking)
# ============================================================================
# Learns user interests from conversations and sends proactive notifications
# with relevant content from Wikipedia, Perplexity, or LLM reflections.
#
# Two LLM configurations:
# 1. EXTRACTION: Fire-and-forget analysis after each response (fast model)
# 2. CONTENT: Generates engaging notification content (quality model)
#
# Feature follows pattern of memory_extractor.py (background LLM analysis).

# --- Feature Toggles ---
# Enable interest extraction from conversations (fire-and-forget LLM analysis)
INTEREST_EXTRACTION_ENABLED=true
# Enable proactive interest notification scheduler (runs every 15 minutes)
INTEREST_NOTIFICATIONS_ENABLED=true
INTEREST_NOTIFY_START_HOUR=9
INTEREST_NOTIFY_END_HOUR=22
PROACTIVE_FEEDBACK_ENABLED=true
PROACTIVE_NOTIFICATION_MAX_LENGTH=150
# --- Proactive Message Injection (LangGraph State) ---
# Max proactive messages to inject into LangGraph state per turn (1-20)
# When user replies to a proactive notification, these are injected as context
PROACTIVE_INJECT_MAX_MESSAGES=5
# Lookback window (hours) when no checkpoint exists / new conversation (1-168)
PROACTIVE_INJECT_LOOKBACK_HOURS=24
INTEREST_WIKIPEDIA_SEARCH_LIMIT=3
INTEREST_PERPLEXITY_RECENCY_FILTER=week
INTEREST_PERPLEXITY_RETURN_RELATED_QUESTIONS=false
INTEREST_NOTIFICATION_INTERVAL_MINUTES=5
INTEREST_NOTIFICATION_BATCH_SIZE=50
INTEREST_TOP_PERCENT=1.0
INTEREST_GLOBAL_COOLDOWN_HOURS=1
INTEREST_PER_TOPIC_COOLDOWN_HOURS=12
INTEREST_ACTIVITY_COOLDOWN_MINUTES=5
# Beta(alpha, beta) prior: initial confidence = alpha/(alpha+beta)
INTEREST_PRIOR_ALPHA=2
INTEREST_PRIOR_BETA=1
INTEREST_DECAY_RATE_PER_DAY=0.005
INTEREST_DORMANT_THRESHOLD_DAYS=15
INTEREST_DELETION_THRESHOLD_DAYS=30
INTEREST_DEDUP_SIMILARITY_THRESHOLD=0.9
INTEREST_CONTENT_SIMILARITY_THRESHOLD=0.92
INTEREST_DEDUP_SEARCH_LIMIT=20
INTEREST_CONTENT_MAX_LENGTH=500
INTEREST_CONTENT_LOOKBACK_DAYS=7
INTEREST_EXTRACTION_QUERY_TRUNCATION_LENGTH=500
INTEREST_USER_LIST_LIMIT=200
INTEREST_ACTIVE_LIST_LIMIT=50
# HITL Semantic Validation
SEMANTIC_VALIDATION_TIMEOUT_SECONDS=20.0

# ============================================================================
# Plan Pattern Learning (dynamic learning from successes/failures)
# ============================================================================
# When enabled: records outcomes to Redis, injects patterns in prompts, bypasses validation for high-confidence patterns
PLAN_PATTERN_TRAINING_ENABLED=false
# Bayesian prior: Beta(alpha, beta) - initial confidence = alpha/(alpha+beta) - Default Beta(2,1) = 67% initial confidence, allows rapid learning
PLAN_PATTERN_PRIOR_ALPHA=2
PLAN_PATTERN_PRIOR_BETA=1
# Decision thresholds for pattern suggestions - Min observations to suggest pattern (K-anonymity)
PLAN_PATTERN_MIN_OBS_SUGGEST=3
# Min confidence (75%) to suggest
PLAN_PATTERN_MIN_CONF_SUGGEST=0.75
# Min observations to bypass validation
PLAN_PATTERN_MIN_OBS_BYPASS=10
# Min confidence (90%) to bypass
PLAN_PATTERN_MIN_CONF_BYPASS=0.90
# Max patterns injected in prompt (token budget)
PLAN_PATTERN_MAX_SUGGESTIONS=3
# Timeout for Redis lookup (strict, fail-open) - 50ms for Docker network latency
PLAN_PATTERN_SUGGESTION_TIMEOUT_MS=100
# Local cache TTL to reduce Redis calls
PLAN_PATTERN_LOCAL_CACHE_TTL_S=1.0
# Redis storage
PLAN_PATTERN_REDIS_PREFIX=plan:patterns
# Pattern expiration (30 days of inactivity)
PLAN_PATTERN_REDIS_TTL_DAYS=30

# ============================================================================
# SEMANTIC LINKING - Cross-domain parameter linking
# ============================================================================
# Enable semantic linking for automatic parameter source suggestions
SEMANTIC_LINKING_ENABLED=true
# Semantic expansion toggle (0.0-1.0): < 1.0 enables expansion, = 1.0 disables it
SEMANTIC_EXPANSION_THRESHOLD=0.7
# Maximum suggestions per parameter in planner context
SEMANTIC_LINKING_MAX_SUGGESTIONS=5

# ============================================================================
# TEXT COMPACTION - Token Optimization for Embedded Data
# ============================================================================
# Post-Jinja evaluation compaction of embedded data structures in text parameters.
# When planner uses $steps.X.places in content_instruction, Jinja evaluates to
# full Python repr (~2000 tokens/place). Text compaction detects and compacts
# these to ~60 tokens/place using payload_to_text().
TEXT_COMPACTION_ENABLED=true
# Minimum size (characters) for a data structure to be compacted
TEXT_COMPACTION_MIN_SIZE=200
# Maximum items to show per list in compacted format
TEXT_COMPACTION_MAX_ITEMS=5
# Maximum length for field values in compacted format
TEXT_COMPACTION_MAX_FIELD_LENGTH=40
# Planner Execution Limits (Security & Cost Control)
# Maximum steps allowed in a generated plan (default: 10, hard limit: 25)
PLANNER_MAX_STEPS=20
# Maximum budget per plan in USD (prevents runaway costs)
PLANNER_MAX_COST_USD=2.0
# Maximum replanning attempts for adaptive planning
PLANNER_MAX_REPLANS=2
# Timeout for planner LLM response in seconds
PLANNER_TIMEOUT_SECONDS=30
# Default max items for for_each iteration pattern (default: 10, hard limit: 100)
FOR_EACH_MAX_DEFAULT=10
# Absolute maximum for for_each_max (schema validation limit)
FOR_EACH_MAX_HARD_LIMIT=100
# Minimum items to trigger HITL for mutations (1=always ask, 3=only 3+ items)
FOR_EACH_MUTATION_THRESHOLD=1
# Threshold for non-mutation for_each to require HITL approval (5+ iterations)
FOR_EACH_APPROVAL_THRESHOLD=5
# Warning level threshold for non-mutation for_each (10+ iterations)
FOR_EACH_WARNING_THRESHOLD=10

# ============================================================================
# LLM ORCHESTRATOR/EXECUTOR
# ============================================================================
# NOTE: V3_EXECUTOR_* thresholds moved to SCORING THRESHOLDS section (line ~667)
# NOTE: TOKEN_THRESHOLD_* moved to SCORING THRESHOLDS section (line ~766)
# Tool Approval Cleanup
TOOL_APPROVAL_CLEANUP_DAYS=1
# Default max results for contact search operations
CONTACTS_TOOL_DEFAULT_MAX_RESULTS=10
# Default limit for contact list operations
CONTACTS_TOOL_DEFAULT_LIMIT=10
# Google API Cache TTL (in seconds)
# Contacts API cache durations (NEW PATTERN - active in code)
CONTACTS_CACHE_LIST_TTL_SECONDS=300
CONTACTS_CACHE_SEARCH_TTL_SECONDS=180
CONTACTS_CACHE_DETAILS_TTL_SECONDS=600
# Default search window in days (prevents token explosion from retrieving years of emails)
GMAIL_DEFAULT_SEARCH_DAYS=90
# Contacts Tool Default Settings
# Default max results for contact search operations
EMAILS_TOOL_DEFAULT_MAX_RESULTS=10
# Default limit for contact list operations
EMAILS_TOOL_DEFAULT_LIMIT=10
# Formatting Display Limits
FORMAT_TRUNCATE_SUBJECT_LENGTH=70
# Maximum email body length before truncation with "read more" link
EMAILS_BODY_MAX_LENGTH=500
# URLs longer than this threshold are converted to [link](url) format
EMAILS_URL_SHORTEN_THRESHOLD=20
# Google API Cache TTL (in seconds)
# Emails API cache durations (NEW PATTERN - active in code)
EMAILS_CACHE_LIST_TTL_SECONDS=60
EMAILS_CACHE_SEARCH_TTL_SECONDS=60
EMAILS_CACHE_DETAILS_TTL_SECONDS=300
# Calendar Tool Default Settings
CALENDAR_TOOL_DEFAULT_MAX_RESULTS=10
# Google API Cache TTL (in seconds)
CALENDAR_CACHE_LIST_TTL_SECONDS=60       # 1 minute - calendar event lists (volatile)
CALENDAR_CACHE_SEARCH_TTL_SECONDS=60     # 1 minute - search results (volatile)
CALENDAR_CACHE_DETAILS_TTL_SECONDS=120   # 2 minutes - event details (moderately stable)
# Drive Tool Default Settings
DRIVE_TOOL_DEFAULT_MAX_RESULTS=10
# Drive API Cache TTL (in seconds) - granular per operation type
DRIVE_CACHE_LIST_TTL_SECONDS=60           # 1 minute - file lists (volatile)
DRIVE_CACHE_SEARCH_TTL_SECONDS=60         # 1 minute - search results (volatile)
DRIVE_CACHE_DETAILS_TTL_SECONDS=300       # 5 minutes - file metadata (stable)
# Tasks Tool Default Settings
TASKS_TOOL_DEFAULT_MAX_RESULTS=10
# Google Drive API Cache TTL (in seconds)
TASKS_CACHE_LIST_TTL_SECONDS=60          # 1 minute - task lists (volatile)
TASKS_CACHE_DETAILS_TTL_SECONDS=120
# OpenWeatherMap API Cache TTL (in seconds)
WEATHER_CACHE_CURRENT_TTL_SECONDS=600    # 10 minutes - current weather (updates frequently)
WEATHER_CACHE_FORECAST_TTL_SECONDS=1800  # 30 minutes - forecast data (more stable)
WEATHER_FORECAST_MAX_DAYS=5
# Wikipedia Display Settings
WIKIPEDIA_SUMMARY_MAX_CHARS=5000
# Wikipedia API Cache TTL (in seconds)
WIKIPEDIA_CACHE_SEARCH_TTL_SECONDS=3600  # 1 hour - search results (static encyclopedic content)
WIKIPEDIA_CACHE_ARTICLE_TTL_SECONDS=86400 # 24 hours - article content (very stable)

# Web Search/Fetch Tool Cache (unified_web_search_tool + fetch_web_page_tool)
WEB_SEARCH_CACHE_ENABLED=true              # Enable Redis TTL caching for web tools
WEB_SEARCH_CACHE_TTL_SECONDS=300           # 5 minutes - unified search results (Perplexity+Brave+Wikipedia)
WEB_FETCH_CACHE_TTL_SECONDS=600            # 10 minutes - extracted page content (stable)
WEB_SEARCH_CACHE_PREFIX=web_search         # Redis key prefix for search cache
WEB_FETCH_CACHE_PREFIX=web_fetch           # Redis key prefix for fetch cache

# --- External Content Wrapping (prompt injection prevention) ---
EXTERNAL_CONTENT_WRAPPING_ENABLED=true    # Wrap untrusted web content in safety markers

# --- Context Compaction (F4 — Intelligent History Summarization) ---
# Summarizes old conversation history via LLM when token count exceeds threshold.
# Preserves recent messages and critical identifiers (UUIDs, URLs, emails).
COMPACTION_ENABLED=true
# Ratio of response LLM context window to trigger compaction (0 = use absolute threshold)
COMPACTION_THRESHOLD_RATIO=0.4
# Absolute token threshold override (0 = use dynamic ratio above)
COMPACTION_TOKEN_THRESHOLD=0
# Number of recent messages always preserved (never compacted)
COMPACTION_PRESERVE_RECENT_MESSAGES=10
# Max tokens per chunk sent to compaction LLM
COMPACTION_CHUNK_MAX_TOKENS=20000
# Minimum messages before considering compaction (fast-path skip)
COMPACTION_MIN_MESSAGES=20

# sonar = basic search, sonar-pro = advanced search, sonar-reasoning = reasoning-enhanced
PERPLEXITY_SEARCH_MODEL=sonar
# Places Tool Default Settings
PLACES_TOOL_DEFAULT_MAX_RESULTS=10
PLACES_TOOL_DEFAULT_RADIUS_METERS=500
# Place photo carousel (multiple photos per place with navigation arrows)
# When false: 1 photo per place = accurate Google API billing (each photo = 1 API call @ $7/1000)
# When true: up to 5 photos per place BUT carousel photos are NOT tracked for billing
# WARNING: If enabled, users viewing additional photos will incur unbilled API costs
PLACE_CAROUSEL_ENABLED=false
# Routes Tool Limits
ROUTES_MAX_WAYPOINTS=25                    # Google Routes API waypoint limit
ROUTES_MAX_MATRIX_ELEMENTS=625             # Maximum matrix elements (25x25)
ROUTES_WALK_THRESHOLD_KM=1.0               # Distance below which WALK mode is default
ROUTES_HITL_DISTANCE_THRESHOLD_KM=20.0     # Distance above which HITL confirmation triggered
ROUTES_MAX_STEPS=10                        # Max steps in condensed route response (1-50)
# Routes API Configuration
ROUTES_CACHE_TRAFFIC_TTL_SECONDS=300       # 5 minutes - routes with traffic (volatile)
ROUTES_CACHE_STATIC_TTL_SECONDS=1800       # 30 minutes - routes without traffic (stable)
ROUTES_CACHE_MATRIX_TTL_SECONDS=600        # 10 minutes - route matrix (moderately stable)
# HTTP Timeouts for Google APIs (in seconds)
HTTP_TIMEOUT_ROUTES_API=30.0               # Google Routes API (complex route calculations)
HTTP_TIMEOUT_PLACES_API=10.0               # Google Places API (destination resolution)
HTTP_TIMEOUT_GEOCODING_API=5.0             # Google Geocoding API (reverse geocoding)

# ============================================================================
# RATE LIMITING
# ============================================================================
# Global Rate Limiting Control
RATE_LIMIT_ENABLED=true
# HTTP Rate Limiting (SlowAPI - FastAPI Endpoints)
RATE_LIMIT_PER_MINUTE=60
# Burst allowance for rate limiting
RATE_LIMIT_BURST=10
# Note: Specific endpoints have different limits (defined in code): "user" (per-user isolation, recommended) or "global" (shared across all users)
RATE_LIMIT_SCOPE=user
# Tool Rate Limits (applies to ALL tools: Contacts, Gmail, Calendar, Tasks, etc.)
RATE_LIMIT_DEFAULT_READ_CALLS=20
RATE_LIMIT_DEFAULT_READ_WINDOW=60
# Write operations (create, update, delete, send) - Lower limit (security)
RATE_LIMIT_DEFAULT_WRITE_CALLS=20
RATE_LIMIT_DEFAULT_WRITE_WINDOW=60
# Expensive operations (export, bulk) - Very low limit (cost protection)
RATE_LIMIT_DEFAULT_EXPENSIVE_CALLS=20
RATE_LIMIT_DEFAULT_EXPENSIVE_WINDOW=300
# API Client Rate Limits (Redis-based, per-second)
CLIENT_RATE_LIMIT_GOOGLE_PER_SECOND=10        # Google APIs (Contacts, Gmail, Calendar, Drive, Places)
CLIENT_RATE_LIMIT_PERPLEXITY_PER_SECOND=2.0   # Perplexity API (paid tier allows more)
CLIENT_RATE_LIMIT_OPENWEATHERMAP_PER_SECOND=1 # OpenWeatherMap (free tier: 60/min = 1/sec)
CLIENT_RATE_LIMIT_WIKIPEDIA_PER_SECOND=0.5    # Wikipedia API (conservative, per etiquette)

# ============================================================================
# HTTP CLIENT CONFIGURATION
# ============================================================================
# Timeout values for external HTTP requests (in seconds)
HTTP_TIMEOUT_OAUTH=10.0
HTTP_TIMEOUT_TOKEN=5.0
HTTP_TIMEOUT_EXTERNAL_API=5.0
HTTP_TIMEOUT_CURRENCY_API=5.0

# ============================================================================
# SSE CONFIGURATION
# ============================================================================
# SSE Configuration: Heartbeat interval prevents connection timeout from proxies/load balancers
SSE_HEARTBEAT_INTERVAL=15

# ============================================================================
# LANGFUSE EVALUATORS - Evaluation Scores (Phase 3.1.3)
# ============================================================================
EVALUATOR_HALLUCINATION_REQUIRE_GROUND_TRUTH=false
# Evaluation Pipeline Configuration
# Auto-send evaluation scores to Langfuse (true/false)
# If true, scores are sent automatically after each evaluation
# If false, scores are calculated but not sent (useful for testing)
EVALUATOR_PIPELINE_SEND_TO_LANGFUSE=false

# ============================================================================
# OBSERVABILITY - LANGCHAIN SDK
# ============================================================================
# LangChain Callbacks Execution Mode
LANGCHAIN_CALLBACKS_BACKGROUND=false

# ============================================================================
# INTERNATIONALIZATION
# ============================================================================
# Internationalization Configuration
DEFAULT_LANGUAGE=fr
# Supported Languages
SUPPORTED_LANGUAGES=fr,en,es,de,it,zh-CN

# ============================================================================
# TOKEN ENCODING CONFIGURATION
# ============================================================================
# Token Encoding for tiktoken (used for accurate token counting and cost estimation)
# o200k_base: For gpt-4.1, gpt-4.1-mini, gpt-4.1-nano and other OpenAI o-series models
# cl100k_base: For older GPT-4 and GPT-3.5-turbo models
TOKEN_ENCODING_NAME=o200k_base

# ============================================================================
# LANGCHAIN MIDDLEWARE CONFIGURATION
# ============================================================================
# LangChain Agent Middleware for context management, retries, and resilience.
# SummarizationMiddleware - Context Compression
SUMMARIZATION_MODEL=gpt-4.1-nano
SUMMARIZATION_TRIGGER_FRACTION=0.7
SUMMARIZATION_KEEP_MESSAGES=10
# ModelRetryMiddleware - Automatic LLM Retry
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2.0
# ModelFallbackMiddleware - Multi-Provider Resilience
ENABLE_FALLBACK_MIDDLEWARE=false
FALLBACK_MODELS=claude-sonnet-4-5,deepseek-chat
# ToolRetryMiddleware - Tool Execution Resilience
TOOL_RETRY_MAX_ATTEMPTS=3
TOOL_RETRY_BACKOFF_FACTOR=1.5
# ModelCallLimitMiddleware - Cost & Loop Protection
MODEL_CALL_THREAD_LIMIT=100
MODEL_CALL_RUN_LIMIT=20
# ContextEditingMiddleware - Tool Result Pruning
CONTEXT_EDIT_MAX_TOOL_RESULT_TOKENS=5000

# ============================================================================
# OAUTH PROACTIVE TOKEN REFRESH (Background Job)
# ============================================================================
# Proactively refreshes OAuth tokens BEFORE they expire to prevent disconnections
# when users return after periods of inactivity.
# OAUTH_PROACTIVE_REFRESH_INTERVAL_MINUTES
# - How often the job runs to check for expiring tokens
# - Default: 15 (every 15 minutes)
# - Range: 5-60 minutes
OAUTH_PROACTIVE_REFRESH_INTERVAL_MINUTES=15
# OAUTH_PROACTIVE_REFRESH_MARGIN_SECONDS
# - Refresh tokens expiring within this window
# - Default: 1800 (30 minutes)
# - Range: 300-7200 seconds (5 min to 2 hours)
# - Should be > interval to ensure no tokens slip through
OAUTH_PROACTIVE_REFRESH_MARGIN_SECONDS=1800

# ============================================================================
# OAUTH HEALTH CHECK (Proactive Token Expiration Notifications)
# ============================================================================
# Monitors OAuth tokens and notifies users BEFORE expiration to prevent
# mid-conversation disruptions. Shows toast for warnings, modal for critical.
# OAUTH_HEALTH_CHECK_ENABLED
# - Enable proactive OAuth health checks and notifications
# - Default: true
OAUTH_HEALTH_CHECK_ENABLED=true
# OAUTH_HEALTH_CHECK_INTERVAL_MINUTES
# - How often to check OAuth token health
# - Default: 5 (every 5 minutes)
# - Range: 1-60 minutes
OAUTH_HEALTH_CHECK_INTERVAL_MINUTES=1
# OAUTH_HEALTH_CRITICAL_COOLDOWN_HOURS
# - Cooldown before re-notifying for expired/error token
# - Default: 24 hours
# - Range: 1-72 hours
OAUTH_HEALTH_CRITICAL_COOLDOWN_HOURS=12
# SSE_CONNECTION_TTL_SECONDS
# - TTL for SSE connection tracking in Redis
# - Used to detect if user is connected for push vs SSE deduplication
# - Default: 120 (2 minutes, refreshed on each keepalive)
# - Range: 30-300 seconds
SSE_CONNECTION_TTL_SECONDS=120

# ============================================================================
# MCP (Model Context Protocol) — External Tool Servers (evolution F2)
# ============================================================================
# MCP allows connecting external tool servers (Stdio or HTTP transport).
# Tools are discovered at startup and registered in the existing catalogue.
# Reference: docs/technical/MCP_INTEGRATION.md
MCP_ENABLED=true
# JSON config for MCP servers
# Format: {"name": {"transport": "stdio"|"streamable_http", "command": "...", "args": [...], "url": "...", "env": {...}, "timeout_seconds": 30, "enabled": true, "hitl_required": null, "description": "...", "internal": false}}
# - description: Domain description for query routing (helps LLM select the right server)
# - internal: Set true for Docker-internal services (skips SSRF validation for HTTP + private IPs)
# MCP_SERVERS_CONFIG={"filesystem":{"transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}
# Example with Docker-internal Google Flights server:
# MCP_SERVERS_CONFIG={"google_flights":{"transport":"streamable_http","url":"http://google-flights:8000/mcp","internal":true,"description":"Search flights, find airports, compare prices and get best flight deals worldwide","timeout_seconds":120,"enabled":true,"hitl_required":false}}
# Excalidraw admin MCP server (interactive diagram creation via MCP Apps)
MCP_SERVERS_CONFIG={"excalidraw":{"transport":"streamable_http","url":"https://mcp.excalidraw.com","timeout_seconds":60,"enabled":true,"hitl_required":false,"description":"Provides interactive hand-drawn diagram creation and sharing using Excalidraw element format. It can render streaming, animated diagrams from element definitions, upload finished diagrams to Excalidraw and return shareable URLs, and save/restore user-edited diagram states. Call the element format reference before first render."}}
# Alternative: path to JSON config file (overrides MCP_SERVERS_CONFIG)
# MCP_SERVERS_CONFIG_PATH=/etc/lia/mcp_servers.json
MCP_TOOL_TIMEOUT_SECONDS=120
MCP_MAX_SERVERS=10
MCP_MAX_TOOLS_PER_SERVER=40
MCP_HITL_REQUIRED=false
MCP_RATE_LIMIT_CALLS=60
MCP_RATE_LIMIT_WINDOW=60
MCP_HEALTH_CHECK_INTERVAL_SECONDS=300
MCP_CONNECTION_RETRY_MAX=3
MCP_MAX_STRUCTURED_ITEMS_PER_CALL=25
# MCP Per-User (evolution F2.1) — User-managed MCP servers
# Each user can declare and manage their own MCP servers via the web UI.
# Only streamable_http transport is allowed for security (no stdio).
MCP_USER_ENABLED=true
MCP_USER_MAX_SERVERS_PER_USER=10
MCP_USER_POOL_TTL_SECONDS=900
MCP_USER_POOL_MAX_TOTAL=50
MCP_USER_POOL_EVICTION_INTERVAL=60
# Base URL for OAuth 2.1 callbacks (required for OAuth-authenticated MCP servers)
MCP_USER_OAUTH_CALLBACK_BASE_URL=https://lia-back.yourdomain.com
MCP_EXCALIDRAW_STEP_TIMEOUT_SECONDS=60

# ============================================================================
# Channels — Multi-Channel Messaging (evolution F3)
# ============================================================================
# Enable multi-channel messaging (Telegram, etc.) for chatting with LIA
# and receiving proactive notifications on external platforms.
# Reference: docs/technical/CHANNELS_INTEGRATION.md
CHANNELS_ENABLED=true
# Telegram Bot Configuration
# Get a bot token from @BotFather on Telegram: https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
# Secret token for webhook signature verification (generate a random string)
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
# Public HTTPS URL for webhook (production). If absent, long polling is used (dev).
TELEGRAM_WEBHOOK_URL=https://lia-back.yourdomain.com/api/v1/channels/telegram/webhook
# Bot @username (displayed in UI for OTP instructions)
TELEGRAM_BOT_USERNAME=@LIABot
TELEGRAM_MESSAGE_MAX_LENGTH=4000
# OTP Linking Flow
CHANNEL_OTP_TTL_SECONDS=300
CHANNEL_OTP_LENGTH=6
CHANNEL_OTP_MAX_ATTEMPTS=5
CHANNEL_OTP_BLOCK_TTL_SECONDS=900
# Rate Limiting
CHANNEL_RATE_LIMIT_PER_USER_PER_MINUTE=10
CHANNEL_RATE_LIMIT_GLOBAL_PER_SECOND=25
# Message Processing
CHANNEL_MESSAGE_LOCK_TTL_SECONDS=120

# ============================================================================
# HEARTBEAT AUTONOME — Proactive Notifications (evolution F5)
# ============================================================================
# LLM-driven proactive notifications. Aggregates context (calendar, weather,
# interests, memories) and lets the LLM decide whether to notify the user.
# Two-phase LLM: 1) Decision (structured output) 2) Message (personality-aware).
# Reference: docs/technical/HEARTBEAT_AUTONOME.md
# --- Feature Flag ---
# Global toggle. Must be true for scheduler job and API router to register.
HEARTBEAT_ENABLED=true
# --- Scheduler Configuration ---
# Interval between heartbeat scheduler runs (10-120 minutes)
HEARTBEAT_NOTIFICATION_INTERVAL_MINUTES=30
# Number of users to process per scheduler run (10-200)
HEARTBEAT_NOTIFICATION_BATCH_SIZE=50
# --- Cooldowns ---
# Minimum hours between any two heartbeat notifications for a user (1-12)
HEARTBEAT_GLOBAL_COOLDOWN_HOURS=1
# Don't notify if user sent a message within N minutes (5-60)
HEARTBEAT_ACTIVITY_COOLDOWN_MINUTES=15
# --- Cross-Type Proactive Cooldown ---
# Minimum minutes between any two proactive notifications of different types
# (e.g., interest + heartbeat). Prevents notification bursts for the same user.
# Applies to ALL proactive task types symmetrically. (min: 5, max: 120)
PROACTIVE_CROSS_TYPE_COOLDOWN_MINUTES=10
# --- Context Aggregation ---
# Hours ahead to look for calendar events (1-24)
HEARTBEAT_CONTEXT_CALENDAR_HOURS=4
# Maximum number of user memories to include in context (1-20)
HEARTBEAT_CONTEXT_MEMORY_LIMIT=5
# --- Weather Change Detection Thresholds ---
# Probability of precipitation above which rain is considered likely (0.3-0.9)
HEARTBEAT_WEATHER_RAIN_THRESHOLD_HIGH=0.6
# Probability of precipitation below which rain is considered clearing (0.1-0.5)
HEARTBEAT_WEATHER_RAIN_THRESHOLD_LOW=0.4
# Temperature change in degrees C that triggers a notification (2.0-15.0)
HEARTBEAT_WEATHER_TEMP_CHANGE_THRESHOLD=5.0
# Wind speed in m/s above which a wind alert is triggered (8.0-25.0)
HEARTBEAT_WEATHER_WIND_THRESHOLD=14.0
# --- Early-exit Optimization ---
# Skip heartbeat if user inactive for more than N days (saves LLM tokens) (1-30)
HEARTBEAT_INACTIVE_SKIP_DAYS=7

# ============================================================================
# FILE ATTACHMENTS (evolution F4)
# ============================================================================
# Upload images (JPEG, PNG, GIF, WebP, HEIC) and documents (PDF) in chat.
# Vision LLM analysis via configurable model (Admin > LLM Config > vision_analysis).
# Reference: docs/technical/ATTACHMENTS_INTEGRATION.md
# --- Feature Flag ---
ATTACHMENTS_ENABLED=true
# --- Storage ---
ATTACHMENTS_STORAGE_PATH=/app/data/attachments
ATTACHMENTS_MAX_IMAGE_SIZE_MB=10
ATTACHMENTS_MAX_DOC_SIZE_MB=20
ATTACHMENTS_MAX_PER_MESSAGE=5
# --- Lifecycle ---
ATTACHMENTS_TTL_HOURS=24
# --- PDF Processing ---
ATTACHMENTS_MAX_PDF_TEXT_CHARS=50000

# ============================================================================
# SKILLS (agentskills.io standard)
# ============================================================================
# Reference: docs/technical/SKILLS_INTEGRATION.md
# --- Feature Flag ---
SKILLS_ENABLED=true
# --- Paths ---
# Directory for admin/system skills (git-tracked, shipped with app)
SKILLS_SYSTEM_PATH=data/skills/system
# Directory for user-imported skills (per-user subdirectories)
SKILLS_USERS_PATH=data/skills/users
# --- Limits ---
# Maximum skills per user (1-100)
SKILLS_MAX_PER_USER=20
# --- Script Execution ---
# Enable Python script execution from skill scripts/ directories
SKILLS_SCRIPTS_ENABLED=false
# Timeout for script execution (5-120 seconds)
SKILLS_SCRIPT_TIMEOUT_SECONDS=30
# Maximum script output size (1-500 KB)
SKILLS_SCRIPT_MAX_OUTPUT_KB=50
# Maximum script input size (1-500 KB)
SKILLS_SCRIPT_MAX_INPUT_KB=100

# ============================================================================
# RAG SPACES (User Knowledge Documents)
# Allows users to create knowledge spaces, upload documents (PDF, TXT, MD, DOCX),
# and enrich AI responses with relevant content via hybrid search (semantic + BM25).
# ============================================================================
# --- Feature Flag ---
RAG_SPACES_ENABLED=true
# --- Storage ---
RAG_SPACES_STORAGE_PATH=/app/data/rag_uploads
RAG_SPACES_MAX_FILE_SIZE_MB=20
RAG_SPACES_MAX_SPACES_PER_USER=10
RAG_SPACES_MAX_DOCS_PER_SPACE=50
# --- Chunking ---
RAG_SPACES_CHUNK_SIZE=1000
RAG_SPACES_CHUNK_OVERLAP=200
# --- Retrieval ---
RAG_SPACES_RETRIEVAL_LIMIT=5
RAG_SPACES_RETRIEVAL_MIN_SCORE=0.5
RAG_SPACES_MAX_CONTEXT_TOKENS=2000
RAG_SPACES_HYBRID_ALPHA=0.7
# --- Embedding ---
RAG_SPACES_EMBEDDING_MODEL=text-embedding-3-small
RAG_SPACES_EMBEDDING_DIMENSIONS=1536

# ============================================================================
# V3 DISPLAY
# ============================================================================
# Viewport breakpoints for responsive formatting (pixels)
V3_DISPLAY_VIEWPORT_MOBILE_MAX_WIDTH=430
# Show action buttons below HTML cards (reply, archive, directions, etc.)
# Set to false to hide all suggested action buttons
V3_DISPLAY_SHOW_ACTION_BUTTONS=false

# ============================================================================
# HOST PORT OVERRIDES (optional - for running multiple instances)
# ============================================================================
# Override default host ports when running alongside another dev stack.
# These only affect the host-side port mapping, not internal container ports.
# Default values (shown after :-) are used when variables are not set.
#
# POSTGRES_HOST_PORT=5433
# PGADMIN_HOST_PORT=5051
# REDIS_HOST_PORT=6380
# API_HOST_PORT=8001
# DEBUG_HOST_PORT=5679
# API_METRICS_HOST_PORT=9191
# WEB_HOST_PORT=3010
# PROMETHEUS_HOST_PORT=9190
# ALERTMANAGER_HOST_PORT=9194
# GRAFANA_HOST_PORT=3011
# LOKI_HOST_PORT=3110
# PROMTAIL_HOST_PORT=9180
# TEMPO_HOST_PORT=3210
# OTLP_GRPC_HOST_PORT=4327
# OTLP_HTTP_HOST_PORT=4328
# CADVISOR_HOST_PORT=8081
# PG_EXPORTER_HOST_PORT=9287
# REDIS_EXPORTER_HOST_PORT=9221
# NODE_EXPORTER_HOST_PORT=9200
# MINIO_API_HOST_PORT=9292
# MINIO_CONSOLE_HOST_PORT=9293
# LANGFUSE_HOST_PORT=3012
# LANGFUSE_WORKER_HOST_PORT=3040
