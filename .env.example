CONTEXT_REFERENCE_RESOLUTION_ENABLED=true                   # Enable reference resolution for follow-up questions (default: true)
CONTEXT_ACTIVE_WINDOW_TURNS=3                               # Active context window in conversation turns (default: 3)
CONTEXT_CURRENT_ITEM_CONFIDENCE=0.95                        # Confidence for current item references (default: 0.95)
CONTEXT_DEMONSTRATIVE_CONFIDENCE=0.8                        # Confidence for demonstrative references (default: 0.8)
CONTEXT_RESOLUTION_TIMEOUT_MS=500                           # Timeout for context resolution in ms (default: 500)
DEFAULT_ITEM_CONFIDENCE=0.5                                 # Default confidence when items lack explicit score (default: 0.5)
QUERY_ENGINE_SIMILARITY_THRESHOLD=0.93                      # Duplicate query detection (SequenceMatcher, not embeddings). Calibrated 2026-04-09.


