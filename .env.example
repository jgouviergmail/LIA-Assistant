# ============================================================================
# [01] ENVIRONMENT & LOGGING
# Config: src/core/config/__init__.py
# ============================================================================

ENVIRONMENT=development                                     # valid: development, staging, production
DEBUG=true                                                  # Enable debug mode (verbose errors, etc.)
DOCKER_CONTAINER=false                                      # Set to true inside Docker containers (auto-detected, do not set manually)
LOG_LEVEL=INFO                                              # valid: DEBUG, INFO, WARNING, ERROR, CRITICAL
HTTP_LOG_LEVEL=DEBUG                                        # Log level for HTTP request events (default: DEBUG, filtered by LOG_LEVEL)
HTTP_LOG_EXCLUDE_PATHS=/metrics,/health                     # Comma-separated paths to exclude from HTTP logging
LOG_LEVEL_HTTPX=ERROR                                       # httpx library log level
LOG_LEVEL_SQLALCHEMY=ERROR                                  # SQLAlchemy library log level
LOG_LEVEL_UVICORN=ERROR                                     # Uvicorn server log level
LOG_LEVEL_UVICORN_ACCESS=ERROR                              # Uvicorn access log level


# ============================================================================
# [02] SECURITY & AUTHENTICATION
# Config: src/core/config/security.py
# ============================================================================

# Generate with: openssl rand -base64 32 (minimum 32 characters)
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256                                             # JWT signing algorithm
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_FERNET_KEY
SESSION_COOKIE_NAME=lia_session                             # Session cookie name
SESSION_COOKIE_SECURE=true                                  # Require HTTPS for cookies (always true in production)
SESSION_COOKIE_HTTPONLY=true                                 # Prevent XSS access to cookies
SESSION_COOKIE_SAMESITE=lax                                 # CSRF protection (valid: strict, lax, none)
SESSION_COOKIE_MAX_AGE=604800                                # Session cookie max age in seconds (default: 604800 = 7 days)
SESSION_COOKIE_MAX_AGE_REMEMBER=2592000                      # Session cookie max age with remember-me (default: 2592000 = 30 days)
# Set to "localhost" for local dev, ".yourdomain.com" for production
SESSION_COOKIE_DOMAIN=.yourdomain.com


# ============================================================================
# [03] DATABASE (PostgreSQL)
# Config: src/core/config/database.py
# ============================================================================

POSTGRES_USER=CHANGE_ME_DB_USER                             # PostgreSQL username (used by docker-compose)
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD                        # PostgreSQL password (used by docker-compose)
POSTGRES_DB=lia                                             # Database name
# For Docker: use service name (postgres). For local dev: use localhost
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# Used by integration tests with testcontainers (auto-generated, leave empty)
TEST_DATABASE_URL=
DATABASE_POOL_SIZE=30                                       # Persistent connections (default: 30)
DATABASE_MAX_OVERFLOW=30                                    # Burst capacity for peak load (default: 30)
DATABASE_POOL_TIMEOUT=30                                    # Seconds to wait for a connection (default: 30)
DATABASE_POOL_RECYCLE=1800                                  # Recycle connections every N seconds (default: 1800 = 30min)


# ============================================================================
# [04] REDIS
# Config: src/core/config/database.py
# ============================================================================

# Avoid special chars ($, @, #, %) — they require URL encoding in REDIS_URL
REDIS_PASSWORD=CHANGE_ME_PASSWORD
# For Docker: use service name (redis). For local dev: use localhost
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_SESSION_DB=1                                          # Redis DB index for sessions
REDIS_CACHE_DB=2                                            # Redis DB index for application cache
REDIS_MAX_CONNECTIONS=100                                   # Max connections per pool (default: 100)
REDIS_SOCKET_TIMEOUT=30                                     # Seconds before closing idle connection (default: 30)
REDIS_SOCKET_CONNECT_TIMEOUT=5                              # Connection timeout in seconds (default: 5)
REDIS_HEALTH_CHECK_INTERVAL=30                              # Seconds between PING health checks (default: 30)


# ============================================================================
# [05] API SERVER & CORS
# Config: src/core/config/__init__.py
# ============================================================================

API_HOST=0.0.0.0                                            # API bind address
API_PORT=8000                                               # API listen port
API_PREFIX=/api/v1                                          # API route prefix
CORS_ORIGINS=https://lia.yourdomain.com,https://lia-back.yourdomain.com  # Comma-separated allowed origins
FRONTEND_URL=https://lia.yourdomain.com                     # Frontend URL (used for email links, CORS)
API_URL=https://lia-back.yourdomain.com                     # Public API URL


# ============================================================================
# [06] WEB FRONTEND (Next.js)
# Config: apps/web/.env (Next.js reads from root .env)
# ============================================================================

NODE_ENV=development                                        # valid: development, production
# Browser-side API URL (HTTPS). For LAN: https://<your-ip>.nip.io:8000
NEXT_PUBLIC_API_URL=https://localhost:8000
# Server-side API URL for SSR/Server Actions (Docker service name)
API_URL_SERVER=https://api:8000
# HTTP fallback for Next.js rewrites (proxy cannot validate self-signed certs)
API_URL_SERVER_HTTP=http://api:8000
# Application URL. For LAN: https://<your-ip>.nip.io:3000
NEXT_PUBLIC_APP_URL=https://localhost:3000
NEXT_PUBLIC_LOG_LEVEL=info                                  # Frontend log level (valid: debug, info, warn, error, none)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID     # Google OAuth Client ID (public, safe for frontend)
NEXT_PUBLIC_APP_NAME=LIA                                    # Application display name
# Hostname only (not full URL) for Next.js 16+ dev origin check. For LAN: <your-ip>.nip.io
NEXT_PUBLIC_ALLOWED_DEV_ORIGINS=localhost
JINJA_MAX_RECURSION_DEPTH=20                                # Jinja2 template recursion limit (default: 20)


# ============================================================================
# [07] SSL (Development only)
# Config: infrastructure/docker-compose.yml (ssl-init service)
# ============================================================================

# Domain for self-signed SSL certificates (used by ssl-init container in dev)
# For LAN access, use nip.io with your local IP (e.g., 192.168.1.100.nip.io)
# The IP is automatically extracted from nip.io domains for SAN inclusion
# Not needed in production (use real certificates from Let's Encrypt, etc.)
#SSL_DOMAIN=192.168.1.100.nip.io


# ============================================================================
# [08] DOCKER SERVICES CREDENTIALS
# Config: infrastructure/docker-compose.yml
# ============================================================================

PGADMIN_DEFAULT_EMAIL=admin@lia.local                       # PgAdmin login email
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PASSWORD                 # PgAdmin login password
GRAFANA_ADMIN_USER=CHANGE_ME_GRAFANA_USER                   # Grafana admin username
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_PASSWORD                   # Grafana admin password
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER                        # MinIO (S3-compatible) admin user
MINIO_ROOT_PASSWORD=CHANGE_ME_PASSWORD                      # MinIO admin password
LANGFUSE_DB_USER=CHANGE_ME_LANGFUSE_DB_USER                 # Langfuse PostgreSQL user
LANGFUSE_DB_PASSWORD=CHANGE_ME_PASSWORD                     # Langfuse PostgreSQL password
CLICKHOUSE_USER=CHANGE_ME_CLICKHOUSE_USER                   # Langfuse ClickHouse user
CLICKHOUSE_PASSWORD=CHANGE_ME_PASSWORD                      # Langfuse ClickHouse password
LANGFUSE_REDIS_PASSWORD=CHANGE_ME_PASSWORD                  # Langfuse Redis password
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_SECRET_KEY               # Langfuse NextAuth secret
LANGFUSE_SALT=CHANGE_ME_SALT                                # Langfuse password salt
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_64_HEX_CHARS  # 64-char hex encryption key


# ============================================================================
# [09] HOST PORT OVERRIDES
# Config: infrastructure/docker-compose.yml
# ============================================================================
# Override default host ports when running alongside another dev stack.
# These only affect the host-side port mapping, not internal container ports.
# Default values (shown after :-) are used when variables are not set.

POSTGRES_HOST_PORT=5432
PGADMIN_HOST_PORT=5050
REDIS_HOST_PORT=6379
API_HOST_PORT=8000
DEBUG_HOST_PORT=5678
API_METRICS_HOST_PORT=9091
WEB_HOST_PORT=3000
PROMETHEUS_HOST_PORT=9090
ALERTMANAGER_HOST_PORT=9094
GRAFANA_HOST_PORT=3001
LOKI_HOST_PORT=3100
PROMTAIL_HOST_PORT=9080
TEMPO_HOST_PORT=3200
OTLP_GRPC_HOST_PORT=4317
OTLP_HTTP_HOST_PORT=4318
CADVISOR_HOST_PORT=8080
PG_EXPORTER_HOST_PORT=9187
REDIS_EXPORTER_HOST_PORT=9121
NODE_EXPORTER_HOST_PORT=9100
MINIO_API_HOST_PORT=9092
MINIO_CONSOLE_HOST_PORT=9093
LANGFUSE_HOST_PORT=3002
LANGFUSE_WORKER_HOST_PORT=3030


# ============================================================================
# [10] OAUTH PROVIDERS (Google, Microsoft, Apple)
# Config: src/core/config/connectors.py
# ============================================================================

# --- Google OAuth ---
# Get from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Create separate Client IDs for dev and prod (security best practice)
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
# Backend handles OAuth callback. Production: https://yourdomain.com/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=https://lia-back.yourdomain.com/api/v1/auth/google/callback
# Google API Key (for Places photos, Drive thumbnails, etc.)
GOOGLE_API_KEY=CHANGE_ME_API_KEY
# Google Gemini API Key (dedicated key restricted to Generative Language API — used for embeddings)
GOOGLE_GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY

# --- Microsoft 365 OAuth (Entra ID / Azure AD) ---
# Get from Azure Portal: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Redirect URIs: https://<domain>/api/v1/connectors/microsoft-outlook/callback (+ calendar, contacts, tasks)
MICROSOFT_CLIENT_ID=CHANGE_ME_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
MICROSOFT_TENANT_ID=common                                  # valid: common, consumers, organizations

# --- Apple iCloud ---
# Uses Apple ID + app-specific password (not OAuth). Requires 2FA.
# Generate at: https://appleid.apple.com/
APPLE_IMAP_HOST=imap.mail.me.com                            # Apple IMAP server
APPLE_IMAP_PORT=993                                         # Apple IMAP port (SSL)
APPLE_SMTP_HOST=smtp.mail.me.com                            # Apple SMTP server
APPLE_SMTP_PORT=587                                         # Apple SMTP port (STARTTLS)
APPLE_SMTP_DAILY_LIMIT=1000                                 # Apple imposes 1000 messages/day
APPLE_SMTP_MAX_RECIPIENTS=500                               # 500 recipients per message
APPLE_SMTP_MAX_SIZE_MB=20                                   # 20 MB per message
APPLE_CALDAV_URL=https://caldav.icloud.com                  # CalDAV endpoint (Apple Calendar)
APPLE_CARDDAV_URL=https://contacts.icloud.com               # CardDAV endpoint (Apple Contacts)
APPLE_CONNECTION_TIMEOUT=30.0                               # Connection timeout in seconds
CLIENT_RATE_LIMIT_APPLE_PER_SECOND=5                        # Rate limit for Apple API calls
APPLE_CONTACTS_CACHE_TTL=600                                # Full contacts list cache TTL (10 min)
APPLE_EMAIL_MESSAGE_CACHE_TTL=60                            # IMAP message cache TTL (solves N+1)

# --- Philips Hue Remote API (optional) ---
# Register at https://developers.meethue.com/ to get credentials
HUE_REMOTE_CLIENT_ID=                                       # Leave empty to disable
HUE_REMOTE_CLIENT_SECRET=
HUE_REMOTE_APP_ID=

# --- Brave Search ---
# No global API key — each user configures their own via Settings > Connectors
CLIENT_RATE_LIMIT_BRAVE_SEARCH_PER_SECOND=20.0              # Rate limit for Brave Search API
BRAVE_SEARCH_CACHE_TTL_SECONDS=3600                         # Cache TTL for search results (1 hour)


# ============================================================================
# [11] LLM PROVIDERS & API KEYS
# Config: src/core/config/llm.py, src/infrastructure/llm/factory.py
# ============================================================================
#
# NOTE: Per-agent LLM model, temperature, and max_tokens are NOT set here.
# They are managed via Admin > LLM Configuration (database-backed, hot-reloadable).
# Only provider-level API keys and base URLs belong in this file.
# See: docs/technical/LLM_CONFIG_ADMIN.md
#

# OpenAI API Key (read by openai SDK, used by langchain-openai)
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_ORGANIZATION_ID=                                     # OpenAI Organization ID (optional, leave empty if not needed)

# External API Keys (optional — leave empty to disable)
OPENWEATHERMAP_API_KEY=                                     # OpenWeatherMap API key (for weather tools)
GOOGLE_PLACES_API_KEY=                                      # Google Places API key (for place search/details)

# Ollama Base URL (for local/self-hosted models)
# For Docker: use host.docker.internal to reach host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Knowledge Enrichment (Brave Search integration for LLM context)
KNOWLEDGE_ENRICHMENT_ENABLED=true                           # Enrich responses with web search results

# Perplexity search model (used by web search tool)
PERPLEXITY_SEARCH_MODEL=sonar                               # valid: sonar, sonar-pro, sonar-reasoning

# Token Encoding for tiktoken (accurate token counting and cost estimation)
TOKEN_ENCODING_NAME=o200k_base                              # valid: o200k_base (gpt-4.1+), cl100k_base (older GPT-4)


# ============================================================================
# [12] LLM CACHING & COST TRACKING
# Config: src/core/config/llm.py
# ============================================================================

LLM_CACHE_ENABLED=false                                     # Enable LLM response caching for Router/Planner
LLM_CACHE_TTL_SECONDS=60                                    # Cache TTL in seconds (default: 300)
CONVERSATION_ID_CACHE_TTL_SECONDS=60                        # Conversation ID cache TTL (avoids DB lookup, range: 60-3600)
DEFAULT_CURRENCY=EUR                                        # Currency for cost reporting (valid: USD, EUR)
LLM_PRICING_CACHE_TTL_SECONDS=3600                          # LLM pricing cache TTL (default: 3600 = 1 hour)
DEFAULT_USD_EUR_RATE=0.93                                   # Fallback USD/EUR rate when DB/API unavailable
CURRENCY_API_URL=https://api.frankfurter.dev                # Currency exchange rates API endpoint


# ============================================================================
# [13] LLM MIDDLEWARE & RESILIENCE
# Config: src/infrastructure/llm/middleware_config.py
# ============================================================================

# SummarizationMiddleware — Context Compression
SUMMARIZATION_MODEL=gpt-4.1-nano                            # Model for context summarization
SUMMARIZATION_TRIGGER_FRACTION=0.7                          # Context window fraction to trigger summarization
SUMMARIZATION_KEEP_MESSAGES=10                              # Messages to keep after summarization

# ModelRetryMiddleware — Automatic LLM Retry
RETRY_MAX_ATTEMPTS=3                                        # Max retry attempts on LLM failure
RETRY_BACKOFF_FACTOR=2.0                                    # Exponential backoff multiplier
RETRY_INITIAL_DELAY=1.0                                     # Initial delay in seconds before first retry (default: 1.0)
RETRY_MAX_DELAY=60.0                                        # Maximum delay cap in seconds (default: 60.0)
RETRY_JITTER=true                                           # Add random jitter to retry delays (default: true)

# ModelFallbackMiddleware — Multi-Provider Resilience
ENABLE_FALLBACK_MIDDLEWARE=false                             # Enable cross-provider fallback
FALLBACK_MODELS=claude-sonnet-4-5,deepseek-chat             # Comma-separated fallback model chain

# ToolRetryMiddleware — Tool Execution Resilience
TOOL_RETRY_MAX_ATTEMPTS=3                                   # Max retry attempts on tool failure
TOOL_RETRY_BACKOFF_FACTOR=1.5                               # Exponential backoff multiplier

# ModelCallLimitMiddleware — Cost & Loop Protection
MODEL_CALL_THREAD_LIMIT=100                                 # Max LLM calls per thread
MODEL_CALL_RUN_LIMIT=20                                     # Max LLM calls per run

# ContextEditingMiddleware — Tool Result Pruning
CONTEXT_EDIT_MAX_TOOL_RESULT_TOKENS=5000                    # Max tokens per tool result in context


# ============================================================================
# [14] TOKEN MANAGEMENT
# Config: src/core/config/agents.py
# ============================================================================

# Progressive thresholds for catalogue reduction when prompt is too long.
# GPT-4.1-mini supports 128k context. Quality degrades at higher thresholds.
TOKEN_THRESHOLD_SAFE=20000                                  # Below = full catalogue (default: 80000)
TOKEN_THRESHOLD_WARNING=30000                               # Above = "essential" reduction (default: 100000)
TOKEN_THRESHOLD_CRITICAL=40000                              # Above = "minimal" reduction (default: 110000)
TOKEN_THRESHOLD_MAX=50000                                   # Above = emergency fallback (default: 120000)
TOKEN_COUNT_DEFAULT_MODEL=gpt-4.1-mini                      # Model used for tiktoken token counting (default: gpt-4.1-mini)


# ============================================================================
# [15] OBSERVABILITY — OpenTelemetry & Prometheus
# Config: src/core/config/observability.py
# ============================================================================

# For Docker: use service name (tempo). For local dev: use localhost
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317               # OpenTelemetry collector endpoint
OTEL_SERVICE_NAME=lia-api                                   # Service name in traces
OTEL_SDK_DISABLED=false                                     # Set to true to disable OpenTelemetry (useful for tests)
PROMETHEUS_METRICS_PORT=9091                                 # Dedicated HTTP metrics port (separate from main HTTPS API)


# ============================================================================
# [16] OBSERVABILITY — GeoIP
# Config: src/core/config/observability.py
# ============================================================================

GEOIP_ENABLED=true                                          # Enrich HTTP logs with geographic data
GEOIP_DB_PATH=/data/geoip/dbip-city-lite.mmdb               # Path to MMDB file (downloaded during Docker build)


# ============================================================================
# [17] OBSERVABILITY — Langfuse
# Config: src/core/config/observability.py
# ============================================================================

LANGFUSE_ENABLED=false                                      # Enable Langfuse LLM tracing
# For Docker: use service name (langfuse-web). For local dev: use localhost:3002
LANGFUSE_HOST=http://langfuse-web:3000                      # Langfuse self-hosted URL
LANGFUSE_PUBLIC_KEY=CHANGE_ME_API_KEY                       # Langfuse public API key
LANGFUSE_SECRET_KEY=CHANGE_ME_SECRET_KEY                    # Langfuse secret API key
LANGFUSE_RELEASE=development                                # Release version for deployment tracking
LANGFUSE_SAMPLE_RATE=1.0                                    # Trace sample rate (0.0-1.0, recommended: 0.1-0.5 in prod)
LANGFUSE_FLUSH_INTERVAL=600                                 # Seconds between trace flushes (lower = more real-time)
LANGFUSE_DEBUG=true                                         # Enable SDK debug logging (disable in production)


# ============================================================================
# [18] OBSERVABILITY — Langfuse Evaluators
# Config: src/core/config/observability.py
# ============================================================================

EVALUATOR_ENABLED=true                                      # Enable LLM-as-judge evaluation pipeline (default: true)
EVALUATOR_HALLUCINATION_REQUIRE_GROUND_TRUTH=false           # Require ground truth for hallucination eval
EVALUATOR_PIPELINE_SEND_TO_LANGFUSE=false                   # Auto-send evaluation scores to Langfuse
EVALUATOR_HALLUCINATION_MAX_TOKENS=1000                     # Max tokens for hallucination evaluator response (default: 1000)
EVALUATOR_RELEVANCE_MAX_TOKENS=500                          # Max tokens for relevance evaluator response (default: 500)


# ============================================================================
# [19] OBSERVABILITY — LangChain SDK
# Config: environment variable (read by LangChain SDK)
# ============================================================================

LANGCHAIN_CALLBACKS_BACKGROUND=false                        # Run LangChain callbacks in background (true = non-blocking)


# ============================================================================
# [20] SMTP & ALERTING
# Config: infrastructure/alertmanager/alertmanager.yml
# ============================================================================

ALERTMANAGER_SMTP_SMARTHOST=CHANGE_ME_SMTP_HOST:587         # SMTP server:port
ALERTMANAGER_SMTP_AUTH_USERNAME=CHANGE_ME_SMTP_USERNAME      # SMTP auth username
ALERTMANAGER_SMTP_AUTH_PASSWORD=CHANGE_ME_SMTP_PASSWORD      # SMTP auth password
APPLICATION_SMTP_FROM=noreply@yourdomain.com                # Application email sender
ALERTMANAGER_SMTP_FROM=alerts@yourdomain.com                # Monitoring alert sender
ALERTMANAGER_BACKEND_TEAM_EMAIL=your-email@example.com      # Backend alerts recipient
ALERTMANAGER_FINANCE_TEAM_EMAIL=your-email@example.com      # Finance alerts recipient
ALERTMANAGER_SECURITY_TEAM_EMAIL=your-email@example.com     # Security alerts recipient
ALERTMANAGER_ML_TEAM_EMAIL=your-email@example.com           # ML/AI alerts recipient
ALERTMANAGER_SLACK_WEBHOOK_CRITICAL=                        # Slack webhook for critical alerts (optional)
ALERTMANAGER_SLACK_WEBHOOK_WARNING=                         # Slack webhook for warning alerts (optional)
ALERTMANAGER_SLACK_WEBHOOK_SECURITY=                        # Slack webhook for security alerts (optional)
ALERTMANAGER_PAGERDUTY_ROUTING_KEY=                         # PagerDuty routing key (optional)


# ============================================================================
# [21] SCORING — Intent Detection
# Config: src/core/config/agents.py
# ============================================================================
# Determines confidence in the user intent: search, details, create, chat, etc.

SEMANTIC_INTENT_FALLBACK_THRESHOLD=0.7                      # Below = uncertain intent, use fallback (default: 0.50)
SEMANTIC_INTENT_HIGH_THRESHOLD=0.85                         # Above = certain intent (default: 0.75)
SEMANTIC_FALLBACK_THRESHOLD=0.75                            # Global fallback safety net (default: 0.4)


# ============================================================================
# [22] SCORING — Domain Selection
# Config: src/core/config/agents.py
# ============================================================================
# Softmax temperature calibration to amplify score differences between domains.

V3_DOMAIN_SOFTMAX_TEMPERATURE=0.8                           # Softmax temperature (lower = stronger discrimination, recommended: 0.1)
V3_DOMAIN_CALIBRATED_PRIMARY_MIN=0.75                       # Min calibrated score for primary domain
V3_DOMAIN_MIN_RANGE_FOR_DISCRIMINATION=0.03                 # Min raw score range for meaningful discrimination
SEMANTIC_DOMAIN_MAX_DOMAINS=3                               # Max domains selected per query (default: 3)


# ============================================================================
# [23] SCORING — Routing Decision
# Config: src/core/config/agents.py
# ============================================================================
# Decides: chat (direct response, ~500 tokens) vs planner (tool execution, ~3000-6000 tokens).
# TOKEN IMPACT: Critical — bad routing wastes 5000+ tokens.

V3_ROUTING_HIGH_SEMANTIC_THRESHOLD=0.8                      # Above = clearly planner (default: 0.7)
V3_ROUTING_CHAT_SEMANTIC_THRESHOLD=0.7                      # Below = clearly chat (default: 0.4)
V3_ROUTING_MIN_CONFIDENCE=0.75                              # Min confidence for planner in ambiguous zone (default: 0.6)
V3_ROUTING_CHAT_OVERRIDE_THRESHOLD=0.85                     # Chat intent override when confidence >= this (default: 0.85)
V3_ROUTING_CROSS_DOMAIN_THRESHOLD=0.5                       # Cross-domain reference routing threshold (default: 0.5)
ROUTER_CONFIDENCE_HIGH=0.8                                  # High confidence threshold for router decisions (default: 0.8)
ROUTER_CONFIDENCE_MEDIUM=0.6                                # Medium confidence threshold (default: 0.6)
ROUTER_CONFIDENCE_LOW=0.4                                   # Low confidence threshold (default: 0.4)
ROUTER_DEBUG_LOG_ENABLED=false                              # Enable separate debug log for router reasoning (default: false)
ROUTER_DEBUG_LOG_PATH=/var/log/lia/router_debug.log         # Path for router debug log file (default: /var/log/lia/router_debug.log)
V3_DOMAIN_SCORE_DELTA_MIN=0.05                              # Min score delta between top and secondary domains (default: 0.05)
V3_DOMAIN_SECONDARY_THRESHOLD=0.80                          # Min absolute score for secondary domains (default: 0.80)
