SEMANTIC_DOMAIN_SOFT_THRESHOLD=0.65                         # Soft threshold for domain selection (default: 0.65)


# ============================================================================
# [24] SCORING — Tool Selection
# Config: src/core/config/agents.py
# ============================================================================
# Filters tools sent to LLM. Fewer tools = shorter prompt = fewer tokens + hallucinations.

V3_TOOL_SOFTMAX_TEMPERATURE=0.1                             # Softmax temperature for tool scoring (0.1 = strong discrimination)
V3_TOOL_CALIBRATED_PRIMARY_MIN=0.07                         # Min calibrated score for primary tool
SEMANTIC_TOOL_SELECTOR_MAX_TOOLS=8                          # Max tools sent to LLM per query
SEMANTIC_TOOL_SELECTOR_HARD_THRESHOLD=0.70                  # Hard threshold for tool selection (default: 0.70)
SEMANTIC_TOOL_SELECTOR_SOFT_THRESHOLD=0.60                  # Soft threshold for tool selection (default: 0.60)
V3_TOOL_SELECTOR_HYBRID_ENABLED=true                        # Enable hybrid scoring (description + keywords) (default: true)
V3_TOOL_SELECTOR_HYBRID_ALPHA=0.6                           # Hybrid weight: semantic vs keyword (default: 0.6)
V3_TOOL_SELECTOR_HYBRID_MODE=first_line                     # Hybrid mode: first_line or full (default: first_line)


