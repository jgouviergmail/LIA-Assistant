APPROVAL_COST_THRESHOLD_USD=5.00                            # Cost threshold in USD triggering approval (default: 5.00)
APPROVAL_AUTO_APPROVE_ROLES=["admin","power_user"]                # JSON list of roles that auto-approve (default: admin,power_user)
