CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3                         # Successes needed to close circuit (default: 3)
CIRCUIT_BREAKER_TIMEOUT_SECONDS=10                          # Duration before recovery attempt (default: 60)
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3                       # Calls allowed in half-open to test (default: 3)


