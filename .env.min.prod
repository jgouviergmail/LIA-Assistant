# ============================================================================
# LIA - MINIMAL PRODUCTION CONFIGURATION
# ============================================================================
# This file contains ONLY the essential variables needed for a working deployment.
# For the full configuration with all options, see .env.example
#
# Steps:
# 1. Copy this file to .env
# 2. Replace all CHANGE_ME_* placeholders with real values
# 3. Generate secrets:
#    - SECRET_KEY: openssl rand -base64 32
#    - FERNET_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
# Generate with: openssl rand -base64 32 (minimum 32 characters)
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_FERNET_KEY

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD
POSTGRES_DB=lia
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ============================================================================
# REDIS
# ============================================================================
REDIS_PASSWORD=CHANGE_ME_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ============================================================================
# SESSION
# ============================================================================
SESSION_COOKIE_NAME=lia_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=.yourdomain.com

# ============================================================================
# URLS & CORS
# ============================================================================
CORS_ORIGINS=https://lia.yourdomain.com,https://lia-back.yourdomain.com
FRONTEND_URL=https://lia.yourdomain.com
API_URL=https://lia-back.yourdomain.com
NEXT_PUBLIC_API_URL=https://lia-back.yourdomain.com
NEXT_PUBLIC_APP_URL=https://lia.yourdomain.com
API_URL_SERVER=https://lia-back.yourdomain.com

# ============================================================================
# APPLICATION
# ============================================================================
NEXT_PUBLIC_APP_NAME=LIA
ASSISTANT_NAME=LIA
NODE_ENV=production
DEFAULT_LANGUAGE=fr

# ============================================================================
# LLM PROVIDER (at least one required)
# ============================================================================
# Configure at least one LLM provider via the Admin UI (Settings > Administration > LLM Configuration)
# or set API keys here as fallback. The application supports: OpenAI, Anthropic, Google Gemini,
# DeepSeek, Perplexity, and Ollama.
#
# Example for OpenAI (most common):
# OPENAI_API_KEY=CHANGE_ME_API_KEY
#
# Example for Anthropic:
# ANTHROPIC_API_KEY=CHANGE_ME_API_KEY
#
# Example for Google Gemini:
# GEMINI_API_KEY=CHANGE_ME_API_KEY
#
# API keys can also be configured per-provider in the Admin UI (encrypted in DB).
